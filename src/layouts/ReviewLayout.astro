---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { afiliados } from '../data/afiliados.ts';
import { getBreadcrumb, type Categoria } from '../data/estrutura';

interface FaqItem {
	question: string;
	answer: string;
}

// Item do ranking — usado para gerar o ItemList schema
interface RankingItem {
	position: number;
	name: string;
	url: string;
}

// Item de sub-navegação (tabs abaixo do header)
interface SubnavItem {
	label: string;
	href: string;
	icon?: string; // emoji ou texto curto
}

interface Props {
	title: string;
	image?: string;
	description: string;
	publishDate: string;
	updatedDate: string;
	authorName: string;
	authorHref?: string;
	authorRole: string;
	authorImage: string;
	heroGradient?: string;
	faq?: FaqItem[];
	renderFaq?: boolean;
	breadcrumb: { label: string; href?: string }[];
	// Lista de empresas rankeadas para o ItemList schema
	// Ex: [{ position: 1, name: "Contabilidade Com", url: "https://..." }]
	ranking?: RankingItem[];
	// Sub-navegação em tabs (estilo NerdWallet) abaixo do header
	subnav?: SubnavItem[];
}

const {
	title,
	description,
	publishDate,
	updatedDate,
	authorName,
	authorHref,
	authorRole,
	authorImage,
	breadcrumb,
	heroGradient = 'from-[#1a3a5c] to-[#2d6a9f]',
	faq = [],
	renderFaq = true,
	ranking = [],
	subnav = [],
	image,
} = Astro.props;

// Detecta o path atual para marcar o tab ativo
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  datePublished: new Date(publishDate).toISOString(),
  dateModified: new Date(updatedDate).toISOString(),
  ...(image ? { image: new URL(image, Astro.site).href } : {}),
  author: {
    '@type': 'Person',
    name: authorName,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Negócio Certo',
    url: Astro.site?.href ?? '',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).href,
      width: 512,
      height: 512,
    },
  },
};

const faqSchema =
	faq.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faq.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: null;

// #1 — BreadcrumbSchema JSON-LD
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumb.map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.label,
		...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
	})),
};

// #2 — ItemList schema para páginas de ranking ("melhores X")
const itemListSchema =
	ranking.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'ItemList',
				name: title,
				description: description,
				numberOfItems: ranking.length,
				itemListElement: ranking.map((r) => ({
					'@type': 'ListItem',
					position: r.position,
					name: r.name,
					url: r.url,
				})),
			}
		: null;
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="article" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content="pt_BR" />
	
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<link rel="preconnect" href="https://cdnjs.cloudflare.com" />
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
		{itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)}></script>}

		<style>
			/* === Review Subnav === */
			.review-subnav {
				background: #fff;
				border-bottom: 1px solid #f3f4f6;
				width: 100%;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
			}
			.review-subnav::-webkit-scrollbar { display: none; }
			.review-subnav-inner {
				display: flex;
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 20px;
			}
			.review-subnav-item {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 5px;
				padding: 12px 20px 9px;
				text-decoration: none !important;
				color: #6b7280;
				border-bottom: 3px solid transparent;
				transition: color 0.15s, border-color 0.15s;
				flex-shrink: 0;
			}
			.review-subnav-item:hover { color: #111827; }
			.review-subnav-item.active {
				color: #15803d;
				border-bottom-color: #16a34a;
			}
			.subnav-icon {
				font-size: 22px;
				width: 48px;
				height: 48px;
				border-radius: 50%;
				background: #f3f4f6;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: background 0.15s;
			}
			.review-subnav-item.active .subnav-icon { background: #dcfce7; }
			.subnav-label {
				font-size: 12px;
				font-weight: 500;
				white-space: nowrap;
			}
			@media (max-width: 640px) {
				.review-subnav-inner { padding: 0 8px; }
				.review-subnav-item { padding: 10px 14px 8px; }
				.subnav-icon { width: 40px; height: 40px; font-size: 19px; }
			}
		</style>
	</head>
	<body>
		<Header />

		{subnav.length > 0 && (
			<nav class="review-subnav" aria-label="Subcategorias">
				<div class="review-subnav-inner">
					{subnav.map((item) => {
						const itemPath = item.href.replace(/\/$/, '');
						const isActive = currentPath === itemPath;
						return (
							<a href={item.href} class={`review-subnav-item${isActive ? ' active' : ''}`} aria-current={isActive ? 'page' : undefined}>
								{item.icon && <span class="subnav-icon">{item.icon}</span>}
								<span class="subnav-label">{item.label}</span>
							</a>
						);
					})}
				</div>
			</nav>
		)}

		<section class="review-hero">
			<div class="review-hero-container">

				<!-- Breadcrumb -->
				{breadcrumb.length > 0 && (
					<nav aria-label="Breadcrumb" class="review-breadcrumb">
						<ol class="breadcrumb-list">
							{breadcrumb.map((item, index) => (
								<li>
									{index < breadcrumb.length - 1 ? (
										<a href={item.href}>
											{index === 0 ? (
												<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="Home" style="display:inline;vertical-align:middle;margin-bottom:1px;">
													<path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
												</svg>
											) : item.label}
										</a>
									) : (
										<span>{item.label}</span>
									)}
									{index < breadcrumb.length - 1 && <span class="rbc-sep">›</span>}
								</li>
							))}
						</ol>
					</nav>
				)}

				<!-- Título e Descrição -->
				<h1 class="review-hero-title">{title}</h1>
				<p class="review-hero-desc">{description}</p>

	
				<!-- Meta: avatar | (escrito por / data + verificado) -->
				<div class="review-hero-meta">
					<img
						src={authorImage}
						alt={`Foto de ${authorName}`}
						width="48"
						height="48"
						loading="eager"
						fetchpriority="high"
						class="review-hero-avatar"
					/>
					<div class="review-meta-text">
						<div class="review-meta-row1">
							Escrito por <a href={authorHref ?? '#'} class="review-hero-author-name" rel="author">{authorName}</a>
						</div>
						<div class="review-meta-row2">
							<span class="review-meta-date">
								Última atualização em <time datetime={updatedDate}>{new Date(updatedDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>.
							</span>
							<span class="review-meta-sep">|</span>
							<span class="review-meta-verified">
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
								VERIFICADO
							</span>
							<span class="review-meta-sep">|</span>
							<span class="review-meta-integrity">INTEGRIDADE EDITORIAL</span>
						</div>
					</div>
				</div>

			</div>
		</section>

		<!--
			SLOT RANKING
			============
			REGRAS PARA A IA — LEIA ANTES DE GERAR O CONTEÚDO:

			1. Use EXATAMENTE esta abertura, sem alterar nada:
			   <div slot="ranking" style="padding: 0 24px;">

			2. NÃO adicione background/cor de fundo — o azul é do hero acima

			3. O wrapper dos cards deve ter EXATAMENTE:
			   <div class="contabilidade-wrapper" id="wrapper">

			4. O overlay do fade deve ter EXATAMENTE:
			   <div class="fade-overlay" id="fadeOverlay">

			5. O botão ver mais deve ter EXATAMENTE:
			   onclick="showMore()"

			6. NÃO adicione <style> — todos os estilos já estão neste layout

			7. NÃO adicione <script> — todas as funções já estão neste layout:
			   showMore(), toggleAccordion(this), toggleFaq(this)
		-->
		<div class="ranking-preview-wrap">
			<div class="ranking-preview-header">
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
				<span>Pouco tempo pra ler? Veja os <strong>3 primeiros</strong> do ranking abaixo</span>
			</div>
			<slot name="ranking" />
		</div>

		<div class="review-main-container">
			<div class="flex-1 min-w-0">
				<!--
					SLOT PRINCIPAL (conteúdo do artigo)
					=====================================
					REGRAS PARA A IA:

					1. NÃO adicione <script> — as funções já existem:
					   - Accordions: onclick="toggleAccordion(this)"
					   - FAQ: onclick="toggleFaq(this)"

					2. NÃO adicione <style> — todos os estilos já estão no layout

					3. Cada review deve ter 4 accordions nesta ordem:
					   - Análise do editor
					   - Preços
					   - Vantagens e desvantagens
					   - Avaliação dos clientes

					4. Estrutura obrigatória do FAQ:
					   <div class="faq-container">
					     <div class="faq-item">
					       <div class="faq-question" onclick="toggleFaq(this)">
					         <span>Pergunta</span>
					         <span class="faq-icon"><i class="fa fa-chevron-down"></i></span>
					       </div>
					       <div class="faq-answer"><p>Resposta</p></div>
					     </div>
					   </div>
				-->
				<article>
					<slot />
					{faq.length > 0 && renderFaq && (
						<section class="mt-16">
							<h2>Perguntas Frequentes</h2>
							{faq.map((item) => (
								<div class="mb-6">
									<h3>{item.question}</h3>
									<p>{item.answer}</p>
								</div>
							))}
						</section>
					)}
				</article>
			</div>

			<div class="hidden md:block w-64 shrink-0" style="position: sticky; top: 100px; align-self: flex-start; height: fit-content;">
				<slot name="sidebar-offers" />
				<div id="custom-toc-widget">
					<h3 class="toc-title" id="toc-toggle" onclick="toggleToc()" style="cursor:pointer; display:flex; justify-content:space-between; align-items:center;">
						Navegue pelo conteúdo
						<span id="toc-chevron" style="font-size:11px; color:#9ca3af; transition:transform 0.2s; display:inline-block;">▼</span>
					</h3>
					<div id="toc-body" style="display:none; overflow:hidden; transition:max-height 0.3s ease;">
						<ul id="custom-toc-list"></ul>
					</div>
				</div>
			</div>
		</div>

		<!--
			SCRIPTS GLOBAIS
			===============
			NÃO replique nenhuma destas funções nos arquivos de artigo.
		-->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function () {
				document.querySelectorAll('.contabilidade-container').forEach(function (card) {
					var logoCol = card.querySelector('.logo-column');
					var ratingCol = card.querySelector('.rating-column');
					if (!logoCol || !ratingCol) return;

					// Move rating para dentro do logo-column
					logoCol.appendChild(ratingCol);
					ratingCol.style.display = 'block';

					// Gerar estrelas dinâmicas
					var scoreEl = ratingCol.querySelector('.rating-score');
					if (!scoreEl) return;
					var score = parseFloat(scoreEl.textContent.replace(',', '.'));
					if (score > 5) score = score / 2; // converte /10 para /5
					var score5 = score.toFixed(1).replace('.', ',');
					var full = Math.floor(score);
					var partial = score - full;
					var empty = 5 - full - (partial > 0 ? 1 : 0);
					var html = '<div class="rating-row"><div class="stars-display">';
					for (var i = 0; i < full; i++) html += '<span class="star-full">★</span>';
					if (partial > 0) {
						var pct = Math.round(partial * 100);
						html += '<span class="star-partial"><span class="star-fill" style="width:' + pct + '%">★</span>★</span>';
					}
					for (var i = 0; i < empty; i++) html += '<span class="star-empty">★</span>';
					html += '</div><span class="score-num">' + score5 + '/5</span></div>';
					ratingCol.innerHTML = html;
				});
			});

			window.toggleAccordion = function (el) {
				const item = el.parentElement;
				const header = el;
				const isActive = item.classList.contains('active');
				item.classList.toggle('active');
				// Atualiza aria-expanded para acessibilidade (#15 da auditoria)
				header.setAttribute('aria-expanded', isActive ? 'false' : 'true');
			};

			/* toggleFaq — FAQ do artigo
			   Requer class="faq-question" no div clicável e class="faq-icon" no ícone */
			window.toggleFaq = function (el) {
				const item = el.parentElement;
				const icon = el.querySelector('.faq-icon i');
				const isActive = item.classList.contains('active');
				item.classList.toggle('active');
				if (icon) icon.className = isActive ? 'fa fa-chevron-down' : 'fa fa-chevron-up';
				// Atualiza aria-expanded para acessibilidade
				el.setAttribute('aria-expanded', isActive ? 'false' : 'true');
			};

			/* toggleToc — abre/fecha o índice lateral */
			window.toggleToc = function() {
				var body = document.getElementById('toc-body');
				var chevron = document.getElementById('toc-chevron');
				if (!body) return;
				var isOpen = body.style.display !== 'none';
				body.style.display = isOpen ? 'none' : 'block';
				if (chevron) chevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
			};

			/* Fecha o TOC ao iniciar rolagem (apenas uma vez) */
			window.addEventListener('scroll', function tocCollapseOnScroll() {
				var body = document.getElementById('toc-body');
				if (body && body.style.display !== 'none') {
					body.style.display = 'none';
					var chevron = document.getElementById('toc-chevron');
					if (chevron) chevron.style.transform = 'rotate(0deg)';
				}
				window.removeEventListener('scroll', tocCollapseOnScroll);
			}, { passive: true });

			/* showMore — botão "Ver Todas" do ranking
			   Requer id="wrapper" no div pai e id="fadeOverlay" no overlay */
			function showMore() {
				const wrapper = document.getElementById('wrapper');
				const overlay = document.getElementById('fadeOverlay');
				if (wrapper) wrapper.classList.remove('content-hidden');
				if (overlay) overlay.classList.add('hidden');
			}

			window.addEventListener('DOMContentLoaded', function() {
				const wrapper = document.getElementById('wrapper');
				if (wrapper) wrapper.classList.add('content-hidden');
			});

			document.addEventListener('DOMContentLoaded', function () {
				const contentSelectors = ['.entry-content', '.elementor-widget-theme-post-content', '.post-content', 'article', 'main'];
				let contentContainer = null;
				for (let s of contentSelectors) {
					let el = document.querySelector(s);
					if (el) {
						contentContainer = el;
						break;
					}
				}
				if (!contentContainer) return;

				const headings = contentContainer.querySelectorAll('h2, h3');
				if (headings.length === 0) return;

				const widget = document.getElementById('custom-toc-widget');
				const list = document.getElementById('custom-toc-list');
				widget.style.display = 'block';
				/* TOC começa fechado — body oculto, chevron normal */
				var tocBody = document.getElementById('toc-body');
				if (tocBody) tocBody.style.display = 'none';

				headings.forEach((heading, index) => {
					if (!heading.id) heading.id = 'toc-' + index;
					const li = document.createElement('li');
					const a = document.createElement('a');
					li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-h3' : 'toc-h2';
					a.href = '#' + heading.id;
					a.textContent = heading.textContent;
					a.addEventListener('click', function (e) {
						e.preventDefault();
						const target = document.getElementById(heading.id);
						const offset = 120;
						const bodyRect = document.body.getBoundingClientRect().top;
						const elementRect = target.getBoundingClientRect().top;
						const offsetPosition = elementRect - bodyRect - offset;
						window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
						document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
						li.classList.add('active');
					});
					li.appendChild(a);
					list.appendChild(li);
				});

				window.addEventListener('scroll', function () {
					let scrollY = window.scrollY;
					let currentId = '';
					headings.forEach((heading) => {
						if (scrollY >= heading.offsetTop - 150) currentId = heading.id;
					});
					if (currentId) {
						document.querySelectorAll('#custom-toc-list li').forEach((li) => {
							const link = li.querySelector('a');
							if (link.getAttribute('href') === '#' + currentId) {
								if (!li.classList.contains('active')) {
									document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
									li.classList.add('active');
									const widgetHeight = widget.clientHeight;
									const itemTop = li.offsetTop;
									const itemHeight = li.clientHeight;
									const currentScroll = widget.scrollTop;
									if (itemTop < currentScroll || itemTop + itemHeight > currentScroll + widgetHeight) {
										widget.scrollTo({ top: itemTop - widgetHeight / 2 + itemHeight / 2, behavior: 'smooth' });
									}
								}
							}
						});
					}
				});

				if (list.firstChild) list.firstChild.classList.add('active');
			});
		</script>

		<style is:global>
			/* ===== RANKING PREVIEW CARD ===== */
			.ranking-preview-wrap {
				max-width: 1200px;
				margin: -72px auto 56px;
				padding: 0 40px;
				position: relative;
				z-index: 10;
			}
			.ranking-preview-header {
				max-width: 840px;
				background: #eff8ff;
				border: 1px solid #bfdbfe;
				border-bottom: none;
				border-radius: 14px 14px 0 0;
				padding: 11px 20px;
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 13px;
				font-weight: 600;
				color: #2563eb;
				font-family: 'Nunito Sans', 'Inter', sans-serif;
			}
			.ranking-preview-header strong { font-weight: 800; }
			.contabilidade-wrapper {
				font-family: 'Nunito Sans', 'Inter', Arial, sans-serif;
				max-width: 840px;
				background: #ffffff;
				border: 1px solid #e5e7eb;
				border-radius: 0 0 14px 14px;
				box-shadow: 0 8px 32px rgba(0,0,0,0.10);
				overflow: hidden;
				margin: 0;
				padding: 0 !important;
				position: relative;
				z-index: 10;
			}
			/* Cancelar o padding do slot div nos pages */
			.ranking-preview-wrap > div[style] { padding: 0 !important; }
			.contabilidade-container {
				background: white;
				border-radius: 0;
				box-shadow: none;
				padding: 18px 12px 18px 24px;
				width: 100%;
				box-sizing: border-box;
				border-bottom: 1px solid #f0f2f5;
			}
			.contabilidade-container:last-child { border-bottom: none; }
			/* Remover estilo especial do primeiro card */
			.contabilidade-container:first-child {
				border: none;
				border-bottom: 1px solid #f0f2f5;
				margin-top: 0;
				position: static;
				z-index: auto;
			}
			.contabilidade-grid {
				display: grid;
				grid-template-columns: 140px 1.5fr 1.4fr;
				gap: 12px;
				align-items: center;
			}
			.logo-column {
				grid-column: 1;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				justify-content: center;
				gap: 8px;
				align-self: stretch;
			}
			/* rating-column movido para dentro do logo-column via JS */
			.rating-column { display: none; }
			.info-column {
				grid-column: 2;
				display: flex;
				flex-direction: column;
