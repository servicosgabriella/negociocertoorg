---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

/*
  INSTRUÇÕES PARA A IA — POSTS DE BLOG
  =====================================
  Posts devem ser arquivos .md na pasta src/content/blog/
  NÃO crie posts como .astro — use SEMPRE .md

  FRONTMATTER OBRIGATÓRIO DE CADA POST:
  --------------------------------------
  ---
  title: "Título do post"
  description: "Descrição curta para SEO (máx 160 caracteres)"
  pubDate: 2026-02-01
  updatedDate: 2026-02-22
  authorName: "Nome do Autor"
  authorRole: "Cargo do Autor"
  authorImage: "/images/foto-autor.webp"
  authorHref: "/autor/nome-do-autor/"
  coverImage: "/images/foto-capa.webp"
  coverAlt: "Descrição da imagem de capa"
  breadcrumb:
    - label: "Home"
      href: "/"
    - label: "Blog"
      href: "/blog/"
    - label: "Título do post"
  faq:
    - question: "Pergunta 1?"
      answer: "Resposta 1."
    - question: "Pergunta 2?"
      answer: "Resposta 2."
  ---

  REGRAS DO CONTEÚDO:
  -------------------
  - Escreva o conteúdo em Markdown abaixo do frontmatter
  - Use ## para h2 e ### para h3
  - NÃO adicione <style> ou <script> no post — tudo já está neste layout
  - O FAQ no frontmatter é opcional — se não tiver, omita o campo faq
*/

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate: string;
  authorName: string;
  authorRole: string;
  authorImage: string;
  authorHref?: string;
  coverImage: string;
  coverAlt: string;
  breadcrumb?: { label: string; href?: string }[];
  category?: string;
  categoryHref?: string;
  faq?: { question: string; answer: string }[];
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  authorName,
  authorRole,
  authorImage,
  authorHref = '',
  coverImage,
  coverAlt,
  breadcrumb: customBreadcrumb = [],
  category,
  categoryHref,
  faq = [],
} = Astro.props;

// Generate breadcrumb: if category is provided, show Home > Category
// Otherwise fall back to custom breadcrumb
const breadcrumb = category && categoryHref
  ? [
      { label: 'Home', href: '/' },
      { label: category, href: categoryHref }
    ]
  : customBreadcrumb;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const coverImageAbsolute = new URL(coverImage, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  datePublished: new Date(publishDate).toISOString(),
  dateModified: new Date(updatedDate).toISOString(),
  image: coverImageAbsolute,
  author: { '@type': 'Person', name: authorName },
  publisher: {
    '@type': 'Organization',
    name: 'Negócio Certo',
    url: Astro.site?.href ?? '',
  },
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
  })),
};
---

<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={coverImageAbsolute} />
  <meta property="og:locale" content="pt_BR" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={coverImageAbsolute} />

  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
</head>
<body>
  <Header />

  <!-- HERO VERDE -->
  <section class="blog-hero">
    <div class="blog-hero-container">

      <!-- Breadcrumb -->
      {breadcrumb.length > 0 && (
        <nav aria-label="Breadcrumb" class="blog-breadcrumb">
          <ol class="breadcrumb-list">
            {breadcrumb.map((item, index) => (
              <li>
                {index < breadcrumb.length - 1 ? (
                  <a href={item.href}>
                    {index === 0 ? (
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="Home" style="display:inline;vertical-align:middle;margin-bottom:1px;">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                      </svg>
                    ) : item.label}
                  </a>
                ) : (
                  <span>{item.label}</span>
                )}
                {index < breadcrumb.length - 1 && <span class="sep">›</span>}
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Título e Descrição -->
      <h1 class="blog-hero-title">{title}</h1>
      <p class="blog-hero-desc">{description}</p>

      <!-- Divisor -->
      <hr class="blog-hero-divider" />

      <!-- Meta: autor + data -->
      <div class="blog-hero-meta">
        <div class="blog-hero-author">
          <img
            src={authorImage}
            alt={`Foto de ${authorName}`}
            width="44"
            height="44"
            loading="eager"
            fetchpriority="high"
            class="blog-hero-avatar"
          />
          <div class="blog-hero-author-info">
            <span class="blog-hero-author-label">Escrito por</span>
            {authorHref ? (
              <a href={authorHref} class="blog-hero-author-name" rel="author">{authorName}</a>
            ) : (
              <strong class="blog-hero-author-name">{authorName}</strong>
            )}
          </div>
        </div>
        <div class="blog-hero-date">
          <i class="fa-regular fa-clock" aria-hidden="true"></i>
          <span>Última atualização:</span>
          <time datetime={updatedDate}>
            {new Date(updatedDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
      </div>

    </div>
  </section>

  <!-- LAYOUT PRINCIPAL: conteúdo esquerda + sidebar direita (sobrepõe o hero) -->
  <div class="blog-main-wrap">
    <div class="blog-main-layout">

      <!-- CONTEÚDO PRINCIPAL -->
      <div class="blog-content-card">
        <!--
          SLOT DO CONTEÚDO
          - NÃO adicione <style> aqui — estilos já estão neste layout
          - NÃO adicione <script> aqui — TOC já está neste layout
          - Use ## para h2 e ### para h3 no markdown
          - O FAQ é gerado automaticamente pelo frontmatter
        -->
        <article>
          <slot />
          {faq.length > 0 && (
            <section class="blog-faq">
              <h2>Perguntas Frequentes</h2>
              {faq.map(item => (
                <details class="blog-faq-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </section>
          )}
        </article>
      </div>

      <!-- SIDEBAR: imagem de capa + TOC -->
      <aside class="blog-sidebar">
        <div class="blog-sidebar-inner">
          <!-- Imagem de capa -->
          <div class="blog-sidebar-cover">
            <img
              src={coverImage}
              alt={coverAlt}
              loading="eager"
              fetchpriority="high"
            />
          </div>

          <!-- TOC -->
          <div id="custom-toc-widget">
            <h3 class="toc-title">Neste artigo</h3>
            <ul id="custom-toc-list"></ul>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <Footer />

  <!-- SCRIPT DO TOC -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const contentContainer = document.querySelector('article');
      if (!contentContainer) return;

      const headings = contentContainer.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      const widget = document.getElementById('custom-toc-widget');
      const list = document.getElementById('custom-toc-list');
      widget.style.display = 'block';

      headings.forEach((heading, index) => {
        if (!heading.id) heading.id = 'toc-' + index;
        const li = document.createElement('li');
        const a = document.createElement('a');
        li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-h3' : 'toc-h2';
        a.href = '#' + heading.id;
        a.textContent = heading.textContent;
        a.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.getElementById(heading.id);
          const offset = 120;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementRect = target.getBoundingClientRect().top;
          const offsetPosition = elementRect - bodyRect - offset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
          document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
          li.classList.add('active');
        });
        li.appendChild(a);
        list.appendChild(li);
      });

      window.addEventListener('scroll', function () {
        let currentId = '';
        headings.forEach((heading) => {
          if (window.scrollY >= heading.offsetTop - 150) currentId = heading.id;
        });
        if (currentId) {
          document.querySelectorAll('#custom-toc-list li').forEach((li) => {
            const link = li.querySelector('a');
            if (link.getAttribute('href') === '#' + currentId) {
              if (!li.classList.contains('active')) {
                document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
                li.classList.add('active');
                const widgetHeight = widget.clientHeight;
                const itemTop = li.offsetTop;
                const itemHeight = li.clientHeight;
                const currentScroll = widget.scrollTop;
                if (itemTop < currentScroll || itemTop + itemHeight > currentScroll + widgetHeight) {
                  widget.scrollTo({ top: itemTop - widgetHeight / 2 + itemHeight / 2, behavior: 'smooth' });
                }
              }
            }
          });
        }
      });

      if (list.firstChild) list.firstChild.classList.add('active');
    });
  </script>

  <style is:global>
    /* ===================== HERO ===================== */
    .blog-hero {
      background:
        linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px),
        linear-gradient(135deg, #0d4a28 0%, #1d6b3d 45%, #3aaa62 100%);
      background-size: 44px 44px, 44px 44px, auto;
      padding: 40px 0 96px;
    }
    .blog-hero-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      box-sizing: border-box;
    }

    /* Breadcrumb */
    .blog-breadcrumb {
      margin: 0 0 20px 0;
      padding: 0;
    }
    .blog-breadcrumb ol {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
    }
    .blog-breadcrumb li {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      margin: 0;
      padding: 0;
    }
    .blog-breadcrumb a {
      color: #ffffff;
      text-decoration: none;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 12px;
    }
    .blog-breadcrumb a:hover { color: #fff; text-decoration: underline; }
    .blog-breadcrumb span { color: #ffffff; font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 500; }
    .blog-breadcrumb .sep { color: rgba(255,255,255,0.60); }

    /* Título e descrição */
    .blog-hero-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      color: #ffffff;
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      font-weight: 800;
      line-height: 1.2;
      margin: 0 0 16px;
      letter-spacing: -0.3px;
    }
    .blog-hero-desc {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      color: rgba(255,255,255,0.85);
      font-size: 1.1rem;
      line-height: 1.6;
      margin: 0 0 28px;
    }

    /* Divisor */
    .blog-hero-divider {
      border: none;
      border-top: 0.5px solid #e9fd62;
      margin: 0 0 24px;
    }

    /* Meta: autor + data */
    .blog-hero-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .blog-hero-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .blog-hero-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid rgba(255,255,255,0.3);
    }
    .blog-hero-author-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .blog-hero-author-label {
      font-size: 11px;
      color: rgba(255,255,255,0.65);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .blog-hero-author-name {
      font-size: 14px;
      color: #ffffff;
      font-weight: 700;
      text-decoration: none;
    }
    a.blog-hero-author-name:hover { text-decoration: underline; }
    .blog-hero-author-role {
      font-size: 12px;
      color: rgba(255,255,255,0.65);
    }
    .blog-hero-date {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 15px;
      color: rgba(255,255,255,0.80);
      font-family: 'Nunito Sans', 'Inter', sans-serif;
    }
    .blog-hero-date i { font-size: 14px; }
    .blog-hero-date time { font-weight: 600; color: #fff; }

    /* ===================== LAYOUT PRINCIPAL ===================== */
    .blog-main-wrap {
      background: #f3f4f6;
      padding-bottom: 64px;
    }
    .blog-main-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      gap: 28px;
      align-items: flex-start;
      position: relative;
      top: -56px;
      margin-bottom: -56px;
    }

    /* Card de conteúdo */
    .blog-content-card {
      flex: 1;
      min-width: 0;
      background: #ffffff;
      border-radius: 12px;
      padding: 40px 44px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    }

    /* Sidebar */
    .blog-sidebar {
      width: 300px;
      flex-shrink: 0;
    }
    .blog-sidebar-inner {
      position: sticky;
      top: 100px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* Imagem de capa na sidebar */
    .blog-sidebar-cover {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
    .blog-sidebar-cover img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
      aspect-ratio: 16/10;
    }

    /* ===================== TYPOGRAPHY ===================== */
    article h2 {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: #111827;
      margin: 36px 0 12px;
      line-height: 1.3;
      border-left: 4px solid #2d6a4f;
      padding-left: 14px;
    }
    article h3 {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: #1f2937;
      margin: 24px 0 8px;
      line-height: 1.4;
    }
    article h4 {
      font-size: 0.95rem;
      font-weight: 700;
      color: #111827;
      margin: 16px 0 6px;
    }
    article p {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1rem;
      color: #374151;
      line-height: 1.8;
      margin-bottom: 18px;
    }
    article ul, article ol {
      padding-left: 1.5em;
      margin-bottom: 16px;
      list-style-position: outside;
    }
    article ul { list-style-type: disc; }
    article ol { list-style-type: decimal; }
    article li {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 4px;
      margin-left: 1em;
    }
    article strong { color: #111827; font-weight: 700; }
    article a { color: #2d6a4f; text-decoration: none; font-weight: 500; }
    article a:hover { text-decoration: underline; }

    /* FAQ */
    .blog-faq { margin-top: 48px; }
    .blog-faq-item {
      margin-bottom: 10px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 14px 16px;
      background: #f9fafb;
    }
    .blog-faq-item summary {
      cursor: pointer;
      font-weight: 700;
      color: #1f2937;
      font-size: 15px;
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .blog-faq-item summary::after {
      content: '+';
      font-size: 18px;
      color: #2d6a4f;
      font-weight: 400;
    }
    .blog-faq-item[open] summary::after { content: '−'; }
    .blog-faq-item p { margin-top: 12px; margin-bottom: 0; font-size: 0.95rem; }

    /* ===================== TOC WIDGET ===================== */
    #custom-toc-widget {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 16px 0 16px;
      width: 100%;
      box-sizing: border-box;
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      display: none;
      max-height: 50vh;
      overflow-y: auto;
      overscroll-behavior-y: contain;
    }
    #custom-toc-widget::-webkit-scrollbar { width: 4px; }
    #custom-toc-widget::-webkit-scrollbar-track { background: transparent; }
    #custom-toc-widget::-webkit-scrollbar-thumb { background-color: #d1d5db; border-radius: 4px; }

    #custom-toc-widget h3.toc-title {
      font-size: 11px;
      font-weight: 700;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 0 0 12px;
      padding: 0 16px;
    }
    #custom-toc-list { list-style: none; padding: 0; margin: 0; }
    #custom-toc-list li {
      position: relative;
      padding: 5px 16px 5px 20px;
      background: transparent !important;
      margin: 0;
      line-height: 1;
    }
    #custom-toc-list li::before {
      content: "";
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background-color: transparent;
      border-radius: 0 4px 4px 0;
      transition: background-color 0.2s ease;
    }
    #custom-toc-list a {
      text-decoration: none !important;
      color: #6b7280 !important;
      font-size: 13px !important;
      display: block;
      line-height: 1.4;
      transition: color 0.2s;
    }
    #custom-toc-list li.toc-h2 a { font-weight: 500; }
    #custom-toc-list li.toc-h3 { padding-left: 32px; }
    #custom-toc-list li.toc-h3 a { font-size: 12px !important; color: #9ca3af !important; }
    #custom-toc-list a:hover { color: #2d6a4f !important; }
    #custom-toc-list li.active::before { background-color: #2d6a4f; }
    #custom-toc-list li.active a { font-weight: 700 !important; color: #2d6a4f !important; }

    /* ===================== MOBILE ===================== */
    @media (max-width: 900px) {
      .blog-main-layout { flex-direction: column-reverse; gap: 20px; }
      .blog-sidebar { width: 100%; }
      .blog-sidebar-inner { position: static; }
      .blog-sidebar-cover img { max-height: 260px; object-fit: cover; }
      #custom-toc-widget { display: none !important; }
    }
    @media (max-width: 600px) {
      .blog-hero { padding: 32px 0 80px; }
      .blog-hero-title { font-size: 1.5rem; }
      .blog-hero-meta { flex-direction: column; align-items: flex-start; }
      .blog-content-card { padding: 24px 20px; }
      .blog-main-layout { padding: 0 16px; top: -40px; margin-bottom: -40px; }
    }
  </style>

</body>
</html>