---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

/*
  INSTRUÇÕES PARA A IA — POSTS DE BLOG
  =====================================
  Posts devem ser arquivos .md na pasta src/content/blog/
  NÃO crie posts como .astro — use SEMPRE .md

  FRONTMATTER OBRIGATÓRIO DE CADA POST:
  --------------------------------------
  ---
  title: "Título do post"
  description: "Descrição curta para SEO (máx 160 caracteres)"
  pubDate: 2026-02-01
  updatedDate: 2026-02-22
  authorName: "Nome do Autor"
  authorRole: "Cargo do Autor"
  authorImage: "/images/foto-autor.webp"
  authorHref: "/autor/nome-do-autor/"
  coverImage: "/images/foto-capa.webp"
  coverAlt: "Descrição da imagem de capa"
  breadcrumb:
    - label: "Home"
      href: "/"
    - label: "Blog"
      href: "/blog/"
    - label: "Título do post"
  faq:
    - question: "Pergunta 1?"
      answer: "Resposta 1."
    - question: "Pergunta 2?"
      answer: "Resposta 2."
  ---

  REGRAS DO CONTEÚDO:
  -------------------
  - Escreva o conteúdo em Markdown abaixo do frontmatter
  - Use ## para h2 e ### para h3
  - NÃO adicione <style> ou <script> no post — tudo já está neste layout
  - O FAQ no frontmatter é opcional — se não tiver, omita o campo faq
*/

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate: string;
  authorName: string;
  authorRole: string;
  authorImage: string;
  authorHref?: string;
  coverImage: string;
  coverAlt: string;
  breadcrumb?: { label: string; href?: string }[];
  category?: string;
  categoryHref?: string;
  faq?: { question: string; answer: string }[];
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  authorName,
  authorRole,
  authorImage,
  authorHref = '',
  coverImage,
  coverAlt,
  breadcrumb: customBreadcrumb = [],
  category,
  categoryHref,
  faq = [],
} = Astro.props;

// Generate breadcrumb: if category is provided, show Home > Category
// Otherwise fall back to custom breadcrumb
const breadcrumb = category && categoryHref
  ? [
      { label: 'Home', href: '/' },
      { label: category, href: categoryHref }
    ]
  : customBreadcrumb;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const coverImageAbsolute = new URL(coverImage, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  datePublished: new Date(publishDate).toISOString(),
  dateModified: new Date(updatedDate).toISOString(),
  image: coverImageAbsolute,
  author: { '@type': 'Person', name: authorName },
  publisher: {
    '@type': 'Organization',
    name: 'Negócio Certo',
    url: Astro.site?.href ?? '',
  },
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
  })),
};
---

<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={coverImageAbsolute} />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Negócio Certo" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={coverImageAbsolute} />

  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
</head>
<body>
  <Header />

  <!-- HERO AZUL -->
  <section class="blog-hero">
    <div class="blog-hero-container">
      <div class="blog-hero-content">
        <nav aria-label="Breadcrumb" class="breadcrumb-nav" style="font-size: 13px; margin: 0 0 16px 0; padding: 0; display: block; width: 100%;">
          <ol class="breadcrumb-list" style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; align-items: center; gap: 4px;">
            {breadcrumb.map((item, index) => (
              <li style="display: flex; align-items: center; gap: 4px;">
                {index < breadcrumb.length - 1 ? (
                  <a href={item.href} style="color: #bfdbfe; text-decoration: none;">{item.label}</a>
                ) : (
                  <span style="color: #ffffff; font-weight: 500;">{item.label}</span>
                )}
                {index < breadcrumb.length - 1 && <span style="color: #bfdbfe;">›</span>}
              </li>
            ))}
          </ol>
        </nav>
        <h1 class="blog-hero-title">{title}</h1>
        <p style="color: #bfdbfe; font-size: 1.125rem; margin-bottom: 24px;">{description}</p>
        <div style="display: flex; align-items: center; gap: 12px;">
          <img src={authorImage} alt={`Foto de ${authorName}`} width="40" height="40"
            loading="eager" fetchpriority="high"
            style="width:40px; height:40px; border-radius:50%; object-fit:cover; flex-shrink:0;" />
          <div>
            <div style="color: #dce4f1; font-size: 13px;">
              Escrito por: {authorHref ? (
                <a href={authorHref} style="color: white; text-decoration: underline; font-weight: 700;" rel="author">{authorName}</a>
              ) : (
                <strong style="color: white;">{authorName}</strong>
              )} · <span style="color: #dce4f1;">{authorRole}</span>
            </div>
            <div style="color: #bfdbfe; font-size: 13px; margin-top: 4px;">
              <i class="fa-regular fa-clock" aria-hidden="true"></i>
              <span style="font-weight: bold;"> Última atualização:</span>
              <time datetime={updatedDate}>{new Date(updatedDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGEM DE CAPA — alinhada com o conteúdo -->
  <div class="blog-cover-wrapper">
    <img
      class="blog-cover-image"
      src={coverImage}
      alt={coverAlt}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- CONTEÚDO + TOC LATERAL -->
  <div class="blog-layout">
    <div class="blog-content">
      <!--
        SLOT DO CONTEÚDO
        =================
        REGRAS PARA A IA:
        - NÃO adicione <style> aqui — os estilos já estão neste layout
        - NÃO adicione <script> aqui — o TOC já está neste layout
        - Use ## para h2 e ### para h3 no markdown
        - O FAQ é gerado automaticamente pelo frontmatter, não precisa escrever no conteúdo
      -->
      <article>
        <slot />
        {faq.length > 0 && (
          <section style="margin-top: 48px;">
            <h2>Perguntas Frequentes</h2>
            {faq.map(item => (
              <details style="margin-bottom: 12px; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px 14px; background: #fff;">
                <summary style="cursor: pointer; font-weight: 700; color: #4b5563; font-size: 15px;">{item.question}</summary>
                <p style="margin-top: 10px; margin-bottom: 0;">{item.answer}</p>
              </details>
            ))}
          </section>
        )}
      </article>
    </div>

    <!-- TOC LATERAL -->
    <div class="blog-toc-column">
      <div id="custom-toc-widget">
        <h3 class="toc-title">Navegue pelo conteúdo</h3>
        <ul id="custom-toc-list"></ul>
      </div>
    </div>
  </div>

  <Footer />

  <!-- SCRIPT DO TOC — NÃO REPLIQUE NOS POSTS -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const contentSelectors = ['article', 'main'];
      let contentContainer = null;
      for (let s of contentSelectors) {
        let el = document.querySelector(s);
        if (el) { contentContainer = el; break; }
      }
      if (!contentContainer) return;

      const headings = contentContainer.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      const widget = document.getElementById('custom-toc-widget');
      const list = document.getElementById('custom-toc-list');
      widget.style.display = 'block';

      headings.forEach((heading, index) => {
        if (!heading.id) heading.id = 'toc-' + index;
        const li = document.createElement('li');
        const a = document.createElement('a');
        li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-h3' : 'toc-h2';
        a.href = '#' + heading.id;
        a.textContent = heading.textContent;
        a.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.getElementById(heading.id);
          const offset = 120;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementRect = target.getBoundingClientRect().top;
          const offsetPosition = elementRect - bodyRect - offset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
          document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
          li.classList.add('active');
        });
        li.appendChild(a);
        list.appendChild(li);
      });

      window.addEventListener('scroll', function () {
        let scrollY = window.scrollY;
        let currentId = '';
        headings.forEach((heading) => {
          if (scrollY >= heading.offsetTop - 150) currentId = heading.id;
        });
        if (currentId) {
          document.querySelectorAll('#custom-toc-list li').forEach((li) => {
            const link = li.querySelector('a');
            if (link.getAttribute('href') === '#' + currentId) {
              if (!li.classList.contains('active')) {
                document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
                li.classList.add('active');
                const widgetHeight = widget.clientHeight;
                const itemTop = li.offsetTop;
                const itemHeight = li.clientHeight;
                const currentScroll = widget.scrollTop;
                if (itemTop < currentScroll || itemTop + itemHeight > currentScroll + widgetHeight) {
                  widget.scrollTo({ top: itemTop - widgetHeight / 2 + itemHeight / 2, behavior: 'smooth' });
                }
              }
            }
          });
        }
      });

      if (list.firstChild) list.firstChild.classList.add('active');
    });
  </script>

  <style is:global>
    /* ===================== BLOG LAYOUT ===================== */

    .blog-hero {
      background: linear-gradient(to right, #1a3a5c, #2d6a9f);
      padding: 40px 0 48px;
    }
    .blog-hero-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0;
      box-sizing: border-box;
      overflow: hidden;
    }
    .blog-hero-content {
      max-width: 100%;
      box-sizing: border-box;
      text-align: left;
      padding: 0 24px;
      display: block;
    }
    .blog-hero-content > nav {
      width: 100%;
    }
    .blog-hero-content > h1 {
      width: 100%;
    }
    .breadcrumb-nav {
      display: none !important;
      padding: 0 !important;
      margin: 0 !important;
      width: 100% !important;
    }
    @media (min-width: 768px) {
      .breadcrumb-nav {
        display: block !important;
      }
    }
    .blog-hero nav {
      padding: 0 !important;
      margin: 0 !important;
      display: block !important;
      width: 100% !important;
    }
    .blog-hero nav ol {
      padding: 0 !important;
      margin: 0 !important;
      display: flex !important;
      width: 100%;
      margin-left: 0 !important;
    }
    .blog-hero nav li {
      padding: 0 !important;
      margin: 0 !important;
      margin-left: 0 !important;
      display: flex !important;
    }
    .blog-hero-title {
      color: white;
      font-size: 2.25rem;
      font-weight: 800;
      line-height: 1.25;
      margin-top: 0;
      margin-bottom: 16px;
    }

    .blog-cover-wrapper {
      max-width: 1200px;
      margin: -32px auto 0;
      padding: 0 24px;
      box-sizing: border-box;
      overflow: hidden;
    }
    .blog-cover-image {
      width: 100%;
      max-width: 100%;
      height: 400px;
      object-fit: cover;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.15);
      display: block;
    }

    .blog-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px;
      display: flex;
      gap: 40px;
    }
    .blog-content {
      flex: 1;
      min-width: 0;
    }
    .blog-toc-column {
      width: 256px;
      flex-shrink: 0;
    }

    /* ===================== ARTICLE TYPOGRAPHY ===================== */
    article h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
      margin: 32px 0 12px 0;
      line-height: 1.3;
    }
    article h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #111827;
      margin: 24px 0 8px 0;
      line-height: 1.4;
    }
    article h4 {
      font-size: 0.95rem;
      font-weight: 700;
      color: #111827;
      margin: 16px 0 6px 0;
    }
    article p {
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 16px;
    }
    article ul, article ol {
      padding-left: 1.5em;
      margin-bottom: 16px;
      list-style-position: outside;
    }
    article ul {
      list-style-type: disc;
    }
    article ol {
      list-style-type: decimal;
    }
    article li {
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 4px;
      margin-left: 1em;
    }
    article strong {
      color: #111827;
      font-weight: 700;
    }
    article a {
      color: #007eff;
      text-decoration: none;
    }
    article a:hover {
      text-decoration: underline;
    }

    /* ===================== TOC WIDGET ===================== */
    #custom-toc-widget {
      background-color: #ffffff;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      position: -webkit-sticky;
      position: sticky;
      top: 100px;
      z-index: 9;
      max-height: 40vh;
      overflow-y: auto;
      overscroll-behavior-y: contain;
      padding: 12px 10px 12px 0;
      width: 100%;
      box-sizing: border-box;
      align-self: flex-start;
      font-family: Arial, sans-serif;
      color: #333;
      display: none;
    }
    #custom-toc-widget::-webkit-scrollbar { width: 4px; }
    #custom-toc-widget::-webkit-scrollbar-track { background: transparent; }
    #custom-toc-widget::-webkit-scrollbar-thumb { background-color: #ddd; border-radius: 4px; }
    #custom-toc-widget h3.toc-title {
      text-transform: uppercase;
      font-weight: 700;
      color: #000;
      font-size: 11px;
      margin: 0 0 8px 0;
      padding-left: 20px;
    }
    #custom-toc-list { list-style: none; padding: 0; margin: 0; }
    #custom-toc-list li {
      margin-bottom: 6px;
      line-height: 1.2;
      position: relative;
      padding-left: 20px;
      background: transparent !important;
    }
    #custom-toc-list li::before {
      content: "";
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px;
      background-color: transparent;
      border-radius: 0 4px 4px 0;
      transition: background-color 0.2s ease;
    }
    #custom-toc-list a {
      text-decoration: none !important;
      color: #666 !important;
      font-size: 12px !important;
      display: block;
      line-height: 1.3;
      transition: color 0.2s ease;
    }
    #custom-toc-list li.toc-h2 a { font-weight: 500; }
    #custom-toc-list li.toc-h3 { padding-left: 30px; }
    #custom-toc-list li.toc-h3 a { font-size: 11px !important; color: #888 !important; }
    #custom-toc-list a:hover { color: #000 !important; }
    #custom-toc-list li.active::before { background-color: #000; }
    #custom-toc-list li.active a { font-weight: 700 !important; color: #000 !important; }

    /* ===================== MOBILE ===================== */
    @media (max-width: 768px) {
      .blog-hero-content { max-width: 100% !important; }
      .blog-hero-title { font-size: 1.5rem; }
      .blog-cover-image { width: 100% !important; height: 240px; }
      .blog-layout { flex-direction: column; gap: 0; }
      .blog-toc-column { display: none; }
      #custom-toc-widget { display: none !important; }
    }
  </style>

</body>
</html>