---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { estrutura, getBreadcrumb, type Categoria } from '../data/estrutura';

/*
  ====================================================================
  INSTRUÇÕES PARA A IA — PÁGINAS DE CONTEÚDO (.astro)
  ====================================================================
  
  Este layout é para artigos que pertencem às CATEGORIAS e SUBCATEGORIAS
  do site (Finanças, Planejamento, Gestão, RH). NÃO é para posts do blog.

  ====================================================================
  REGRAS DE CRIAÇÃO DO ARQUIVO
  ====================================================================
  1. Crie SEMPRE como .astro — NUNCA como .md
  2. Coloque em src/pages/ na RAIZ — NUNCA em subpastas
     ✅ src/pages/contabilidade-online-ou-presencial.astro
     ❌ src/pages/financas/contabilidade-online-ou-presencial.astro
     ❌ src/content/blog/contabilidade-online-ou-presencial.md
  3. O nome do arquivo = slug da URL (sem acentos, tudo minúsculo, hífen)
     Ex: contabilidade-online-ou-presencial.astro → /contabilidade-online-ou-presencial/
  4. Import do layout SEMPRE: import ContentLayout from '../layouts/ContentLayout.astro';
  5. CONFIRA o nome do arquivo antes de salvar — erros de digitação quebram a URL

  ====================================================================
  EXEMPLO COMPLETO DE PÁGINA .astro
  ====================================================================
  ---
  import ContentLayout from '../layouts/ContentLayout.astro';
  ---

  <ContentLayout
    title="Contabilidade Online ou Presencial: Qual Escolher em 2026?"
    description="Descubra as diferenças entre contabilidade online e presencial."
    publishDate="2026-02-24"
    updatedDate="2026-02-24"
    authorName="Gabriella Fernandes"
    authorRole="Especialista em Negócios"
    authorImage="/images/autor/gabriella-fernandes.jpg"
    authorHref="/autor/gabriela.fernandes/"
    category="Finanças"
    subcategory="Contabilidade Online"
    coverImage="/images/contabilidade-online-ou-presencial.jpg"
    coverAlt="Comparação entre contabilidade online e presencial"
    faq={[
      { question: "Pergunta 1?", answer: "Resposta 1." },
    ]}
  >
    <p>Conteúdo HTML aqui...</p>
    <h2>Subtítulo</h2>
    <p>Mais conteúdo...</p>
  </ContentLayout>

  ====================================================================
  PROPS — REFERÊNCIA RÁPIDA
  ====================================================================
  
  OBRIGATÓRIAS:
    title          → Título do artigo (aparece no h1 e meta title)
    description    → Descrição SEO (máx 160 caracteres)
    publishDate    → Data de publicação (formato: "2026-02-24")
    authorName     → Nome completo do autor
    authorRole     → Cargo do autor
    authorImage    → Caminho da foto do autor (/images/...)
    category       → Categoria do Header (ex: "Finanças", "Gestão", "RH", "Planejamento")
    subcategory    → Subcategoria do Header (ex: "Contabilidade Online", "Maquininha de Cartão")
  
  OPCIONAIS:
    updatedDate    → Data da última atualização (se omitido, usa publishDate)
    authorHref     → Link para página do autor (/autor/slug/)
    coverImage     → Imagem de capa (/images/...)
    coverAlt       → Texto alternativo da imagem de capa
    faq            → Array de { question, answer } para FAQ com schema

  NOTA: O breadcrumb é GERADO AUTOMATICAMENTE a partir de category e subcategory.
  NÃO passe breadcrumb manualmente.

  ====================================================================
  REGRAS DO CONTEÚDO HTML
  ====================================================================
  - Escreva em HTML dentro do <ContentLayout>
  - Use <h2> para títulos e <h3> para subtítulos
  - NÃO adicione <style> ou <script> — já estão neste layout
  - NÃO importe Header ou Footer — já estão neste layout
  - O FAQ é renderizado automaticamente via prop faq
  - Tabelas devem usar HTML com inline styles para responsividade

  ====================================================================
  AÇÕES AUTOMÁTICAS PÓS-CRIAÇÃO (A IA DEVE FAZER TUDO ISSO)
  ====================================================================
  Ao criar um artigo com este layout, a IA DEVE executar TODAS as ações
  abaixo SEM que o usuário precise pedir. Isso faz parte do processo
  de criação do artigo.

  1. CRIAR O ARQUIVO .astro
     → Em src/pages/ com o nome correto (slug)

  2. ATUALIZAR O HEADER (src/components/Header.astro)
     → Adicionar o link do artigo no submenu da subcategoria correta
     → Desktop: dentro do .sub-menu da subcategoria
     → Mobile: dentro do .mobile-sub-menu da subcategoria
     → Se a subcategoria ainda não tem sub-menu, criar a estrutura

  3. ATUALIZAR A ESTRUTURA (src/data/estrutura.ts)
     → Adicionar o artigo na categoria/subcategoria correspondente
     → href deve ser "/slug-do-artigo" (sem /blog/, sem categoria na URL)

  4. ATUALIZAR A PÁGINA DO AUTOR (src/pages/autor/[autor].astro)
     → Adicionar o artigo no array de artigos publicados pelo autor

  5. CONFIRMAR COM O USUÁRIO
     → Informar: "Artigo criado. Também atualizei: Header, estrutura.ts e página do autor."
     → Informar a URL final: http://localhost:4321/slug-do-artigo/

  Se algum desses arquivos não existir ou a IA não tiver acesso,
  deve AVISAR o usuário sobre o que falta atualizar manualmente.
*/

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  authorName: string;
  authorRole: string;
  authorImage: string;
  authorHref?: string;
  category: string;
  subcategory: string;
  coverImage?: string;
  coverAlt?: string;
  faq?: { question: string; answer: string }[];
}

const {
  title,
  description,
  publishDate,
  updatedDate = publishDate,
  authorName,
  authorRole,
  authorImage,
  authorHref = '',
  category,
  subcategory,
  coverImage = '',
  coverAlt = '',
  faq = [],
} = Astro.props;

// Busca hrefs de categoria e subcategoria no estrutura.ts
const cat = Object.values(estrutura).find(c => c.label === category);
const sub = cat ? Object.values((cat as any).subcategorias ?? {}).find((s: any) => s.label === subcategory) as any : null;

const breadcrumb = [
  { label: "Home", href: "/" },
  { label: category, href: cat?.href },
  { label: subcategory, href: sub?.href },
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const coverImageAbsolute = coverImage ? new URL(coverImage, Astro.site).href : '';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  datePublished: new Date(publishDate).toISOString(),
dateModified: new Date(updatedDate).toISOString(),
  ...(coverImageAbsolute ? { image: coverImageAbsolute } : {}),
  author: { '@type': 'Person', name: authorName },
  publisher: {
    '@type': 'Organization',
    name: 'Negócio Certo',
    url: Astro.site?.href ?? '',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).href,
      width: 512,
      height: 512,
    },
  },
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
  })),
};
---

<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  {coverImageAbsolute && <meta property="og:image" content={coverImageAbsolute} />}
  <meta property="og:locale" content="pt_BR" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {coverImageAbsolute && <meta name="twitter:image" content={coverImageAbsolute} />}

  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
</head>
<body>
  <Header />

  <!-- HERO VERDE -->
  <section class="cl-hero">
    <div class="cl-hero-container">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="cl-breadcrumb">
        <ol class="cl-breadcrumb-list">
          {breadcrumb.map((item, index) => (
            <li>
              {index < breadcrumb.length - 1 ? (
                item.href ? (
                  <a href={item.href}>
                    {index === 0 ? (
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="Home" style="display:inline;vertical-align:middle;margin-bottom:1px;">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                      </svg>
                    ) : item.label}
                  </a>
                ) : (
                  <span>{item.label}</span>
                )
              ) : (
                <span class="cl-breadcrumb-current">{item.label}</span>
              )}
              {index < breadcrumb.length - 1 && <span class="cl-sep">›</span>}
            </li>
          ))}
        </ol>
      </nav>

      <!-- Título e Descrição -->
      <h1 class="cl-hero-title">{title}</h1>
      <p class="cl-hero-desc">{description}</p>

      <!-- Divisor -->
      <hr class="cl-hero-divider" />

      <!-- Meta: autor + data -->
      <div class="cl-hero-meta">
        <div class="cl-hero-author">
          <img
            src={authorImage}
            alt={`Foto de ${authorName}`}
            width="44"
            height="44"
            loading="eager"
            fetchpriority="high"
            class="cl-hero-avatar"
          />
          <div class="cl-hero-author-info">
            <span class="cl-hero-author-label">Escrito por</span>
            {authorHref ? (
              <a href={authorHref} class="cl-hero-author-name" rel="author">{authorName}</a>
            ) : (
              <strong class="cl-hero-author-name">{authorName}</strong>
            )}
          </div>
        </div>
        <div class="cl-hero-date">
          <i class="fa-regular fa-clock" aria-hidden="true"></i>
          <span>Última atualização:</span>
          <time datetime={updatedDate}>
            {new Date(updatedDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
      </div>

    </div>
  </section>

  <!-- LAYOUT PRINCIPAL: conteúdo esquerda + sidebar direita (sobrepõe o hero) -->
  <div class="cl-main-wrap">
    <div class="cl-main-layout">

      <!-- CONTEÚDO PRINCIPAL -->
      <div class="cl-content-card">
        <article>
          <slot />
          {faq.length > 0 && (
            <section class="cl-faq">
              <h2>Perguntas Frequentes</h2>
              {faq.map(item => (
                <details class="cl-faq-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </section>
          )}
        </article>
      </div>

      <!-- SIDEBAR: Google card + imagem de capa + TOC -->
      <aside class="cl-sidebar">
        <div class="cl-sidebar-inner">
          <div class="cl-sidebar-stack">
            <a href="https://www.google.com/preferences/source?q=negociocerto.org" target="_blank" rel="noopener noreferrer" class="cl-google-card">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="cl-google-icon" aria-hidden="true">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                <path fill="none" d="M0 0h48v48H0z"/>
              </svg>
              <span class="cl-google-text">
                Adicionar <strong>negóciocerto</strong> como fonte preferencial no Google
              </span>
            </a>

            {coverImage && (
              <div class="cl-sidebar-cover">
                <img
                  src={coverImage}
                  alt={coverAlt}
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            )}
          </div>

          <!-- TOC -->
          <div id="custom-toc-widget">
            <h3 class="toc-title">Neste artigo</h3>
            <ul id="custom-toc-list"></ul>
          </div>
        </div>
      </aside>

    </div>
  </div>

  <Footer />

  <!-- SCRIPT DO TOC -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const contentContainer = document.querySelector('article');
      if (!contentContainer) return;

      const headings = contentContainer.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      const widget = document.getElementById('custom-toc-widget');
      const list = document.getElementById('custom-toc-list');
      widget.style.display = 'block';

      headings.forEach((heading, index) => {
        if (!heading.id) heading.id = 'toc-' + index;
        const li = document.createElement('li');
        const a = document.createElement('a');
        li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-h3' : 'toc-h2';
        a.href = '#' + heading.id;
        a.textContent = heading.textContent;
        a.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.getElementById(heading.id);
          const offset = 120;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementRect = target.getBoundingClientRect().top;
          const offsetPosition = elementRect - bodyRect - offset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
          document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
          li.classList.add('active');
        });
        li.appendChild(a);
        list.appendChild(li);
      });

      window.addEventListener('scroll', function () {
        let currentId = '';
        headings.forEach((heading) => {
          if (window.scrollY >= heading.offsetTop - 150) currentId = heading.id;
        });
        if (currentId) {
          document.querySelectorAll('#custom-toc-list li').forEach((li) => {
            const link = li.querySelector('a');
            if (link.getAttribute('href') === '#' + currentId) {
              if (!li.classList.contains('active')) {
                document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
                li.classList.add('active');
                const widgetHeight = widget.clientHeight;
                const itemTop = li.offsetTop;
                const itemHeight = li.clientHeight;
                const currentScroll = widget.scrollTop;
                if (itemTop < currentScroll || itemTop + itemHeight > currentScroll + widgetHeight) {
                  widget.scrollTo({ top: itemTop - widgetHeight / 2 + itemHeight / 2, behavior: 'smooth' });
                }
              }
            }
          });
        }
      });

      if (list.firstChild) list.firstChild.classList.add('active');
    });
  </script>

  <style is:global>
    /* ===================== HERO ===================== */
    .cl-hero {
      background:
        linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px),
        linear-gradient(135deg, #0d4a28 0%, #1d6b3d 45%, #3aaa62 100%);
      background-size: 28px 28px, 28px 28px, auto;
      padding: 40px 0 96px;
    }
    .cl-hero-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      box-sizing: border-box;
    }

    /* Breadcrumb */
    .cl-breadcrumb {
      margin: 0 0 20px 0;
      padding: 0;
    }
    .cl-breadcrumb-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
    }
    .cl-breadcrumb-list li {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      margin: 0;
      padding: 0;
    }
    .cl-breadcrumb-list a {
      color: #ffffff;
      text-decoration: none;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 12px;
    }
    .cl-breadcrumb-list a:hover { color: #fff; text-decoration: underline; }
    .cl-breadcrumb-list span { color: #ffffff; font-size: 12px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 500; }
    .cl-breadcrumb-current { color: rgba(255,255,255,0.75) !important; font-weight: 400 !important; }
    .cl-sep { color: rgba(255,255,255,0.60) !important; }

    /* Título e descrição */
    .cl-hero-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      color: #ffffff;
      font-size: clamp(1.75rem, 3.5vw, 2.75rem);
      font-weight: 800;
      line-height: 1.2;
      margin: 0 0 16px;
      letter-spacing: -0.3px;
    }
    .cl-hero-desc {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      color: rgba(255,255,255,0.85);
      font-size: 1.1rem;
      line-height: 1.6;
      margin: 0 0 28px;
    }

    /* Divisor */
    .cl-hero-divider {
      border: none;
      border-top: 0.5px solid #e9fd62;
      margin: 0 0 24px;
    }

    /* Meta: autor + data */
    .cl-hero-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .cl-hero-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .cl-hero-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      border: 2px solid rgba(255,255,255,0.3);
    }
    .cl-hero-author-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .cl-hero-author-label {
      font-size: 11px;
      color: rgba(255,255,255,0.65);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .cl-hero-author-name {
      font-size: 14px;
      color: #ffffff;
      font-weight: 700;
      text-decoration: none;
    }
    a.cl-hero-author-name:hover { text-decoration: underline; }
    .cl-hero-date {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 15px;
      color: rgba(255,255,255,0.80);
      font-family: 'Nunito Sans', 'Inter', sans-serif;
    }
    .cl-hero-date i { font-size: 14px; }
    .cl-hero-date time { font-weight: 600; color: #fff; }

    /* ===================== LAYOUT PRINCIPAL ===================== */
    .cl-main-wrap {
      background: #f3f4f6;
      padding-bottom: 64px;
    }
    .cl-main-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      gap: 28px;
      align-items: flex-start;
      position: relative;
      top: -56px;
      margin-bottom: -56px;
    }

    /* Card de conteúdo */
    .cl-content-card {
      flex: 1;
      min-width: 0;
      background: #ffffff;
      border-radius: 12px;
      padding: 40px 44px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    }

    /* Sidebar */
    .cl-sidebar {
      width: 300px;
      flex-shrink: 0;
    }
    .cl-sidebar-inner {
      position: sticky;
      top: 100px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* Stack: Google card + capa sobrepostos */
    .cl-sidebar-stack {
      position: relative;
      display: flex;
      flex-direction: column;
    }

    /* Card Google */
    .cl-google-card {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #ffffff;
      border: 1px solid #e2e6ea;
      border-radius: 12px;
      padding: 14px 16px 16px;
      text-decoration: none;
      position: relative;
      z-index: 1;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .cl-google-card:hover {
      background: #111827;
      border-color: #111827;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }
    .cl-google-card:hover .cl-google-text { color: #ffffff; }
    .cl-google-card:hover .cl-google-text strong { color: #ffffff; }
    .cl-google-icon {
      width: 28px;
      height: 28px;
      flex-shrink: 0;
    }
    .cl-google-text {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 13px;
      color: #374151;
      line-height: 1.4;
      flex: 1;
      min-width: 0;
      transition: color 0.2s ease;
    }
    .cl-google-text strong {
      color: #111827;
      font-weight: 700;
      transition: color 0.2s ease;
    }

    /* Imagem de capa na sidebar */
    .cl-sidebar-cover {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      position: relative;
      z-index: 2;
      margin-top: -12px;
      border: 2px solid #ffffff;
    }
    .cl-sidebar-cover img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
      aspect-ratio: 16/10;
    }

    /* ===================== TYPOGRAPHY ===================== */
    article h2 {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: #111827;
      margin: 36px 0 12px;
      line-height: 1.3;
