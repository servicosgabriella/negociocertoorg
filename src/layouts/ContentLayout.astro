---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { estrutura, getBreadcrumb, type Categoria } from '../data/estrutura';

/*
  ====================================================================
  INSTRUÇÕES PARA A IA — PÁGINAS DE CONTEÚDO (.astro)
  ====================================================================
  
  Este layout é para artigos que pertencem às CATEGORIAS e SUBCATEGORIAS
  do site (Finanças, Planejamento, Gestão, RH). NÃO é para posts do blog.

  ====================================================================
  REGRAS DE CRIAÇÃO DO ARQUIVO
  ====================================================================
  1. Crie SEMPRE como .astro — NUNCA como .md
  2. Coloque em src/pages/ na RAIZ — NUNCA em subpastas
     ✅ src/pages/contabilidade-online-ou-presencial.astro
     ❌ src/pages/financas/contabilidade-online-ou-presencial.astro
     ❌ src/content/blog/contabilidade-online-ou-presencial.md
  3. O nome do arquivo = slug da URL (sem acentos, tudo minúsculo, hífen)
     Ex: contabilidade-online-ou-presencial.astro → /contabilidade-online-ou-presencial/
  4. Import do layout SEMPRE: import ContentLayout from '../layouts/ContentLayout.astro';
  5. CONFIRA o nome do arquivo antes de salvar — erros de digitação quebram a URL

  ====================================================================
  EXEMPLO COMPLETO DE PÁGINA .astro
  ====================================================================
  ---
  import ContentLayout from '../layouts/ContentLayout.astro';
  ---

  <ContentLayout
    title="Contabilidade Online ou Presencial: Qual Escolher em 2026?"
    description="Descubra as diferenças entre contabilidade online e presencial."
    publishDate="2026-02-24"
    updatedDate="2026-02-24"
    authorName="Gabriella Fernandes"
    authorRole="Especialista em Negócios"
    authorImage="/images/perfil.jpg"
    authorHref="/autor/gabriela.fernandes/"
    category="Finanças"
    subcategory="Contabilidade Online"
    coverImage="/images/contabilidade-online-ou-presencial.jpg"
    coverAlt="Comparação entre contabilidade online e presencial"
    faq={[
      { question: "Pergunta 1?", answer: "Resposta 1." },
    ]}
  >
    <p>Conteúdo HTML aqui...</p>
    <h2>Subtítulo</h2>
    <p>Mais conteúdo...</p>
  </ContentLayout>

  ====================================================================
  PROPS — REFERÊNCIA RÁPIDA
  ====================================================================
  
  OBRIGATÓRIAS:
    title          → Título do artigo (aparece no h1 e meta title)
    description    → Descrição SEO (máx 160 caracteres)
    publishDate    → Data de publicação (formato: "2026-02-24")
    authorName     → Nome completo do autor
    authorRole     → Cargo do autor
    authorImage    → Caminho da foto do autor (/images/...)
    category       → Categoria do Header (ex: "Finanças", "Gestão", "RH", "Planejamento")
    subcategory    → Subcategoria do Header (ex: "Contabilidade Online", "Maquininha de Cartão")
  
  OPCIONAIS:
    updatedDate    → Data da última atualização (se omitido, usa publishDate)
    authorHref     → Link para página do autor (/autor/slug/)
    coverImage     → Imagem de capa (/images/...)
    coverAlt       → Texto alternativo da imagem de capa
    faq            → Array de { question, answer } para FAQ com schema

  NOTA: O breadcrumb é GERADO AUTOMATICAMENTE a partir de category e subcategory.
  NÃO passe breadcrumb manualmente.

  ====================================================================
  REGRAS DO CONTEÚDO HTML
  ====================================================================
  - Escreva em HTML dentro do <ContentLayout>
  - Use <h2> para títulos e <h3> para subtítulos
  - NÃO adicione <style> ou <script> — já estão neste layout
  - NÃO importe Header ou Footer — já estão neste layout
  - O FAQ é renderizado automaticamente via prop faq
  - Tabelas devem usar HTML com inline styles para responsividade

  ====================================================================
  AÇÕES AUTOMÁTICAS PÓS-CRIAÇÃO (A IA DEVE FAZER TUDO ISSO)
  ====================================================================
  Ao criar um artigo com este layout, a IA DEVE executar TODAS as ações
  abaixo SEM que o usuário precise pedir. Isso faz parte do processo
  de criação do artigo.

  1. CRIAR O ARQUIVO .astro
     → Em src/pages/ com o nome correto (slug)

  2. ATUALIZAR O HEADER (src/components/Header.astro)
     → Adicionar o link do artigo no submenu da subcategoria correta
     → Desktop: dentro do .sub-menu da subcategoria
     → Mobile: dentro do .mobile-sub-menu da subcategoria
     → Se a subcategoria ainda não tem sub-menu, criar a estrutura

  3. ATUALIZAR A ESTRUTURA (src/data/estrutura.ts)
     → Adicionar o artigo na categoria/subcategoria correspondente
     → href deve ser "/slug-do-artigo" (sem /blog/, sem categoria na URL)

  4. ATUALIZAR A PÁGINA DO AUTOR (src/pages/autor/[autor].astro)
     → Adicionar o artigo no array de artigos publicados pelo autor

  5. CONFIRMAR COM O USUÁRIO
     → Informar: "Artigo criado. Também atualizei: Header, estrutura.ts e página do autor."
     → Informar a URL final: http://localhost:4321/slug-do-artigo/

  Se algum desses arquivos não existir ou a IA não tiver acesso,
  deve AVISAR o usuário sobre o que falta atualizar manualmente.
*/

interface Props {
  title: string;
  description: string;
  publishDate: string;
  updatedDate?: string;
  authorName: string;
  authorRole: string;
  authorImage: string;
  authorHref?: string;
  category: string;
  subcategory: string;
  coverImage?: string;
  coverAlt?: string;
  faq?: { question: string; answer: string }[];
}

const {
  title,
  description,
  publishDate,
  updatedDate = publishDate,
  authorName,
  authorRole,
  authorImage,
  authorHref = '',
  category,
  subcategory,
  coverImage = '',
  coverAlt = '',
  faq = [],
} = Astro.props;

// Busca hrefs de categoria e subcategoria no estrutura.ts
const cat = Object.values(estrutura).find(c => c.label === category);
const sub = cat ? Object.values((cat as any).subcategorias ?? {}).find((s: any) => s.label === subcategory) as any : null;

const breadcrumb = [
  { label: "Home", href: "/" },
  { label: category, href: (cat as any)?.href ?? '' },
  { label: subcategory, href: sub?.href ?? '' },
  { label: title },
];

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const coverImageAbsolute = coverImage ? new URL(coverImage, Astro.site).href : '';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  datePublished: new Date(publishDate).toISOString(),
dateModified: new Date(updatedDate).toISOString(),
  ...(coverImageAbsolute ? { image: coverImageAbsolute } : {}),
  author: { '@type': 'Person', name: authorName },
  publisher: {
    '@type': 'Organization',
    name: 'Negócio Certo',
    url: Astro.site?.href ?? '',
  },
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
  })),
};
---

<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  {coverImageAbsolute && <meta property="og:image" content={coverImageAbsolute} />}
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Negócio Certo" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {coverImageAbsolute && <meta name="twitter:image" content={coverImageAbsolute} />}

  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
</head>
<body>
  <Header />

  <!-- HERO AZUL -->
  <section class="blog-hero">
    <div class="blog-hero-container">
      <div class="blog-hero-content">
        <nav aria-label="Breadcrumb" class="hidden md:flex" style="font-size: 13px; margin-bottom: 16px;">
          <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; align-items: center; gap: 4px;">
            {breadcrumb.map((item, index) => (
              <li style="display: flex; align-items: center; gap: 4px;">
                {index < breadcrumb.length - 1 ? (
                  item.href ? (
                    <a href={item.href} style="color: #bfdbfe; text-decoration: none;">{item.label}</a>
                  ) : (
                    <span style="color: #bfdbfe;">{item.label}</span>
                  )
                ) : (
                  <span style="color: #ffffff; font-weight: 500;">{item.label}</span>
                )}
                {index < breadcrumb.length - 1 && <span style="color: #bfdbfe;">›</span>}
              </li>
            ))}
          </ol>
        </nav>
        <h1 class="blog-hero-title">{title}</h1>
        <p style="color: #bfdbfe; font-size: 1.125rem; margin-bottom: 24px;">{description}</p>
        <div style="display: flex; align-items: center; gap: 12px;">
          <img src={authorImage} alt={`Foto de ${authorName}`} width="40" height="40"
            loading="eager" fetchpriority="high"
            style="width:40px; height:40px; border-radius:50%; object-fit:cover; flex-shrink:0;" />
          <div>
            <div style="color: #dce4f1; font-size: 13px;">
              Escrito por: {authorHref ? (
                <a href={authorHref} style="color: white; text-decoration: underline; font-weight: 700;" rel="author">{authorName}</a>
              ) : (
                <strong style="color: white;">{authorName}</strong>
              )} · <span style="color: #dce4f1;">{authorRole}</span>
            </div>
            <div style="color: #bfdbfe; font-size: 13px; margin-top: 4px;">
              <i class="fa-regular fa-clock" aria-hidden="true"></i>
              <span style="font-weight: bold;"> Última atualização:</span>
              <time datetime={updatedDate}>{new Date(updatedDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGEM DE CAPA (opcional) -->
  {coverImage && (
    <div class="blog-cover-wrapper">
      <img
        class="blog-cover-image"
        src={coverImage}
        alt={coverAlt}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  )}

  <!-- CONTEÚDO + TOC LATERAL -->
  <div class="blog-layout">
    <div class="blog-content">
      <article>
        <slot />
        {faq.length > 0 && (
          <section style="margin-top: 48px;">
            <h2>Perguntas Frequentes</h2>
            {faq.map(item => (
              <details style="margin-bottom: 12px; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px 14px; background: #fff;">
                <summary style="cursor: pointer; font-weight: 700; color: #4b5563; font-size: 15px;">{item.question}</summary>
                <p style="margin-top: 10px; margin-bottom: 0;">{item.answer}</p>
              </details>
            ))}
          </section>
        )}
      </article>
    </div>

    <!-- TOC LATERAL -->
    <div class="blog-toc-column">
      <div id="custom-toc-widget">
        <h3 class="toc-title">Navegue pelo conteúdo</h3>
        <ul id="custom-toc-list"></ul>
      </div>
    </div>
  </div>

  <Footer />

  <!-- SCRIPT DO TOC -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const contentSelectors = ['article', 'main'];
      let contentContainer = null;
      for (let s of contentSelectors) {
        let el = document.querySelector(s);
        if (el) { contentContainer = el; break; }
      }
      if (!contentContainer) return;

      const headings = contentContainer.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      const widget = document.getElementById('custom-toc-widget');
      const list = document.getElementById('custom-toc-list');
      widget.style.display = 'block';

      headings.forEach((heading, index) => {
        if (!heading.id) heading.id = 'toc-' + index;
        const li = document.createElement('li');
        const a = document.createElement('a');
        li.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-h3' : 'toc-h2';
        a.href = '#' + heading.id;
        a.textContent = heading.textContent;
        a.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.getElementById(heading.id);
          const offset = 120;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementRect = target.getBoundingClientRect().top;
          const offsetPosition = elementRect - bodyRect - offset;
          window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
          document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
          li.classList.add('active');
        });
        li.appendChild(a);
        list.appendChild(li);
      });

      window.addEventListener('scroll', function () {
        let scrollY = window.scrollY;
        let currentId = '';
        headings.forEach((heading) => {
          if (scrollY >= heading.offsetTop - 150) currentId = heading.id;
        });
        if (currentId) {
          document.querySelectorAll('#custom-toc-list li').forEach((li) => {
            const link = li.querySelector('a');
            if (link.getAttribute('href') === '#' + currentId) {
              if (!li.classList.contains('active')) {
                document.querySelectorAll('#custom-toc-list li').forEach((l) => l.classList.remove('active'));
                li.classList.add('active');
                const widgetHeight = widget.clientHeight;
                const itemTop = li.offsetTop;
                const itemHeight = li.clientHeight;
                const currentScroll = widget.scrollTop;
                if (itemTop < currentScroll || itemTop + itemHeight > currentScroll + widgetHeight) {
                  widget.scrollTo({ top: itemTop - widgetHeight / 2 + itemHeight / 2, behavior: 'smooth' });
                }
              }
            }
          });
        }
      });

      if (list.firstChild) list.firstChild.classList.add('active');
    });
  </script>

  <style is:global>
    /* ===================== CONTENT LAYOUT ===================== */

    .blog-hero {
      background: linear-gradient(to right, #1a3a5c, #2d6a9f);
      padding: 40px 0 48px;
    }
    .blog-hero-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .blog-hero-content {
      width: 100%;
      max-width: 100%;
    }
    .blog-hero nav {
      padding: 0;
      margin: 0;
    }
    .blog-hero-title {
      color: white;
      font-size: 2.25rem;
      font-weight: 800;
      line-height: 1.25;
      margin-top: 0;
      margin-bottom: 16px;
    }

    .blog-cover-wrapper {
      max-width: 1200px;
      margin: -32px auto 0;
      padding: 0 24px;
    }
    .blog-cover-image {
      width: 100%;
      height: 400px;
      object-fit: cover;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.15);
      display: block;
    }

    .blog-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px;
      display: flex;
      gap: 40px;
    }
    .blog-content {
      flex: 1;
      min-width: 0;
    }
    .blog-toc-column {
      width: 256px;
      flex-shrink: 0;
    }

    /* ===================== ARTICLE TYPOGRAPHY ===================== */
    article h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
      margin: 32px 0 12px 0;
      line-height: 1.3;
    }
    article h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #111827;
      margin: 24px 0 8px 0;
      line-height: 1.4;
    }
    article h4 {
      font-size: 0.95rem;
      font-weight: 700;
      color: #111827;
      margin: 16px 0 6px 0;
    }
    article p {
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 16px;
    }
    article ul, article ol {
      padding-left: 1.5em;
      margin-bottom: 16px;
    }
    article li {
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 4px;
    }
    article strong {
      color: #111827;
      font-weight: 700;
    }
    article a {
      color: #007eff;
      text-decoration: none;
    }
    article a:hover {
      text-decoration: underline;
    }

    /* ===================== TOC WIDGET ===================== */
    #custom-toc-widget {
      background-color: #ffffff;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      position: -webkit-sticky;
      position: sticky;
      top: 100px;
      z-index: 9;
      max-height: 40vh;
      overflow-y: auto;
      overscroll-behavior-y: contain;
      padding: 12px 10px 12px 0;
      width: 100%;
      box-sizing: border-box;
      align-self: flex-start;
      font-family: Arial, sans-serif;
      color: #333;
      display: none;
    }
    #custom-toc-widget::-webkit-scrollbar { width: 4px; }
    #custom-toc-widget::-webkit-scrollbar-track { background: transparent; }
    #custom-toc-widget::-webkit-scrollbar-thumb { background-color: #ddd; border-radius: 4px; }
    #custom-toc-widget h3.toc-title {
      text-transform: uppercase;
      font-weight: 700;
      color: #000;
      font-size: 11px;
      margin: 0 0 8px 0;
      padding-left: 20px;
    }
    #custom-toc-list { list-style: none; padding: 0; margin: 0; }
    #custom-toc-list li {
      margin-bottom: 6px;
      line-height: 1.2;
      position: relative;
      padding-left: 20px;
      background: transparent !important;
    }
    #custom-toc-list li::before {
      content: "";
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px;
      background-color: transparent;
      border-radius: 0 4px 4px 0;
      transition: background-color 0.2s ease;
    }
    #custom-toc-list a {
      text-decoration: none !important;
      color: #666 !important;
      font-size: 12px !important;
      display: block;
      line-height: 1.3;
      transition: color 0.2s ease;
    }
    #custom-toc-list li.toc-h2 a { font-weight: 500; }
    #custom-toc-list li.toc-h3 { padding-left: 30px; }
    #custom-toc-list li.toc-h3 a { font-size: 11px !important; color: #888 !important; }
    #custom-toc-list a:hover { color: #000 !important; }
    #custom-toc-list li.active::before { background-color: #000; }
    #custom-toc-list li.active a { font-weight: 700 !important; color: #000 !important; }

    /* ===================== MOBILE ===================== */
    @media (max-width: 768px) {
      .blog-hero-content { max-width: 100% !important; }
      .blog-hero-title { font-size: 1.5rem; }
      .blog-cover-image { width: 100% !important; height: 240px; }
      .blog-layout { flex-direction: column; gap: 0; }
      .blog-toc-column { display: none; }
      #custom-toc-widget { display: none !important; }
    }
  </style>

</body>
</html>