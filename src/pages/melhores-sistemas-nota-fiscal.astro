  .pdv-review { padding: 18px 4px 4px; font-size: 15px; color: #374151; line-height: 1.7; }
  .pdv-review p { margin: 0 0 10px; }

  @media (max-width: 700px) {
    .pdv-header { gap: 14px; padding: 16px; flex-wrap: wrap; }
    .pdv-logo-zone { width: 120px; }
    .pdv-cta-zone { min-width: 140px; }
