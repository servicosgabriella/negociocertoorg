  .pdv-features { display: flex; flex-wrap: wrap; gap: 8px; padding: 13px 22px; background: #fafafa; border-top: 1px solid #e5e7eb; }
  .pdv-feature-chip { border: 1px solid #e5e7eb; border-radius: 20px; padding: 5px 12px; font-size: 12.5px; color: #374151; background: #fff; white-space: nowrap; }
  .pdv-feature-chip i { color: #16a34a; margin-right: 4px; }
  .pdv-data-row { display: grid; grid-template-columns: 1fr 1fr 1fr; border-top: 1px solid #e5e7eb; }
  .pdv-cell { padding: 14px 18px; border-right: 1px solid #e5e7eb; }
  .pdv-cell:last-child { border-right: none; }
  .pdv-cell-label { font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
  .pdv-cell-value { font-size: 15px; font-weight: 700; color: #111827; }
