---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Calculadora de Juros Compostos";
const description = "Simule o crescimento do seu investimento com juros compostos. Veja quanto seu dinheiro vai render com aportes mensais, taxa de juros e prazo personalizados.";
const canonicalUrl = new URL('/calculadora-juros-compostos/', Astro.site).href;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} — Negócio Certo</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <Header />

  <!-- HERO -->
  <section class="calc-hero">
    <div class="calc-hero-inner">
      <nav aria-label="Breadcrumb" class="calc-breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><a href="/calculadoras/">Calculadoras</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><span class="current">Calculadora de Juros Compostos</span></li>
        </ol>
      </nav>
      <h1 class="calc-hero-title">Calculadora de Juros Compostos</h1>
      <p class="calc-hero-desc">Descubra quanto seu dinheiro pode render ao longo do tempo com o poder dos juros compostos.</p>
    </div>
  </section>

  <!-- FERRAMENTA -->
  <main class="calc-main">
    <div class="calc-tool">

      <!-- PAINEL ESQUERDO: FORM -->
      <aside class="calc-form-panel">
        <h2 class="calc-form-title">Detalhes do investimento</h2>

        <div class="calc-field">
          <label class="calc-label" for="inp-inicial">
            Depósito inicial
            <span class="tip-wrap" aria-label="Valor que você já possui para investir agora. É o ponto de partida da simulação.">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">Valor que você já possui para investir agora. É o ponto de partida da simulação.</span>
            </span>
          </label>
          <div class="calc-input-wrap">
            <span class="calc-unit left">R$</span>
            <input id="inp-inicial" class="calc-input" type="text" inputmode="numeric" value="10.000" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-anos">
            Anos de crescimento
            <span class="tip-wrap" aria-label="Por quantos anos você pretende deixar o dinheiro investido.">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">Por quantos anos você pretende deixar o dinheiro investido.</span>
            </span>
          </label>
          <div class="calc-input-wrap">
            <input id="inp-anos" class="calc-input" type="text" inputmode="numeric" value="10" />
            <span class="calc-unit right">Anos</span>
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-taxa">
            Taxa de retorno estimada
            <span class="tip-wrap" aria-label="Taxa de juros anual do investimento (% a.a.). Por exemplo: 12% significa que o dinheiro rende 12% ao ano.">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">Taxa de juros anual do investimento (% a.a.). Por exemplo: 12% significa que o dinheiro rende 12% ao ano.</span>
            </span>
          </label>
          <div class="calc-input-wrap">
            <input id="inp-taxa" class="calc-input" type="text" inputmode="decimal" value="12%" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-freq-cap">
            Frequência de capitalização
            <span class="tip-wrap" aria-label="De quanto em quanto tempo os juros são calculados e somados ao saldo. Capitalização mensal é o padrão da maioria dos investimentos brasileiros (CDB, Selic, poupança).">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">De quanto em quanto tempo os juros são calculados e somados ao saldo. Capitalização mensal é o padrão da maioria dos investimentos brasileiros (CDB, Selic, poupança).</span>
            </span>
          </label>
          <div class="calc-select-wrap">
            <select id="inp-freq-cap" class="calc-select">
              <option value="12" selected>Mensal</option>
              <option value="4">Trimestral</option>
              <option value="2">Semestral</option>
              <option value="1">Anual</option>
              <option value="365">Diária</option>
            </select>
            <span class="calc-select-arrow" aria-hidden="true">▼</span>
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-aporte">
            Valor do aporte
            <span class="tip-wrap" aria-label="Quanto você pretende depositar periodicamente, além do valor inicial. Aportes regulares aceleram muito o crescimento do investimento.">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">Quanto você pretende depositar periodicamente, além do valor inicial. Aportes regulares aceleram muito o crescimento do investimento.</span>
            </span>
          </label>
          <div class="calc-input-wrap">
            <span class="calc-unit left">R$</span>
            <input id="inp-aporte" class="calc-input" type="text" inputmode="numeric" value="500" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label">
            Frequência do aporte
            <span class="tip-wrap" aria-label="Se você vai depositar o valor do aporte todo mês ou uma única vez por ano. Aportes mensais tendem a gerar mais rendimento por aproveitar melhor os juros compostos.">
              <span class="tip-icon" aria-hidden="true">i</span>
              <span class="tip-box" role="tooltip">Se você vai depositar o valor do aporte todo mês ou uma única vez por ano. Aportes mensais tendem a gerar mais rendimento por aproveitar melhor os juros compostos.</span>
            </span>
          </label>
          <div class="calc-toggle-group" role="group" aria-label="Frequência do aporte">
            <button class="calc-toggle active" data-value="monthly" type="button">Mensal</button>
            <button class="calc-toggle" data-value="annually" type="button">Anual</button>
          </div>
        </div>
      </aside>

      <!-- PAINEL DIREITO: GRÁFICO -->
      <div class="calc-chart-panel">
        <div class="calc-chart-header">
          <p class="calc-chart-label">Saldo Total</p>
          <p class="calc-chart-total" id="result-total">R$ 231.865,21</p>
        </div>
        <div class="calc-chart-area">
          <canvas id="grafico" aria-label="Gráfico de crescimento do investimento"></canvas>
        </div>
        <div class="calc-chart-legend">
          <span class="calc-legend-item">
            <span class="calc-legend-swatch principal"></span>
            Principal total
          </span>
          <span class="calc-legend-item">
            <span class="calc-legend-swatch juros"></span>
            Juros acumulados
          </span>
        </div>
      </div>

    </div>

    <!-- TABELA ANO A ANO -->
    <div class="calc-table-section">
      <h2 class="calc-section-title">Evolução ano a ano</h2>
      <div class="calc-table-scroll">
        <table class="calc-table">
          <thead>
            <tr>
              <th>Ano</th>
              <th>Saldo Inicial</th>
              <th>Aportes no Ano</th>
              <th>Juros no Ano</th>
              <th>Saldo Final</th>
            </tr>
          </thead>
          <tbody id="tabela-body">
            <!-- preenchido pelo JavaScript -->
          </tbody>
        </table>
      </div>
    </div>

    <!-- CONTEÚDO EDUCATIVO -->
    <div class="calc-content">

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>O que são juros compostos?</h2>
          <p>Juros compostos são aqueles calculados sobre o capital inicial <strong>mais os juros já acumulados</strong> nos períodos anteriores. É o famoso "juros sobre juros" — cada ciclo de rendimento se incorpora ao saldo e passa a render também.</p>
          <p>Na prática: se você investe R$ 1.000 a 1% ao mês, no primeiro mês ganha R$ 10. No segundo mês, você não ganha 1% sobre R$ 1.000 — ganha 1% sobre R$ 1.010. No terceiro mês, sobre R$ 1.020,10. E assim por diante, em progressão geométrica.</p>
          <p>É por isso que Albert Einstein (supostamente) teria chamado os juros compostos de <strong>"a oitava maravilha do mundo"</strong> — quem entende, ganha. Quem não entende, paga.</p>

          <h3>Fórmula utilizada nesta calculadora</h3>
          <div class="calc-formula-block">
            <code>M = P × (1 + i/n)<sup>n×t</sup> + C × [(1 + i/n)<sup>n×t</sup> − 1] / (i/n)</code>
          </div>
          <div class="calc-formula-vars">
            <div><strong>M</strong> — Montante final</div>
            <div><strong>P</strong> — Capital inicial (depósito inicial)</div>
            <div><strong>i</strong> — Taxa de juros anual</div>
            <div><strong>n</strong> — Frequência de capitalização por ano</div>
            <div><strong>t</strong> — Prazo em anos</div>
            <div><strong>C</strong> — Aporte periódico</div>
          </div>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Juros compostos vs. juros simples: qual a diferença real?</h2>
          <p>No regime de <strong>juros simples</strong>, os juros incidem sempre sobre o capital inicial. Se você emprestou R$ 1.000 a 10% ao ano, recebe R$ 100 por ano — sempre o mesmo valor, independente do tempo.</p>
          <p>Nos <strong>juros compostos</strong>, os juros de cada período são somados ao saldo antes do próximo cálculo. O rendimento cresce sobre si mesmo.</p>
          <p>Veja a diferença de R$ 10.000 investidos a 10% ao ano por 20 anos:</p>

          <div class="calc-compare-table">
            <table>
              <thead>
                <tr>
                  <th>Prazo</th>
                  <th>Juros Simples</th>
                  <th>Juros Compostos</th>
                  <th>Diferença</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>5 anos</td><td>R$ 15.000</td><td>R$ 16.105</td><td>+R$ 1.105</td></tr>
                <tr><td>10 anos</td><td>R$ 20.000</td><td>R$ 25.937</td><td>+R$ 5.937</td></tr>
                <tr><td>20 anos</td><td>R$ 30.000</td><td>R$ 67.275</td><td>+R$ 37.275</td></tr>
                <tr class="highlight"><td>30 anos</td><td>R$ 40.000</td><td>R$ 174.494</td><td>+R$ 134.494</td></tr>
              </tbody>
            </table>
          </div>

          <p>Perceba: em 30 anos, os juros compostos rendem <strong>4,3 vezes mais</strong> que os simples. Essa diferença aumenta exponencialmente com o tempo — é o efeito bola de neve.</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Por que a frequência de capitalização muda tudo?</h2>
          <p>A mesma taxa anual de 12% pode render valores diferentes dependendo de quantas vezes os juros são calculados por ano. Quanto mais frequente a capitalização, maior o rendimento real — pois os juros passam a render mais cedo.</p>
          <p>Veja o impacto para R$ 10.000 com taxa de 12% ao ano por 10 anos:</p>

          <div class="calc-compare-table">
            <table>
              <thead>
                <tr>
                  <th>Capitalização</th>
                  <th>Montante Final</th>
                  <th>Taxa Efetiva Anual</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>Anual</td><td>R$ 31.058</td><td>12,00%</td></tr>
                <tr><td>Semestral</td><td>R$ 32.071</td><td>12,36%</td></tr>
                <tr><td>Trimestral</td><td>R$ 32.620</td><td>12,55%</td></tr>
                <tr><td>Mensal</td><td>R$ 33.004</td><td>12,68%</td></tr>
                <tr class="highlight"><td>Diária</td><td>R$ 33.194</td><td>12,75%</td></tr>
              </tbody>
            </table>
          </div>

          <p>A maioria dos investimentos brasileiros — CDB, Tesouro Selic, fundos de renda fixa — usa <strong>capitalização diária ou mensal</strong>. Por isso, ao simular seus investimentos reais, prefira selecionar "Mensal" ou "Diária" nesta calculadora.</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Quanto rende R$ 10.000 investidos por 10 anos?</h2>
          <p>A taxa de retorno é o fator com maior impacto no resultado final. Veja como o mesmo capital inicial se comporta com diferentes taxas, mantendo aportes mensais de R$ 500 por 10 anos (capitalização mensal):</p>

          <div class="calc-compare-table">
            <table>
              <thead>
                <tr>
                  <th>Taxa Anual</th>
                  <th>Referência</th>
                  <th>Total Investido</th>
                  <th>Montante Final</th>
                  <th>Juros Ganhos</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>6% a.a.</td><td>Poupança (~atual)</td><td>R$ 70.000</td><td>R$ 95.416</td><td>R$ 25.416</td></tr>
                <tr><td>10% a.a.</td><td>CDB conservador</td><td>R$ 70.000</td><td>R$ 116.170</td><td>R$ 46.170</td></tr>
                <tr><td>12% a.a.</td><td>CDB/Tesouro bom</td><td>R$ 70.000</td><td>R$ 130.287</td><td>R$ 60.287</td></tr>
                <tr class="highlight"><td>15% a.a.</td><td>Renda variável*</td><td>R$ 70.000</td><td>R$ 162.173</td><td>R$ 92.173</td></tr>
              </tbody>
            </table>
          </div>
          <p class="calc-table-note">* Retornos em renda variável não são garantidos. A taxa é usada apenas para fins de comparação.</p>
          <p>A diferença entre 6% e 12% ao ano não é o dobro do resultado — é <strong>quase três vezes mais juros</strong>. Cada ponto percentual a mais na taxa tem um impacto enorme no longo prazo.</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>O poder dos aportes mensais: por que consistência bate capital</h2>
          <p>Muita gente acha que precisa de um grande capital inicial para investir. Os números mostram o contrário — <strong>aportes mensais regulares frequentemente superam uma grande quantia investida de uma vez</strong>.</p>
          <p>Comparação com taxa de 12% ao ano por 20 anos:</p>

          <div class="calc-compare-table">
            <table>
              <thead>
                <tr>
                  <th>Estratégia</th>
                  <th>Investimento Inicial</th>
                  <th>Aporte Mensal</th>
                  <th>Total Investido</th>
                  <th>Montante Final</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>Grande aporte inicial</td><td>R$ 50.000</td><td>R$ 0</td><td>R$ 50.000</td><td>R$ 482.314</td></tr>
                <tr><td>Só aportes mensais</td><td>R$ 0</td><td>R$ 500</td><td>R$ 120.000</td><td>R$ 494.636</td></tr>
                <tr class="highlight"><td>Combinado</td><td>R$ 10.000</td><td>R$ 300</td><td>R$ 82.000</td><td>R$ 386.136</td></tr>
              </tbody>
            </table>
          </div>

          <p>Quem investe R$ 500/mês do zero chega ao mesmo patamar que quem colocou R$ 50.000 de uma vez — e investiu R$ 70.000 a mais no total. O segredo: <strong>disciplina e tempo</strong>, não o capital inicial.</p>
          <p>Além disso, aportes mensais criam o hábito de poupar e protegem contra o risco de investir na hora errada (estratégia de custo médio).</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Juros compostos nas dívidas: o lado perigoso</h2>
          <p>O mesmo mecanismo que faz seu investimento crescer exponencialmente é o que faz sua dívida sair do controle. E no crédito brasileiro, as taxas são brutais.</p>
          <p>Veja como R$ 5.000 de dívida no cartão cresce se você pagar só o mínimo:</p>

          <div class="calc-compare-table">
            <table>
              <thead>
                <tr>
                  <th>Modalidade de Crédito</th>
                  <th>Taxa Mensal Média</th>
                  <th>Dívida em 1 ano</th>
                  <th>Dívida em 2 anos</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>Crédito pessoal banco</td><td>3,5% a.m.</td><td>R$ 7.228</td><td>R$ 10.489</td></tr>
                <tr><td>Cheque especial</td><td>7,5% a.m.</td><td>R$ 12.041</td><td>R$ 28.993</td></tr>
                <tr class="highlight"><td>Cartão de crédito rotativo</td><td>14,5% a.m.</td><td>R$ 27.474</td><td>R$ 150.885</td></tr>
              </tbody>
            </table>
          </div>

          <p>Uma dívida de R$ 5.000 no rotativo do cartão pode se tornar <strong>R$ 150.885 em dois anos</strong> — um crescimento de 30 vezes. Não é erro de digitação.</p>
          <p>Por isso, a regra financeira mais importante é: <strong>quite dívidas com juros altos antes de investir</strong>. Não existe investimento no Brasil que pague 14,5% ao mês. Nenhum.</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Como usar esta calculadora para planejar seus investimentos</h2>

          <h3>Para simular um CDB ou Tesouro Selic</h3>
          <p>Use capitalização <strong>Mensal</strong> (ou Diária para o Tesouro Selic). A taxa Selic atual está em torno de 13,75% a.a. — mas CDBs de bancos menores costumam oferecer 110–130% do CDI, o que equivale a aproximadamente 14–18% a.a. Coloque sua taxa estimada, defina o prazo e veja o resultado.</p>

          <h3>Para simular a poupança</h3>
          <p>A poupança rende 70% da Selic quando a taxa está acima de 8,5% a.a. Com Selic a 13,75%, a poupança rende cerca de 9,6% a.a. Use capitalização <strong>Mensal</strong> e essa taxa para comparar com outras alternativas.</p>

          <h3>Para simular renda variável (ações, FIIs)</h3>
          <p>O histórico do Ibovespa médio fica em torno de 13–15% a.a. em reais no longo prazo. Mas lembre: renda variável tem oscilações — o resultado real pode ser muito maior ou menor. Use a simulação como referência de longo prazo, não como garantia.</p>

          <h3>Para planejar a aposentadoria</h3>
          <p>Defina quanto você quer ter ao se aposentar, calcule quantos anos faltam, e use a calculadora ao contrário: ajuste o aporte mensal até o montante final chegar no valor desejado. Use uma taxa conservadora (8–10% a.a.) para não depender de cenários otimistas.</p>
        </div>
      </div>

      <div class="calc-info">
        <div class="calc-info-text">
          <h2>Perguntas frequentes sobre juros compostos</h2>

          <h3>Qual a diferença entre taxa nominal e taxa efetiva?</h3>
          <p>A <strong>taxa nominal</strong> é a declarada no contrato — por exemplo, "12% ao ano". A <strong>taxa efetiva</strong> considera a frequência de capitalização. Com capitalização mensal, 12% a.a. nominal equivale a 12,68% a.a. efetiva. Esta calculadora trabalha com taxa nominal anual.</p>

          <h3>O imposto de renda afeta o rendimento final?</h3>
          <p>Sim. Em investimentos como CDB e Tesouro Direto, o IR incide sobre os juros com alíquotas regressivas: 22,5% até 180 dias, 20% até 360 dias, 17,5% até 720 dias, e 15% acima de 720 dias. A calculadora mostra o rendimento bruto — para o líquido, desconte o IR dos juros calculados.</p>

          <h3>Inflação reduz o rendimento real?</h3>
          <p>Sim. Se sua aplicação rende 12% a.a. e a inflação está em 5% a.a., seu ganho real é de aproximadamente 6,7% a.a. (não simplesmente 7%). A fórmula correta é: taxa real = (1 + taxa nominal) / (1 + inflação) − 1. Para simulações de longo prazo, use a taxa real para ter uma visão mais conservadora e realista.</p>

          <h3>Aportes no início ou no final do período rendem diferente?</h3>
          <p>Sim. Aportes feitos no <strong>início</strong> de cada período (antecipado) rendem mais que aportes feitos no <strong>final</strong> (postecipado), pois ficam mais tempo aplicados. Esta calculadora considera aportes no início de cada período — o que é mais favorável e reflete melhor investimentos com débito automático configurado no começo do mês.</p>

          <h3>Quanto devo poupar por mês para me aposentar com R$ 1 milhão?</h3>
          <p>Depende de quanto tempo você tem. Com taxa de 10% a.a. e capitalização mensal: se faltam 30 anos, basta R$ 442/mês. Se faltam 20 anos, são R$ 1.317/mês. Se faltam 10 anos, R$ 4.882/mês. O tempo é o maior aliado — cada ano que você posterga exige um esforço mensal muito maior.</p>
        </div>
      </div>

    </div>

  </main>

  <Footer />

  <script is:inline>
  (function () {
    'use strict';

    var chart = null;
    var debounceTimer = null;

    var BRL = new Intl.NumberFormat('pt-BR', {
      style: 'currency', currency: 'BRL', minimumFractionDigits: 2, maximumFractionDigits: 2
    });

    /* ---------- helpers ---------- */

    function parseVal(str) {
      var s = String(str).replace(/[R$\s%]/g, '').trim();
      // Se tem vírgula: ponto = milhar, vírgula = decimal  ("1.500,50")
      if (s.indexOf(',') !== -1) {
        s = s.replace(/\./g, '').replace(',', '.');
      } else {
        // Remove ponto usado como separador de milhar ("10.000")
        // Heurística: ponto seguido de exatamente 3 dígitos (e depois outro ponto ou fim)
        s = s.replace(/\.(\d{3})(?=\.|$)/g, '$1');
      }
      return parseFloat(s) || 0;
    }

    function fmtK(v) {
      if (v === 0) return 'R$ 0';
      if (v >= 1000000) return 'R$ ' + (v / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      if (v >= 1000)    return 'R$ ' + (v / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
      return BRL.format(v);
    }

    /* ---------- cálculo ----------
     * Simula período a período para qualquer frequência de capitalização.
     * Para aportes mensais: distribui proporcionalmente por período de capitalização.
     * Para aportes anuais: aplica no início de cada ano.
     */
    function calcularAnos(P, taxaAnual, qtdAnos, aporte, freqAporte, freqCap) {
      var r    = taxaAnual / 100;
      var rPer = r / freqCap;          // taxa por período de capitalização
      var saldo = P;
      var rows  = [];

      for (var ano = 1; ano <= qtdAnos; ano++) {
        var saldoInicio   = saldo;
        var aporteNoAno   = (freqAporte === 'monthly') ? aporte * 12 : aporte;

        for (var per = 0; per < freqCap; per++) {
          // Adiciona aporte no início de cada período proporcional
          if (freqAporte === 'monthly') {
            saldo += aporte * (12 / freqCap);
          } else {
            if (per === 0) saldo += aporte;
          }
          saldo *= (1 + rPer);
        }

        var juroNoAno = saldo - saldoInicio - aporteNoAno;

        rows.push({
          ano:          ano,
          saldoInicio:  saldoInicio,
          aporteNoAno:  aporteNoAno,
          juroNoAno:    juroNoAno,
          saldoFinal:   saldo,
        });
      }

      return rows;
    }

    /* ---------- leitura dos inputs ---------- */
    function lerInputs() {
      return {
        P:          parseVal(document.getElementById('inp-inicial').value),
        anos:       Math.max(1, Math.min(50, Math.round(parseVal(document.getElementById('inp-anos').value)))),
        taxa:       parseVal(document.getElementById('inp-taxa').value),
        freqCap:    parseInt(document.getElementById('inp-freq-cap').value) || 12,
        aporte:     parseVal(document.getElementById('inp-aporte').value),
        freqAporte: (document.querySelector('.calc-toggle.active') || {}).dataset?.value || 'monthly',
      };
    }

    /* ---------- atualiza UI ---------- */
    function atualizar() {
      var inp  = lerInputs();
      var rows = calcularAnos(inp.P, inp.taxa, inp.anos, inp.aporte, inp.freqAporte, inp.freqCap);
      var final = rows.length ? rows[rows.length - 1].saldoFinal : inp.P;

      // Total em destaque
      document.getElementById('result-total').textContent = BRL.format(final);

      // --- Gráfico ---
      var anoAtual    = new Date().getFullYear();
      var labels      = ['Agora'];
      var dPrincipal  = [inp.P];   // capital inicial + aportes acumulados (sem juros)
      var dTotal      = [inp.P];   // saldo real (com juros)
      var contribAcum = inp.P;

      for (var i = 0; i < rows.length; i++) {
        contribAcum += rows[i].aporteNoAno;
        labels.push(String(anoAtual + i + 1));
        dPrincipal.push(contribAcum);
        dTotal.push(rows[i].saldoFinal);
      }

      if (chart) {
        chart.data.labels                  = labels;
        chart.data.datasets[0].data        = dPrincipal;
        chart.data.datasets[1].data        = dTotal;
        chart.update();
      }

      // --- Tabela ---
      var tbody = document.getElementById('tabela-body');
      tbody.innerHTML = '';

      for (var j = 0; j < rows.length; j++) {
        var row    = rows[j];
        var isLast = j === rows.length - 1;
        var tr     = document.createElement('tr');
        if (isLast) tr.className = 'highlight';

        function cel(val, bold) {
          return '<td>' + (bold ? '<strong>' + val + '</strong>' : val) + '</td>';
        }

        tr.innerHTML =
          cel(row.ano, isLast) +
          cel(BRL.format(row.saldoInicio), isLast) +
          cel(BRL.format(row.aporteNoAno), isLast) +
          cel(BRL.format(row.juroNoAno), isLast) +
          cel(BRL.format(row.saldoFinal), isLast);

        tbody.appendChild(tr);
      }
    }

    /* ---------- tooltip externo ---------- */
    function customTooltip(context) {
      var chart   = context.chart;
      var tooltip = context.tooltip;

      var el = document.getElementById('calc-tooltip');
      if (!el) {
        el = document.createElement('div');
        el.id = 'calc-tooltip';
        chart.canvas.parentNode.style.position = 'relative';
        chart.canvas.parentNode.appendChild(el);
      }

      if (tooltip.opacity === 0) {
        el.style.opacity = '0';
        return;
      }

      var pts       = tooltip.dataPoints || [];
      var principal = 0, total = 0;
      pts.forEach(function(p) {
        if (p.datasetIndex === 0) principal = p.parsed.y;
        if (p.datasetIndex === 1) total     = p.parsed.y;
      });
      var juros = total - principal;
      var label = tooltip.title && tooltip.title[0] ? tooltip.title[0] : '';
      var titulo = label === 'Agora' ? 'Agora' : 'Ano ' + label;

      el.innerHTML =
        '<div class="ct-title">' + titulo + '</div>' +
        '<div class="ct-row ct-bold"><span>Saldo total</span><span>' + BRL.format(total) + '</span></div>' +
        '<div class="ct-row"><span><span class="ct-dash" style="background:#2d6a9f"></span>Principal total</span><span>' + BRL.format(principal) + '</span></div>' +
        '<div class="ct-row"><span><span class="ct-dash" style="background:#eab308"></span>Juros acumulados</span><span>' + BRL.format(juros) + '</span></div>';

      // Posição relativa ao canvas
      var caret   = tooltip.caretX;
      var canvasW = chart.canvas.offsetWidth;
      var tipW    = 230;
      var left    = caret + 12;
      if (left + tipW > canvasW) left = caret - tipW - 12;

      el.style.opacity    = '1';
      el.style.left       = left + 'px';
      el.style.top        = (tooltip.caretY - 20) + 'px';
    }

    /* ---------- inicializa gráfico ---------- */
    function initChart() {
      var canvas = document.getElementById('grafico');
      if (!canvas || !window.Chart) return;

      chart = new window.Chart(canvas, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            {
              label: 'Principal total',
              data: [],
              fill: true,
              backgroundColor: 'rgba(45,106,159,0.18)',
              borderColor: 'transparent',
              borderWidth: 0,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#2d6a9f',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              tension: 0.2,
              order: 2,
            },
            {
              label: 'Juros acumulados',
              data: [],
              fill: '-1',
              backgroundColor: 'rgba(26,58,92,0.10)',
              borderColor: '#eab308',
              borderWidth: 2.5,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#eab308',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              tension: 0.2,
              order: 1,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              enabled: false,
              external: customTooltip,
            },
          },
          scales: {
            x: {
              grid: { display: false },
              border: { color: '#d1d5db' },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
                maxTicksLimit: 3,   // só início, meio e fim
                maxRotation: 0,
                autoSkip: true,
              },
            },
            y: {
              min: 0,
              grid: { color: '#f3f4f6' },
              border: { display: false },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
                maxTicksLimit: 6,
                callback: fmtK,
              },
            },
          },
        },
      });

      atualizar();
    }

    /* ---------- eventos ---------- */
    function debounce(fn) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fn, 280);
    }

    document.addEventListener('DOMContentLoaded', function () {
      initChart();

      ['inp-inicial', 'inp-anos', 'inp-taxa', 'inp-aporte'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input',  function () { debounce(atualizar); });
        el.addEventListener('change', atualizar);
        el.addEventListener('blur',   atualizar);
      });

      var sel = document.getElementById('inp-freq-cap');
      if (sel) sel.addEventListener('change', atualizar);

      document.querySelectorAll('.calc-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.calc-toggle').forEach(function (b) {
            b.classList.remove('active');
          });
          btn.classList.add('active');
          atualizar();
        });
      });
    });

  }());
  </script>

