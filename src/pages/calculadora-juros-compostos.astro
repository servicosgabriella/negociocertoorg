      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 10px;
      color: #6b7280;
      pointer-events: none;
    }

    /* Dropdown customizado dentro do input */
    .calc-dd {
      position: relative;
      flex-shrink: 0;
      border-left: 1px solid #d1d5db;
    }
    .calc-dd-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      height: 42px;
      padding: 0 10px 0 12px;
      border: none;
      background: transparent;
      cursor: pointer;
      font-family: Arial, sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: #0d4a28;
      white-space: nowrap;
      min-width: 82px;
      transition: background 0.12s;
    }
    .calc-dd-btn:hover { background: #f0fdf4; }
    .calc-dd.open .calc-dd-btn { background: #dcfce7; }
    .calc-dd-chevron {
      font-size: 9px;
      color: #16a34a;
      transition: transform 0.2s;
      line-height: 1;
      margin-left: auto;
    }
    .calc-dd.open .calc-dd-chevron { transform: rotate(180deg); }
    .calc-dd-list {
      display: none;
      position: absolute;
      top: calc(100% + 4px);
      right: 0;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      list-style: none;
      margin: 0;
      padding: 4px 0;
      z-index: 200;
      min-width: 120%;
      overflow: hidden;
    }
    .calc-dd.open .calc-dd-list { display: block; }
    .calc-dd-opt {
      list-style: none;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
      color: #374151;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.1s;
    }
    .calc-dd-opt:hover { background: #f3f4f6; }
    .calc-dd-opt.active {
      background: #f0fdf4;
      color: #0d4a28;
      font-weight: 700;
    }

    /* Toggle buttons */
    .calc-toggle-group {
      display: flex;
    }
    .calc-toggle {
      flex: 1;
      height: 42px;
      border: 1px solid #d1d5db;
      background: #fff;
      font-size: 14px;
      font-weight: 600;
      color: #374151;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      font-family: Arial, sans-serif;
    }
    .calc-toggle:first-child { border-radius: 4px 0 0 4px; border-right: none; }
    .calc-toggle:last-child  { border-radius: 0 4px 4px 0; }
    .calc-toggle.active {
      background: #0d4a28;
      color: #fff;
      border-color: #0d4a28;
    }
    .calc-toggle:not(.active):hover { background: #f3f4f6; }

    /* ===== CHART PANEL ===== */
    .calc-chart-panel {
      padding: 20px 24px 16px;
      display: flex;
      flex-direction: column;
      gap: 0;
      height: 100%;
      box-sizing: border-box;
      background: #fff;
      border-radius: 0;
      border: 1px solid #e5e7eb;
      box-shadow: none;
    }
    .calc-chart-header {
      text-align: center;
      margin-bottom: 12px;
    }
    .calc-chart-label {
      font-size: 16px;
      color: #6b7280;
      margin: 0 0 2px;
      font-weight: 500;
    }
    .calc-chart-total {
      font-size: 2rem;
      font-weight: 900;
      color: #0d4a28;
      margin: 0;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .calc-chart-area {
      flex: 1;
      position: relative;
      min-height: 0;
    }
    .calc-chart-legend {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 10px;
      font-size: 12px;
      color: #374151;
    }
    .calc-legend-item {
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .calc-legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      display: inline-block;
      flex-shrink: 0;
    }
    .calc-legend-swatch.principal { background: rgba(22,163,74,0.35); border: 1.5px solid rgba(22,163,74,0.6); }
    .calc-legend-swatch.juros     { background: rgba(250,204,21,0.4); border: 2px solid #eab308; }

    /* ===== TABLE ===== */
    .calc-table-section {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 28px;
      margin-bottom: 32px;
    }
    .calc-section-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #111827;
      margin: 0 0 20px;
    }
    .calc-table-scroll { overflow-x: auto; }
    .calc-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .calc-table th {
      background: #f9fafb;
      padding: 10px 16px;
      text-align: right;
      font-size: 12px;
      font-weight: 700;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
      border-bottom: 1px solid #e5e7eb;
    }
    .calc-table th:first-child { text-align: center; }
    .calc-table td {
      padding: 11px 16px;
      text-align: right;
      color: #374151;
      border-bottom: 1px solid #f3f4f6;
      font-size: 14px;
      white-space: nowrap;
    }
    .calc-table td:first-child { text-align: center; color: #9ca3af; font-weight: 600; }
    .calc-table tbody tr:hover { background: #f9fafb; }
    .calc-table tr.highlight td {
      background: #f0fdf4;
      color: #0d4a28;
      font-weight: 700;
      border-bottom: none;
    }
    .calc-table tr.highlight td:first-child { color: #0d4a28; }

    /* ===== ARTICLE CONTENT ===== */
    .calc-article h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
      margin: 40px 0 12px;
      line-height: 1.3;
    }
    .calc-article h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #111827;
      margin: 28px 0 8px;
      line-height: 1.4;
    }
    .calc-article p {
      font-size: 1rem;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 16px;
    }
    .calc-article strong {
      color: #111827;
      font-weight: 700;
    }
    .calc-formula-block {
      background: #f9fafb;
      border-left: 3px solid #16a34a;
      border-radius: 0 6px 6px 0;
      padding: 14px 18px;
      margin-bottom: 16px;
    }
    .calc-formula-block code {
      font-family: 'Courier New', monospace;
      font-size: 15px;
      font-weight: 700;
      color: #0d4a28;
      background: none;
      padding: 0;
    }
    .calc-formula-vars {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 6px 16px;
      font-size: 13px;
      color: #4b5563;
    }
    .calc-formula-vars strong { color: #0d4a28; }

    /* ===== TOOLTIP EXTERNO ===== */
    #calc-tooltip {
      position: absolute;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.10);
      padding: 12px 14px;
      min-width: 210px;
      z-index: 20;
      font-family: Arial, sans-serif;
    }
    .ct-title {
      font-size: 12px;
      color: #6b7280;
      font-weight: 500;
      margin-bottom: 8px;
    }
    .ct-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      font-size: 13px;
      color: #374151;
      padding: 3px 0;
    }
    .ct-row span:first-child {
      display: flex;
      align-items: center;
      gap: 7px;
      white-space: nowrap;
    }
    .ct-row span:last-child {
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .ct-bold {
      font-weight: 700;
      color: #111827;
      font-size: 14px;
      border-bottom: 1px solid #f3f4f6;
      padding-bottom: 8px;
      margin-bottom: 4px;
    }
    .ct-dash {
      display: inline-block;
      width: 14px;
      height: 2.5px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 768px) {
      /* Container */
      .calc-main { padding: 16px 16px 40px; }
      .calc-tool { grid-template-rows: auto; gap: 12px; margin-bottom: 20px; }

      /* Título e descrição */
      .calc-page-title { font-size: 22px !important; line-height: 1.25; }
      .calc-page-desc { font-size: 14px; margin: 0 0 16px; }

      /* Formulário */
      .calc-form-panel { padding: 16px; gap: 12px; }
      .calc-form-title { font-size: 14px; }
      .calc-label { font-size: 13px; }
      .calc-input { font-size: 15px; height: 40px; }
      .calc-unit { height: 40px; padding: 0 10px; font-size: 13px; }
      .calc-dd-btn { height: 40px; min-width: 64px; padding: 0 8px 0 10px; font-size: 12px; }
      .calc-toggle { height: 40px; font-size: 13px; }

      /* Tooltip: ancora à direita para não sair da tela */
      .tip-box {
        left: auto !important;
        right: -8px !important;
        transform: none !important;
        width: 180px;
        font-size: 11px;
      }
      .tip-box::after {
        left: auto !important;
        right: 14px !important;
        transform: none !important;
      }
      .calc-field:first-child .tip-box,
      .calc-field:nth-child(2) .tip-box {
        left: auto !important;
        right: -8px !important;
        transform: none !important;
      }
      .calc-field:first-child .tip-box::after,
      .calc-field:nth-child(2) .tip-box::after {
        right: 14px !important;
        left: auto !important;
        transform: none !important;
      }

      /* Gráfico: corrige height:100% que colapsa no mobile empilhado */
      .calc-chart-panel { height: auto; padding: 16px; }
      .calc-chart-total { font-size: 28px; }
      .calc-chart-label { font-size: 13px; }
      .calc-chart-area { flex: none; height: 210px; min-height: 210px; }
      .calc-chart-legend { gap: 6px 12px; font-size: 11px; flex-wrap: wrap; margin-top: 8px; }
      .calc-chart-area canvas { max-width: 100% !important; }

      /* Tabela */
      .calc-table-section { padding: 16px 12px; border-radius: 8px; margin-bottom: 20px; }
      .calc-section-title { font-size: 15px; margin: 0 0 14px; }
      .calc-table th { padding: 8px 10px; font-size: 11px; }
      .calc-table td { padding: 9px 10px; font-size: 13px; }

      /* Artigo */
      .calc-formula-block { padding: 12px 14px; overflow-x: auto; }
      .calc-formula-block code { font-size: 13px; }
      .calc-formula-vars { font-size: 12px; gap: 4px 12px; }
      .calc-article h2 { font-size: 20px; margin: 28px 0 10px; }
      .calc-article h3 { font-size: 17px; }
      .calc-article p, .calc-article li { font-size: 15px; line-height: 1.65; }
    }
  </style>

</body>
</html>
