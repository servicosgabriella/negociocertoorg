---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Calculadora de Juros Compostos";
const description = "Simule o crescimento do seu investimento com juros compostos. Veja quanto seu dinheiro vai render com aportes mensais, taxa de juros e prazo personalizados.";
const canonicalUrl = new URL('/calculadora-juros-compostos/', Astro.site).href;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} — Negócio Certo</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <Header />

  <!-- HERO -->
  <section class="calc-hero">
    <div class="calc-hero-inner">
      <nav aria-label="Breadcrumb" class="calc-breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><a href="/calculadoras/">Calculadoras</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><span class="current">Calculadora de Juros Compostos</span></li>
        </ol>
      </nav>
      <h1 class="calc-hero-title">Calculadora de Juros Compostos</h1>
      <p class="calc-hero-desc">Descubra quanto seu dinheiro pode render ao longo do tempo com o poder dos juros compostos.</p>
    </div>
  </section>

  <!-- FERRAMENTA -->
  <main class="calc-main">
    <div class="calc-tool">

      <!-- PAINEL ESQUERDO: FORM -->
      <aside class="calc-form-panel">
        <h2 class="calc-form-title">Detalhes do investimento</h2>

        <div class="calc-field">
          <label class="calc-label" for="inp-inicial">Depósito inicial</label>
          <div class="calc-input-wrap">
            <span class="calc-unit left">R$</span>
            <input id="inp-inicial" class="calc-input" type="text" inputmode="numeric" value="10.000" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-anos">Anos de crescimento</label>
          <div class="calc-input-wrap">
            <input id="inp-anos" class="calc-input" type="text" inputmode="numeric" value="10" />
            <span class="calc-unit right">Anos</span>
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-taxa">Taxa de retorno estimada</label>
          <div class="calc-input-wrap">
            <input id="inp-taxa" class="calc-input" type="text" inputmode="decimal" value="12%" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-freq-cap">Frequência de capitalização</label>
          <div class="calc-select-wrap">
            <select id="inp-freq-cap" class="calc-select">
              <option value="12" selected>Mensal</option>
              <option value="4">Trimestral</option>
              <option value="2">Semestral</option>
              <option value="1">Anual</option>
              <option value="365">Diária</option>
            </select>
            <span class="calc-select-arrow" aria-hidden="true">▼</span>
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label" for="inp-aporte">Valor do aporte</label>
          <div class="calc-input-wrap">
            <span class="calc-unit left">R$</span>
            <input id="inp-aporte" class="calc-input" type="text" inputmode="numeric" value="500" />
          </div>
        </div>

        <div class="calc-field">
          <label class="calc-label">Frequência do aporte</label>
          <div class="calc-toggle-group" role="group" aria-label="Frequência do aporte">
            <button class="calc-toggle active" data-value="monthly" type="button">Mensal</button>
            <button class="calc-toggle" data-value="annually" type="button">Anual</button>
          </div>
        </div>
      </aside>

      <!-- PAINEL DIREITO: GRÁFICO -->
      <div class="calc-chart-panel">
        <div class="calc-chart-header">
          <p class="calc-chart-label">Saldo Total</p>
          <p class="calc-chart-total" id="result-total">R$ 231.865,21</p>
        </div>
        <div class="calc-chart-area">
          <canvas id="grafico" aria-label="Gráfico de crescimento do investimento"></canvas>
        </div>
        <div class="calc-chart-legend">
          <span class="calc-legend-item">
            <span class="calc-legend-swatch principal"></span>
            Principal total
          </span>
          <span class="calc-legend-item">
            <span class="calc-legend-swatch juros"></span>
            Juros acumulados
          </span>
        </div>
      </div>

    </div>

    <!-- TABELA ANO A ANO -->
    <div class="calc-table-section">
      <h2 class="calc-section-title">Evolução ano a ano</h2>
      <div class="calc-table-scroll">
        <table class="calc-table">
          <thead>
            <tr>
              <th>Ano</th>
              <th>Saldo Inicial</th>
              <th>Aportes no Ano</th>
              <th>Juros no Ano</th>
              <th>Saldo Final</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>1</td><td>R$ 10.000,00</td><td>R$ 6.000,00</td><td>R$ 1.680,00</td><td>R$ 17.680,00</td></tr>
            <tr><td>2</td><td>R$ 17.680,00</td><td>R$ 6.000,00</td><td>R$ 2.841,60</td><td>R$ 26.521,60</td></tr>
            <tr><td>3</td><td>R$ 26.521,60</td><td>R$ 6.000,00</td><td>R$ 4.142,59</td><td>R$ 36.664,19</td></tr>
            <tr><td>4</td><td>R$ 36.664,19</td><td>R$ 6.000,00</td><td>R$ 5.599,70</td><td>R$ 48.263,89</td></tr>
            <tr><td>5</td><td>R$ 48.263,89</td><td>R$ 6.000,00</td><td>R$ 7.231,67</td><td>R$ 61.495,56</td></tr>
            <tr><td>6</td><td>R$ 61.495,56</td><td>R$ 6.000,00</td><td>R$ 9.059,47</td><td>R$ 76.555,03</td></tr>
            <tr><td>7</td><td>R$ 76.555,03</td><td>R$ 6.000,00</td><td>R$ 11.106,60</td><td>R$ 93.661,63</td></tr>
            <tr><td>8</td><td>R$ 93.661,63</td><td>R$ 6.000,00</td><td>R$ 13.399,39</td><td>R$ 113.061,03</td></tr>
            <tr><td>9</td><td>R$ 113.061,03</td><td>R$ 6.000,00</td><td>R$ 15.967,32</td><td>R$ 135.028,35</td></tr>
            <tr class="highlight"><td><strong>10</strong></td><td><strong>R$ 135.028,35</strong></td><td><strong>R$ 6.000,00</strong></td><td><strong>R$ 18.842,14</strong></td><td><strong>R$ 231.865,21</strong></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- EXPLICAÇÃO -->
    <div class="calc-info">
      <div class="calc-info-text">
        <h2>O que são juros compostos?</h2>
        <p>Juros compostos são calculados sobre o capital inicial somado aos juros já acumulados — é o chamado <strong>"juros sobre juros"</strong>. Quanto mais tempo o dinheiro fica investido, mais rápido ele cresce de forma exponencial.</p>
        <h3>Fórmula utilizada</h3>
        <div class="calc-formula-block">
          <code>M = P × (1 + i/n)<sup>n×t</sup> + C × [(1 + i/n)<sup>n×t</sup> − 1] / (i/n)</code>
        </div>
        <div class="calc-formula-vars">
          <div><strong>M</strong> — Montante final</div>
          <div><strong>P</strong> — Capital inicial</div>
          <div><strong>i</strong> — Taxa de juros anual</div>
          <div><strong>n</strong> — Frequência de capitalização/ano</div>
          <div><strong>t</strong> — Prazo em anos</div>
          <div><strong>C</strong> — Aporte periódico</div>
        </div>
      </div>
    </div>

  </main>

  <Footer />

  <script is:inline>
    // Toggle frequência de aporte
    document.querySelectorAll('.calc-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.calc-toggle').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
      });
    });

    // Dados estáticos de placeholder (placeholder — lógica real em dev futuro)
    var anos = ['Agora','2027','2028','2029','2030','2031','2032','2033','2034','2035','2036'];
    var principal = [10000,16000,22000,28000,34000,40000,46000,52000,58000,64000,70000];
    var total     = [10000,17680,26522,36664,48264,61496,76555,93662,113061,135028,161865];

    var ctx = document.getElementById('grafico');
    if (ctx && window.Chart) {
      new window.Chart(ctx, {
        type: 'line',
        data: {
          labels: anos,
          datasets: [
            {
              label: 'Principal total',
              data: principal,
              fill: true,
              backgroundColor: 'rgba(45,106,159,0.15)',
              borderColor: 'rgba(45,106,159,0.5)',
              borderWidth: 0,
              pointRadius: 0,
              tension: 0.3,
              order: 2,
            },
            {
              label: 'Juros acumulados',
              data: total,
              fill: '-1',
              backgroundColor: 'rgba(26,58,92,0.12)',
              borderColor: '#1a3a5c',
              borderWidth: 2.5,
              pointRadius: 0,
              tension: 0.3,
              order: 1,
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#fff',
              borderColor: '#e5e7eb',
              borderWidth: 1,
              titleColor: '#111827',
              bodyColor: '#374151',
              padding: 12,
              callbacks: {
                label: function(ctx) {
                  return ' ' + ctx.dataset.label + ': ' + new Intl.NumberFormat('pt-BR', {
                    style: 'currency', currency: 'BRL'
                  }).format(ctx.parsed.y);
                }
              }
            }
          },
          scales: {
            x: {
              grid: { display: false },
              border: { color: '#d1d5db' },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
              }
            },
            y: {
              grid: { color: '#f3f4f6', drawBorder: false },
              border: { display: false },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
                callback: function(v) {
                  if (v === 0) return 'R$ 0';
                  return 'R$ ' + (v/1000).toFixed(1).replace('.0','') + 'k';
                }
              }
            }
          }
        }
      });
    }
  </script>

  <style is:global>

    /* ===== HERO ===== */
    .calc-hero {
      background: linear-gradient(to right, #1a3a5c, #2d6a9f);
      padding: 36px 0 44px;
    }
    .calc-hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .calc-breadcrumb ol {
      list-style: none;
      padding: 0; margin: 0 0 16px;
      display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
      font-size: 13px;
    }
    .calc-breadcrumb li { display: flex; align-items: center; gap: 6px; margin: 0; }
    .calc-breadcrumb a { color: #bfdbfe; text-decoration: none; }
    .calc-breadcrumb a:hover { text-decoration: underline; }
    .calc-breadcrumb span { color: #bfdbfe; }
    .calc-breadcrumb span.current { color: #fff; font-weight: 500; }
    .calc-hero-title {
      color: #fff;
      font-size: 2.25rem; font-weight: 800; line-height: 1.2;
      margin: 0 0 10px;
    }
    .calc-hero-desc { color: #bfdbfe; font-size: 1.05rem; margin: 0; max-width: 600px; }

    /* ===== MAIN ===== */
    .calc-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 24px 72px;
    }

    /* ===== TOOL: 2 COLUNAS ===== */
    .calc-tool {
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 0;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 2px 20px rgba(26,58,92,0.07);
      margin-bottom: 40px;
    }
    @media (max-width: 860px) {
      .calc-tool { grid-template-columns: 1fr; }
    }

    /* ===== FORM PANEL ===== */
    .calc-form-panel {
      background: #f2ede8;
      padding: 32px 28px;
      border-right: 1px solid #e5d8cc;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    @media (max-width: 860px) {
      .calc-form-panel { border-right: none; border-bottom: 1px solid #e5d8cc; }
    }
    .calc-form-title {
      font-size: 1rem;
      font-weight: 800;
      color: #111827;
      margin: 0 0 4px;
    }

    /* Fields */
    .calc-field { display: flex; flex-direction: column; gap: 6px; }
    .calc-label {
      font-size: 13px;
      color: #374151;
      font-weight: 500;
    }
    .calc-input-wrap {
      display: flex;
      align-items: center;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 4px;
      overflow: hidden;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .calc-input-wrap:focus-within {
      border-color: #2d6a9f;
      box-shadow: 0 0 0 3px rgba(45,106,159,0.12);
    }
    .calc-unit {
      padding: 0 12px;
      font-size: 14px;
      color: #6b7280;
      background: #f9fafb;
      height: 42px;
      display: flex;
      align-items: center;
      white-space: nowrap;
      border-right: 1px solid #e5e7eb;
      flex-shrink: 0;
    }
    .calc-unit.right {
      border-right: none;
      border-left: 1px solid #e5e7eb;
    }
    .calc-input {
      flex: 1;
      border: none;
      outline: none;
      background: transparent;
      padding: 0 12px;
      height: 42px;
      font-size: 15px;
      font-weight: 600;
      color: #111827;
      font-family: Arial, sans-serif;
      min-width: 0;
    }

    /* Select */
    .calc-select-wrap {
      position: relative;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 4px;
      transition: border-color 0.15s;
    }
    .calc-select-wrap:focus-within {
      border-color: #2d6a9f;
      box-shadow: 0 0 0 3px rgba(45,106,159,0.12);
    }
    .calc-select {
      width: 100%;
      border: none;
      outline: none;
      appearance: none;
      -webkit-appearance: none;
      background: transparent;
      padding: 0 36px 0 12px;
      height: 42px;
      font-size: 15px;
      font-weight: 600;
      color: #111827;
      font-family: Arial, sans-serif;
      cursor: pointer;
    }
    .calc-select-arrow {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 10px;
      color: #6b7280;
      pointer-events: none;
    }

    /* Toggle buttons */
    .calc-toggle-group {
      display: flex;
    }
    .calc-toggle {
      flex: 1;
      height: 42px;
      border: 1px solid #d1d5db;
      background: #fff;
      font-size: 14px;
      font-weight: 600;
      color: #374151;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      font-family: Arial, sans-serif;
    }
    .calc-toggle:first-child { border-radius: 4px 0 0 4px; border-right: none; }
    .calc-toggle:last-child  { border-radius: 0 4px 4px 0; }
    .calc-toggle.active {
      background: #1a3a5c;
      color: #fff;
      border-color: #1a3a5c;
    }
    .calc-toggle:not(.active):hover { background: #f3f4f6; }

    /* ===== CHART PANEL ===== */
    .calc-chart-panel {
      padding: 32px 28px 24px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .calc-chart-header {
      text-align: center;
      margin-bottom: 20px;
    }
    .calc-chart-label {
      font-size: 13px;
      color: #6b7280;
      margin: 0 0 4px;
      font-weight: 500;
    }
    .calc-chart-total {
      font-size: 2.6rem;
      font-weight: 900;
      color: #1a3a5c;
      margin: 0;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .calc-chart-area {
      flex: 1;
      position: relative;
      height: 320px;
    }
    .calc-chart-legend {
      display: flex;
      justify-content: center;
      gap: 28px;
      margin-top: 16px;
      font-size: 13px;
      color: #374151;
    }
    .calc-legend-item {
      display: flex;
      align-items: center;
      gap: 7px;
    }
    .calc-legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      display: inline-block;
      flex-shrink: 0;
    }
    .calc-legend-swatch.principal { background: rgba(45,106,159,0.35); border: 1.5px solid rgba(45,106,159,0.6); }
    .calc-legend-swatch.juros     { background: rgba(26,58,92,0.25); border: 2px solid #1a3a5c; }

    /* ===== TABLE ===== */
    .calc-table-section {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 28px;
      margin-bottom: 32px;
    }
    .calc-section-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: #111827;
      margin: 0 0 20px;
    }
    .calc-table-scroll { overflow-x: auto; }
    .calc-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    .calc-table th {
      background: #f9fafb;
      padding: 10px 16px;
      text-align: right;
      font-size: 12px;
      font-weight: 700;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
      border-bottom: 1px solid #e5e7eb;
    }
    .calc-table th:first-child { text-align: center; }
    .calc-table td {
      padding: 11px 16px;
      text-align: right;
      color: #374151;
      border-bottom: 1px solid #f3f4f6;
      font-size: 14px;
      white-space: nowrap;
    }
    .calc-table td:first-child { text-align: center; color: #9ca3af; font-weight: 600; }
    .calc-table tbody tr:hover { background: #f9fafb; }
    .calc-table tr.highlight td {
      background: #eff6ff;
      color: #1a3a5c;
      font-weight: 700;
      border-bottom: none;
    }
    .calc-table tr.highlight td:first-child { color: #1a3a5c; }

    /* ===== INFO ===== */
    .calc-info {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 32px;
    }
    .calc-info-text h2 {
      font-size: 1.2rem;
      font-weight: 800;
      color: #111827;
      margin: 0 0 10px;
    }
    .calc-info-text h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #1a3a5c;
      margin: 24px 0 8px;
    }
    .calc-info-text p {
      font-size: 15px;
      color: #374151;
      line-height: 1.7;
      margin: 0 0 12px;
    }
    .calc-formula-block {
      background: #f0f5fa;
      border-left: 3px solid #2d6a9f;
      border-radius: 0 6px 6px 0;
      padding: 14px 18px;
      margin-bottom: 16px;
    }
    .calc-formula-block code {
      font-family: 'Courier New', monospace;
      font-size: 15px;
      font-weight: 700;
      color: #1a3a5c;
      background: none;
      padding: 0;
    }
    .calc-formula-vars {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 6px 16px;
      font-size: 13px;
      color: #4b5563;
    }
    .calc-formula-vars strong { color: #1a3a5c; }

    /* ===== MOBILE ===== */
    @media (max-width: 768px) {
      .calc-hero-title { font-size: 1.6rem; }
      .calc-main { padding: 28px 16px 56px; }
      .calc-chart-total { font-size: 2rem; }
      .calc-chart-area { height: 240px; }
      .calc-table-section, .calc-info { padding: 20px 16px; }
    }
  </style>

</body>
</html>
