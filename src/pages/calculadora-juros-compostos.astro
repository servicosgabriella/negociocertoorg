  <script is:inline>
  (function () {
    'use strict';

    var chart = null;
    var debounceTimer = null;

    var BRL = new Intl.NumberFormat('pt-BR', {
      style: 'currency', currency: 'BRL', minimumFractionDigits: 2, maximumFractionDigits: 2
    });

    /* ---------- helpers ---------- */

    function parseVal(str) {
      var s = String(str).replace(/[R$\s%]/g, '').trim();
      // Se tem vírgula: ponto = milhar, vírgula = decimal  ("1.500,50")
      if (s.indexOf(',') !== -1) {
        s = s.replace(/\./g, '').replace(',', '.');
      } else {
        // Remove ponto usado como separador de milhar ("10.000")
        // Heurística: ponto seguido de exatamente 3 dígitos (e depois outro ponto ou fim)
        s = s.replace(/\.(\d{3})(?=\.|$)/g, '$1');
      }
      return parseFloat(s) || 0;
    }

    function fmtK(v) {
      if (v === 0) return 'R$ 0';
      if (v >= 1000000) return 'R$ ' + (v / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      if (v >= 1000)    return 'R$ ' + (v / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
      return BRL.format(v);
    }

    /* ---------- cálculo ----------
     * Simula mês a mês, agrupa por ano para a tabela.
     * Taxa anual é convertida em mensal: iMes = (1+i)^(1/12) - 1
     * totalMeses = período total em meses (convertido em lerInputs)
     */
    function calcular(P, taxaAnual, totalMeses, aporte, freqAporte) {
      var iAnual = taxaAnual / 100;
      var iMes   = Math.pow(1 + iAnual, 1 / 12) - 1;
      var saldo  = P;
      var rows   = [];
      var qtdAnos = Math.ceil(totalMeses / 12);

      for (var ano = 1; ano <= qtdAnos; ano++) {
        var saldoInicio    = saldo;
        var aporteNoAno    = 0;
        var mesesNesteAno  = Math.min(12, totalMeses - (ano - 1) * 12);

        for (var mes = 0; mes < mesesNesteAno; mes++) {
          var aporteEsteMes = 0;
          if (freqAporte === 'monthly') {
            aporteEsteMes = aporte;
          } else if (mes === 0) {
            aporteEsteMes = aporte; // aporte anual: início de cada ano
          }
          saldo *= (1 + iMes);
          saldo += aporteEsteMes;
          aporteNoAno += aporteEsteMes;
        }

        var juroNoAno = saldo - saldoInicio - aporteNoAno;
        rows.push({ ano: ano, saldoInicio: saldoInicio, aporteNoAno: aporteNoAno, juroNoAno: juroNoAno, saldoFinal: saldo });
      }

      return rows;
    }

    /* ---------- leitura dos inputs ---------- */
    function lerInputs() {
      var taxaFreq    = (document.getElementById('dd-taxa') || { dataset: { value: 'annual' } }).dataset.value;
      var periodoUnit = (document.getElementById('dd-periodo') || { dataset: { value: 'years' } }).dataset.value;
      var periodoVal  = Math.max(1, Math.round(parseVal(document.getElementById('inp-periodo').value)));
      var taxaVal     = parseVal(document.getElementById('inp-taxa').value);

      // Converte taxa para anual
      var taxaAnual = taxaFreq === 'monthly'
        ? (Math.pow(1 + taxaVal / 100, 12) - 1) * 100
        : taxaVal;

      // Converte período para meses
      var totalMeses = periodoUnit === 'months'
        ? Math.min(600, periodoVal)
        : Math.min(50, periodoVal) * 12;

      return {
        P:          parseVal(document.getElementById('inp-inicial').value),
        totalMeses: totalMeses,
        taxaAnual:  taxaAnual,
        aporte:     parseVal(document.getElementById('inp-aporte').value),
        freqAporte: (document.querySelector('.calc-toggle.active') || { dataset: {} }).dataset.value || 'monthly',
      };
    }

    /* ---------- atualiza UI ---------- */
    function atualizar() {
      var inp  = lerInputs();
      var rows = calcular(inp.P, inp.taxaAnual, inp.totalMeses, inp.aporte, inp.freqAporte);
      var final = rows.length ? rows[rows.length - 1].saldoFinal : inp.P;

      // Total em destaque
      document.getElementById('result-total').textContent = BRL.format(final);

      // --- Gráfico ---
      var anoAtual    = new Date().getFullYear();
      var labels      = ['Agora'];
      var dPrincipal  = [inp.P];   // capital inicial + aportes acumulados (sem juros)
      var dTotal      = [inp.P];   // saldo real (com juros)
      var contribAcum = inp.P;

      for (var i = 0; i < rows.length; i++) {
        contribAcum += rows[i].aporteNoAno;
        labels.push(String(anoAtual + i + 1));
        dPrincipal.push(contribAcum);
        dTotal.push(rows[i].saldoFinal);
      }

      if (chart) {
        chart.data.labels                  = labels;
        chart.data.datasets[0].data        = dPrincipal;
        chart.data.datasets[1].data        = dTotal;
        chart.update();
      }

      // --- Tabela ---
      var tbody = document.getElementById('tabela-body');
      tbody.innerHTML = '';

      for (var j = 0; j < rows.length; j++) {
        var row    = rows[j];
        var isLast = j === rows.length - 1;
        var tr     = document.createElement('tr');
        if (isLast) tr.className = 'highlight';

        function cel(val, bold) {
          return '<td>' + (bold ? '<strong>' + val + '</strong>' : val) + '</td>';
        }

        tr.innerHTML =
          cel(row.ano, isLast) +
          cel(BRL.format(row.saldoInicio), isLast) +
          cel(BRL.format(row.aporteNoAno), isLast) +
          cel(BRL.format(row.juroNoAno), isLast) +
          cel(BRL.format(row.saldoFinal), isLast);

        tbody.appendChild(tr);
      }
    }

    /* ---------- tooltip externo ---------- */
    function customTooltip(context) {
      var chart   = context.chart;
      var tooltip = context.tooltip;

      var el = document.getElementById('calc-tooltip');
      if (!el) {
        el = document.createElement('div');
        el.id = 'calc-tooltip';
        chart.canvas.parentNode.style.position = 'relative';
        chart.canvas.parentNode.appendChild(el);
      }

      if (tooltip.opacity === 0) {
        el.style.opacity = '0';
        return;
      }

      var pts       = tooltip.dataPoints || [];
      var principal = 0, total = 0;
      pts.forEach(function(p) {
        if (p.datasetIndex === 0) principal = p.parsed.y;
        if (p.datasetIndex === 1) total     = p.parsed.y;
      });
      var juros = total - principal;
      var label = tooltip.title && tooltip.title[0] ? tooltip.title[0] : '';
      var titulo = label === 'Agora' ? 'Agora' : 'Ano ' + label;

      el.innerHTML =
        '<div class="ct-title">' + titulo + '</div>' +
        '<div class="ct-row ct-bold"><span>Saldo total</span><span>' + BRL.format(total) + '</span></div>' +
        '<div class="ct-row"><span><span class="ct-dash" style="background:#16a34a"></span>Principal total</span><span>' + BRL.format(principal) + '</span></div>' +
        '<div class="ct-row"><span><span class="ct-dash" style="background:#eab308"></span>Juros acumulados</span><span>' + BRL.format(juros) + '</span></div>';

      // Posição relativa ao canvas
      var caret   = tooltip.caretX;
      var canvasW = chart.canvas.offsetWidth;
      var tipW    = 230;
      var left    = caret + 12;
      if (left + tipW > canvasW) left = caret - tipW - 12;

      el.style.opacity    = '1';
      el.style.left       = left + 'px';
      el.style.top        = (tooltip.caretY - 20) + 'px';
    }

    /* ---------- inicializa gráfico ---------- */
    function initChart() {
      var canvas = document.getElementById('grafico');
      if (!canvas || !window.Chart) return;

      chart = new window.Chart(canvas, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            {
              label: 'Principal total',
              data: [],
              fill: true,
              backgroundColor: 'rgba(22,163,74,0.18)',
              borderColor: 'transparent',
              borderWidth: 0,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#16a34a',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              tension: 0.2,
              order: 2,
            },
            {
              label: 'Juros acumulados',
              data: [],
              fill: '-1',
              backgroundColor: 'rgba(13,74,40,0.10)',
              borderColor: '#eab308',
              borderWidth: 2.5,
              pointRadius: 0,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#eab308',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2,
              tension: 0.2,
              order: 1,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              enabled: false,
              external: customTooltip,
            },
          },
          scales: {
            x: {
              grid: { display: false },
              border: { color: '#d1d5db' },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
                maxTicksLimit: 3,   // só início, meio e fim
                maxRotation: 0,
                autoSkip: true,
              },
            },
            y: {
              min: 0,
              grid: { color: '#f3f4f6' },
              border: { display: false },
              ticks: {
                color: '#6b7280',
                font: { size: 12 },
                maxTicksLimit: 6,
                callback: fmtK,
              },
            },
          },
        },
      });

      atualizar();
    }

    /* ---------- eventos ---------- */
    function debounce(fn) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fn, 280);
    }

    document.addEventListener('DOMContentLoaded', function () {
      initChart();

      ['inp-inicial', 'inp-periodo', 'inp-taxa', 'inp-aporte'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input',  function () { debounce(atualizar); });
        el.addEventListener('change', atualizar);
        el.addEventListener('blur',   atualizar);
      });

      document.querySelectorAll('.calc-toggle').forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.calc-toggle').forEach(function (b) {
            b.classList.remove('active');
          });
          btn.classList.add('active');
          atualizar();
        });
      });

      // Dropdowns customizados
      document.querySelectorAll('.calc-dd').forEach(function (dd) {
        var btn  = dd.querySelector('.calc-dd-btn');
        var opts = dd.querySelectorAll('.calc-dd-opt');

        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          var isOpen = dd.classList.contains('open');
          document.querySelectorAll('.calc-dd.open').forEach(function (o) {
            o.classList.remove('open');
            o.querySelector('.calc-dd-btn').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            dd.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });

        opts.forEach(function (opt) {
          opt.addEventListener('click', function () {
            opts.forEach(function (o) { o.classList.remove('active'); });
            opt.classList.add('active');
            dd.dataset.value = opt.dataset.value;
            dd.querySelector('.calc-dd-label').textContent = opt.textContent;
            dd.classList.remove('open');
            btn.setAttribute('aria-expanded', 'false');
            atualizar();
          });
        });
      });

      document.addEventListener('click', function () {
        document.querySelectorAll('.calc-dd.open').forEach(function (dd) {
          dd.classList.remove('open');
          dd.querySelector('.calc-dd-btn').setAttribute('aria-expanded', 'false');
        });
      });
    });

  }());
  </script>

