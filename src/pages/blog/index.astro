---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const categories = ['Todos', ...Array.from(new Set(posts.map(p => p.data.category).filter(Boolean)))];

const featured = posts[0];
const secondary = posts.slice(1, 4);
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blog — NegócioCerto</title>
  <meta name="description" content="Artigos, guias e comparações para empreendedores brasileiros." />
  <link rel="canonical" href="https://negociocerto.org/blog/" />
</head>
<body>
  <Header />

  <!-- HERO VERDE -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <div class="blog-hero-text">
        <h1 class="blog-hero-title">Artigos para Empreendedores</h1>
        <p class="blog-hero-desc">Nossos especialistas pesquisam, testam e explicam — para que você tome decisões melhores para o seu negócio.</p>
      </div>
    </div>
    <!-- Triângulos decorativos -->
    <div class="blog-hero-tri blog-hero-tri-1" aria-hidden="true"></div>
    <div class="blog-hero-tri blog-hero-tri-2" aria-hidden="true"></div>
  </section>

  <!-- PRINCIPAIS NOTÍCIAS -->
  {featured && (
    <section class="top-news-section">
      <div class="top-news-container">
        <h2 class="top-news-heading">Principais artigos</h2>
        <div class="top-news-grid">

          <!-- Destaque principal -->
          <a href={`/blog/${featured.id}/`} class="top-news-featured">
            <div class="top-news-featured-img">
              {featured.data.coverImage ? (
                <img src={featured.data.coverImage} alt={featured.data.coverAlt ?? featured.data.title} loading="eager" />
              ) : (
                <div class="top-news-placeholder"></div>
              )}
            </div>
            <h3 class="top-news-featured-title">{featured.data.title}</h3>
            {featured.data.description && (
              <p class="top-news-featured-desc">{featured.data.description}</p>
            )}
            <div class="top-news-author">
              <img src={featured.data.authorImage} alt={featured.data.authorName} class="top-news-avatar" width="32" height="32" />
              <span>Por {featured.data.authorName}</span>
            </div>
          </a>

          <!-- Lista de 3 secundários -->
          <div class="top-news-list">
            {secondary.map((post) => (
              <a href={`/blog/${post.id}/`} class="top-news-item">
                <div class="top-news-item-img">
                  {post.data.coverImage ? (
                    <img src={post.data.coverImage} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
                  ) : (
                    <div class="top-news-placeholder"></div>
                  )}
                </div>
                <div class="top-news-item-body">
                  <h3 class="top-news-item-title">{post.data.title}</h3>
                  <div class="top-news-author">
                    <img src={post.data.authorImage} alt={post.data.authorName} class="top-news-avatar" width="28" height="28" />
                    <span>Por {post.data.authorName}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>

        </div>
      </div>
    </section>
  )}

  <main class="blog-index-main">
    <div class="blog-index-container">

      <!-- Tabs de categoria -->
      {categories.length > 1 && (
        <div class="blog-tabs" role="tablist" aria-label="Filtrar por categoria">
          {categories.map((cat, i) => (
            <button
              class={`blog-tab${i === 0 ? ' active' : ''}`}
              data-cat={cat === 'Todos' ? 'todos' : cat}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              {cat.toUpperCase()}
            </button>
          ))}
        </div>
      )}

      <!-- Grade de artigos — 2 colunas -->
      <div class="blog-articles-grid">
        {posts.map((post) => (
          <article
            class="blog-article-item"
            data-cat={post.data.category ?? 'todos'}
          >
            <a href={`/blog/${post.id}/`} class="blog-article-link">
              <div class="blog-article-thumb">
                {post.data.coverImage ? (
                  <img
                    src={post.data.coverImage}
                    alt={post.data.coverAlt ?? post.data.title}
                    loading="lazy"
                    width="160"
                    height="110"
                  />
                ) : (
                  <div class="blog-article-thumb-placeholder"></div>
                )}
              </div>
              <div class="blog-article-body">
                <h2 class="blog-article-title">{post.data.title}</h2>
                <div class="blog-article-author">
                  <img
                    src={post.data.authorImage}
                    alt={post.data.authorName}
                    class="blog-article-avatar"
                    width="28"
                    height="28"
                    loading="lazy"
                  />
                  <span class="blog-article-author-name">Por {post.data.authorName}</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="blog-empty">Nenhum post publicado ainda.</p>
      )}

    </div>
  </main>

  <Footer />

  <script is:inline>
    const tabs = document.querySelectorAll('.blog-tab');
    const articles = document.querySelectorAll('.blog-article-item');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        const cat = tab.dataset.cat;
        articles.forEach(article => {
          if (cat === 'todos') {
            article.style.display = '';
          } else {
            article.style.display = article.dataset.cat === cat ? '' : 'none';
          }
        });
      });
    });
  </script>

  <style>
    body { margin: 0; background: #ffffff; }

    /* ======= PRINCIPAIS NOTÍCIAS ======= */
    .top-news-section {
      background: #ffffff;
      padding: 56px 24px 48px;
      border-bottom: 1px solid #e5e7eb;
    }
    .top-news-container {
      max-width: 1120px;
      margin: 0 auto;
    }
    .top-news-heading {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #111827;
      margin: 0 0 32px;
      letter-spacing: -0.3px;
    }
    .top-news-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: start;
    }

    /* Destaque */
    .top-news-featured {
      display: flex;
      flex-direction: column;
      gap: 16px;
      text-decoration: none;
    }
    .top-news-featured-img {
      width: 100%;
      aspect-ratio: 16/10;
      border-radius: 10px;
      overflow: hidden;
    }
    .top-news-featured-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .top-news-featured:hover .top-news-featured-img img { transform: scale(1.03); }
    .top-news-featured-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: clamp(1.05rem, 1.6vw, 1.25rem);
      font-weight: 700;
      color: #111827;
      margin: 0;
      line-height: 1.4;
      transition: color 0.15s;
    }
    .top-news-featured:hover .top-news-featured-title { color: #2d6a4f; }
    .top-news-featured-desc {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 0.95rem;
      color: #4b5563;
      line-height: 1.65;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Lista secundária */
    .top-news-list {
      display: flex;
      flex-direction: column;
    }
    .top-news-item {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 20px 0;
      border-bottom: 1px solid #e5e7eb;
      text-decoration: none;
    }
    .top-news-item:first-child { border-top: 1px solid #e5e7eb; }
    .top-news-item-img {
      flex-shrink: 0;
      width: 148px;
      height: 100px;
      border-radius: 8px;
      overflow: hidden;
    }
    .top-news-item-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .top-news-item:hover .top-news-item-img img { transform: scale(1.04); }
    .top-news-item-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .top-news-item-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 0.975rem;
      font-weight: 700;
      color: #111827;
      margin: 0;
      line-height: 1.4;
      transition: color 0.15s;
    }
    .top-news-item:hover .top-news-item-title { color: #2d6a4f; }

    /* Autor (compartilhado) */
    .top-news-author {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 13px;
      color: #6b7280;
      font-weight: 500;
    }
    .top-news-avatar {
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .top-news-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #2d6a4f 0%, #1a3a2a 100%);
    }

    @media (max-width: 768px) {
      .top-news-section { padding: 40px 20px 36px; }
      .top-news-grid { grid-template-columns: 1fr; gap: 32px; }
      .top-news-item-img { width: 112px; height: 78px; }
    }

    /* ======= HERO ======= */
    .blog-hero {
      position: relative;
      background: linear-gradient(135deg, #0d4a28 0%, #1d6b3d 50%, #2d6a4f 100%);
      overflow: hidden;
      padding: 64px 32px 72px;
    }
    .blog-hero-inner {
      max-width: 1120px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }
    .blog-hero-text {
      max-width: 680px;
    }
    .blog-hero-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: clamp(2rem, 4vw, 3.25rem);
      font-weight: 800;
      color: #ffffff;
      margin: 0 0 20px;
      line-height: 1.1;
      letter-spacing: -0.5px;
    }
    .blog-hero-desc {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      color: rgba(255, 255, 255, 0.82);
      line-height: 1.65;
      margin: 0;
      max-width: 560px;
    }

    /* Triângulos decorativos */
    .blog-hero-tri {
      position: absolute;
      bottom: 0;
      right: 0;
    }
    .blog-hero-tri-1 {
      width: 0;
      height: 0;
      border-style: solid;
      border-width: 0 0 180px 180px;
      border-color: transparent transparent #ace347 transparent;
      opacity: 0.55;
      right: 80px;
    }
    .blog-hero-tri-2 {
      width: 0;
      height: 0;
      border-style: solid;
      border-width: 0 0 120px 120px;
      border-color: transparent transparent #5cb85c transparent;
      opacity: 0.30;
      right: 0;
    }

    @media (max-width: 600px) {
      .blog-hero { padding: 44px 20px 56px; }
      .blog-hero-tri { display: none; }
    }

    /* ======= MAIN ======= */
    .blog-index-main {
      background: #ffffff;
      padding: 48px 24px 80px;
    }
    .blog-index-container {
      max-width: 1120px;
      margin: 0 auto;
    }

    /* ======= TABS ======= */
    .blog-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      border-bottom: 2px solid #e5e7eb;
      margin-bottom: 40px;
    }
    .blog-tab {
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      padding: 10px 20px;
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.1em;
      color: #6b7280;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }
    .blog-tab:hover { color: #111827; }
    .blog-tab.active {
      color: #2d6a4f;
      border-bottom-color: #2d6a4f;
    }

    /* ======= GRADE DE ARTIGOS ======= */
    .blog-articles-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 56px;
    }

    /* ======= ARTIGO INDIVIDUAL ======= */
    .blog-article-item {
      border-bottom: 1px solid #e5e7eb;
      padding: 24px 0;
    }

    .blog-article-link {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      text-decoration: none;
    }
    .blog-article-link:hover .blog-article-title {
      color: #2d6a4f;
    }

    /* Thumb */
    .blog-article-thumb {
      flex-shrink: 0;
      width: 160px;
      height: 110px;
      border-radius: 8px;
      overflow: hidden;
    }
    .blog-article-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 8px;
      transition: transform 0.3s ease;
    }
    .blog-article-link:hover .blog-article-thumb img {
      transform: scale(1.03);
    }
    .blog-article-thumb-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #2d6a4f 0%, #1a3a2a 100%);
      border-radius: 8px;
    }

    /* Corpo */
    .blog-article-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 12px;
    }
    .blog-article-title {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: #111827;
      line-height: 1.45;
      margin: 0;
      transition: color 0.15s;
    }

    /* Autor */
    .blog-article-author {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: auto;
    }
    .blog-article-avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .blog-article-author-name {
      font-family: 'Nunito Sans', 'Inter', sans-serif;
      font-size: 13px;
      color: #6b7280;
      font-weight: 500;
    }

    /* Vazio */
    .blog-empty {
      font-family: 'Nunito Sans', sans-serif;
      color: #6b7280;
      text-align: center;
      padding: 80px 0;
      font-size: 16px;
    }

    /* ======= RESPONSIVO ======= */
    @media (max-width: 768px) {
      .blog-index-main { padding: 36px 20px 64px; }
      .blog-articles-grid { grid-template-columns: 1fr; column-gap: 0; }
      .blog-tab { padding: 10px 14px; font-size: 11px; }
      .blog-article-thumb { width: 120px; height: 84px; }
    }
    @media (max-width: 480px) {
      .blog-article-thumb { width: 96px; height: 68px; }
      .blog-article-title { font-size: 0.9rem; }
    }
  </style>

</body>
</html>
