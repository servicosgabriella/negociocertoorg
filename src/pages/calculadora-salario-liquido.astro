  <script is:inline>
  (function () {
    'use strict';

    var chart = null;

    var BRL = new Intl.NumberFormat('pt-BR', {
      style: 'currency', currency: 'BRL', minimumFractionDigits: 2, maximumFractionDigits: 2
    });

    /* ---------- helpers ---------- */
    function parseVal(str) {
      var s = String(str).replace(/[R$\s%]/g, '').trim();
      if (s.indexOf(',') !== -1) {
        s = s.replace(/\./g, '').replace(',', '.');
      } else {
        s = s.replace(/\.(\d{3})(?=\.|$)/g, '$1');
      }
      return parseFloat(s) || 0;
    }

    function fmt(v) { return BRL.format(v); }
    function pct(v, total) { return total > 0 ? (v / total * 100).toFixed(1) + '%' : '0,0%'; }

    /* ---------- INSS 2026 progressivo ---------- */
    function calcularINSS(bruto) {
      var faixas = [
        { ate: 1621.00,  aliquota: 0.075 },
        { ate: 2902.84,  aliquota: 0.09  },
        { ate: 4354.27,  aliquota: 0.12  },
        { ate: 8475.55,  aliquota: 0.14  },
      ];
      var inss     = 0;
      var anterior = 0;

      for (var i = 0; i < faixas.length; i++) {
        if (bruto <= anterior) break;
        var topo = faixas[i].ate;
        var base = Math.min(bruto, topo) - anterior;
        inss += base * faixas[i].aliquota;
        anterior = topo;
        if (bruto <= topo) break;
      }

      return Math.min(inss, 988.09);
    }

    /* ---------- IRRF 2026 (Lei 15.270/2025) ---------- */
    function calcularIRRF(baseCalculo, dependentes, bruto) {
      var deducaoDep = 189.59;
      var base = Math.max(0, baseCalculo - dependentes * deducaoDep);

      // Tabela progressiva 2026 (atualizada)
      var faixas = [
        { ate: 2428.80,   aliquota: 0,     deducao: 0      },
        { ate: 2826.65,   aliquota: 0.075, deducao: 182.16 },
        { ate: 3751.05,   aliquota: 0.15,  deducao: 394.16 },
        { ate: 4664.68,   aliquota: 0.225, deducao: 675.49 },
        { ate: Infinity,  aliquota: 0.275, deducao: 908.73 },
      ];

      var irrf = 0;
      for (var i = 0; i < faixas.length; i++) {
        if (base <= faixas[i].ate) {
          irrf = Math.max(0, base * faixas[i].aliquota - faixas[i].deducao);
          break;
        }
      }

      // Redutor 2026: isenção total até R$ 5.000 bruto,
      // redução gradual até R$ 7.350 (fórmula: 978,62 − 0,133145 × bruto)
      if (bruto <= 5000) {
        irrf = 0;
      } else if (bruto <= 7350) {
        var redutor = 978.62 - (0.133145 * bruto);
        irrf = Math.max(0, irrf - redutor);
      }

      return irrf;
    }

    /* ---------- cálculo principal ---------- */
    function calcular() {
      var bruto      = parseVal(document.getElementById('inp-bruto').value);
      var dependentes = Math.max(0, Math.round(parseVal(document.getElementById('inp-dependentes').value)));
      var outros     = parseVal(document.getElementById('inp-outros').value);

      var inss       = calcularINSS(bruto);
      var baseIR     = Math.max(0, bruto - inss - outros);
      var irrf       = calcularIRRF(baseIR, dependentes, bruto);
      var totalDesc  = inss + irrf + outros;
      var liquido    = Math.max(0, bruto - totalDesc);
      var pctLiq     = bruto > 0 ? (liquido / bruto * 100) : 0;

      return { bruto: bruto, inss: inss, irrf: irrf, outros: outros, totalDesc: totalDesc, liquido: liquido, pctLiq: pctLiq };
    }

    /* ---------- atualiza UI ---------- */
    function atualizar() {
      var r = calcular();

      // Resumo no painel esquerdo
      document.getElementById('res-inss').textContent     = '− ' + fmt(r.inss);
      document.getElementById('res-irrf').textContent     = '− ' + fmt(r.irrf);
      document.getElementById('res-outros').textContent   = '− ' + fmt(r.outros);
      document.getElementById('res-total-desc').textContent = '− ' + fmt(r.totalDesc);

      // Resultado principal
      document.getElementById('result-liquido').textContent = fmt(r.liquido);
      document.getElementById('result-pct').textContent    = r.pctLiq.toFixed(1).replace('.', ',') + '% do bruto';

      // Gráfico donut
      if (chart) {
        chart.data.datasets[0].data = [r.liquido, r.inss, r.irrf, r.outros];
        chart.update();
      }

      // Tabela de composição
      var tbody = document.getElementById('tabela-body');
      tbody.innerHTML = '';

      var linhas = [
        { label: 'Salário bruto',          valor: r.bruto,     sinal: '',  obs: 'Valor do contrato de trabalho',         bold: false },
        { label: 'INSS',                   valor: r.inss,      sinal: '−', obs: 'Tabela progressiva 2025 (até 14%)',      bold: false },
        { label: 'Base de cálculo IR',     valor: r.bruto - r.inss - r.outros, sinal: '', obs: 'Bruto − INSS − outros descontos', bold: false },
        { label: 'IRRF',                   valor: r.irrf,      sinal: '−', obs: 'Tabela progressiva 2025 (até 27,5%)',   bold: false },
        { label: 'Outros descontos',       valor: r.outros,    sinal: '−', obs: 'Vale-transporte, plano de saúde, etc.', bold: false },
        { label: 'Salário líquido',        valor: r.liquido,   sinal: '',  obs: r.pctLiq.toFixed(1).replace('.', ',') + '% do bruto', bold: true },
      ];

      linhas.forEach(function (linha) {
        if (linha.label === 'Outros descontos' && r.outros === 0) return;
        if (linha.label === 'Base de cálculo IR') return; // linha informativa — omitir para clareza
        var tr = document.createElement('tr');
        if (linha.bold) tr.className = 'highlight';

        var valor = linha.sinal ? linha.sinal + ' ' + fmt(linha.valor) : fmt(linha.valor);
        var pctStr = linha.label === 'Salário bruto' ? '100%'
                   : linha.label === 'Salário líquido' ? r.pctLiq.toFixed(1).replace('.', ',') + '%'
                   : (linha.valor > 0 ? pct(linha.valor, r.bruto) : '—');

        tr.innerHTML =
          '<td style="text-align:left; color:' + (linha.bold ? '#1a3a5c' : '#374151') + '">' +
            (linha.bold ? '<strong>' + linha.label + '</strong>' : linha.label) +
          '</td>' +
          '<td>' + (linha.bold ? '<strong>' + valor + '</strong>' : valor) + '</td>' +
          '<td>' + pctStr + '</td>' +
          '<td style="text-align:left; color:#9ca3af; font-size:13px">' + linha.obs + '</td>';

        tbody.appendChild(tr);
      });
    }

    /* ---------- tooltip externo donut ---------- */
    function customTooltip(context) {
      var chartObj = context.chart;
      var tooltip  = context.tooltip;

      var el = document.getElementById('calc-tooltip');
      if (!el) {
        el = document.createElement('div');
        el.id = 'calc-tooltip';
        chartObj.canvas.parentNode.style.position = 'relative';
        chartObj.canvas.parentNode.appendChild(el);
      }

      if (tooltip.opacity === 0) { el.style.opacity = '0'; return; }

      var labels = ['Salário líquido', 'INSS', 'IRRF', 'Outros descontos'];
      var pt     = tooltip.dataPoints && tooltip.dataPoints[0];
      if (!pt) return;

      var label = labels[pt.dataIndex] || '';
      var valor = pt.parsed || 0;

      el.innerHTML =
        '<div class="ct-title">' + label + '</div>' +
        '<div class="ct-row ct-bold"><span>' + BRL.format(valor) + '</span></div>';

      var canvasW = chartObj.canvas.offsetWidth;
      var tipW    = 180;
      var left    = tooltip.caretX + 12;
      if (left + tipW > canvasW) left = tooltip.caretX - tipW - 12;

      el.style.opacity = '1';
      el.style.left    = left + 'px';
      el.style.top     = (tooltip.caretY - 20) + 'px';
    }

    /* ---------- inicializa gráfico donut ---------- */
    function initChart() {
      var canvas = document.getElementById('grafico');
      if (!canvas || !window.Chart) return;

      chart = new window.Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: ['Salário líquido', 'INSS', 'IRRF', 'Outros'],
          datasets: [{
            data: [0, 0, 0, 0],
            backgroundColor: ['#1a3a5c', '#e74c3c', '#eab308', '#9ca3af'],
            borderColor: ['#fff', '#fff', '#fff', '#fff'],
            borderWidth: 3,
            hoverOffset: 8,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '65%',
          plugins: {
            legend: { display: false },
            tooltip: {
              enabled: false,
              external: customTooltip,
            },
          },
        },
      });

      atualizar();
    }

    /* ---------- eventos ---------- */
    var debounceTimer = null;
    function debounce(fn) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fn, 280);
    }

    document.addEventListener('DOMContentLoaded', function () {
      initChart();

      ['inp-bruto', 'inp-dependentes', 'inp-outros'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input',  function () { debounce(atualizar); });
        el.addEventListener('change', atualizar);
        el.addEventListener('blur',   atualizar);
      });
    });

  }());
  </script>

