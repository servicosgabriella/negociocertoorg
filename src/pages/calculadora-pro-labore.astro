    }
    .calc-legend-item { display: flex; align-items: center; gap: 7px; }
    .calc-legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      display: inline-block;
      flex-shrink: 0;
    }
    .calc-legend-swatch.liquido { background: #16a34a; }
    .calc-legend-swatch.inss    { background: #e74c3c; }
    .calc-legend-swatch.irpf    { background: #eab308; }
    .calc-legend-swatch.outros  { background: #9ca3af; }

    /* ===== TABLE ===== */
    .calc-table-section {
