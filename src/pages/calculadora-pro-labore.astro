  <script is:inline>
  (function () {
    'use strict';

    var chart = null;
    var debounceTimer = null;

    // Estado
    var tipoSocio = 'admin';
    var recolherINSS = true;
    var reterIR = true;

    var BRL = new Intl.NumberFormat('pt-BR', {
      style: 'currency', currency: 'BRL', minimumFractionDigits: 2, maximumFractionDigits: 2
    });

    /* ---------- helpers ---------- */
    function parseVal(str) {
      var s = String(str).replace(/[R$\s%]/g, '').trim();
      if (s.indexOf(',') !== -1) {
        s = s.replace(/\./g, '').replace(',', '.');
      } else {
        s = s.replace(/\.(\d{3})(?=\.|$)/g, '$1');
      }
      return parseFloat(s) || 0;
    }
    function fmt(v) { return BRL.format(v); }
    function pct(v, total) { return total > 0 ? (v / total * 100).toFixed(1) + '%' : '0,0%'; }

    /* ---------- INSS 2026 progressivo ---------- */
    function calcularINSS(bruto) {
      var faixas = [
        { ate: 1621.00,  aliquota: 0.075 },
        { ate: 2902.84,  aliquota: 0.09  },
        { ate: 4354.27,  aliquota: 0.12  },
        { ate: 8475.55,  aliquota: 0.14  },
      ];
      var inss = 0, anterior = 0;
      for (var i = 0; i < faixas.length; i++) {
        if (bruto <= anterior) break;
        var topo = faixas[i].ate;
        var base = Math.min(bruto, topo) - anterior;
        inss += base * faixas[i].aliquota;
        anterior = topo;
        if (bruto <= topo) break;
      }
      return Math.min(inss, 988.09);
    }

    /* ---------- IRPF 2026 ---------- */
    function calcularIRPF(baseCalculo, dependentes, bruto) {
      var deducaoDep = 189.59;
      var base = Math.max(0, baseCalculo - dependentes * deducaoDep);
      var faixas = [
        { ate: 2428.80,  aliquota: 0,     deducao: 0      },
        { ate: 2826.65,  aliquota: 0.075, deducao: 182.16 },
        { ate: 3751.05,  aliquota: 0.15,  deducao: 394.16 },
        { ate: 4664.68,  aliquota: 0.225, deducao: 675.49 },
        { ate: Infinity, aliquota: 0.275, deducao: 908.73 },
      ];
      var irpf = 0;
      for (var i = 0; i < faixas.length; i++) {
        if (base <= faixas[i].ate) {
          irpf = Math.max(0, base * faixas[i].aliquota - faixas[i].deducao);
          break;
        }
      }
      // Redutor 2026
      if (bruto <= 5000) {
        irpf = 0;
      } else if (bruto <= 7350) {
        var redutor = 978.62 - (0.133145 * bruto);
        irpf = Math.max(0, irpf - redutor);
      }
      return irpf;
    }

    /* ---------- cálculo principal ---------- */
    function calcular() {
      var bruto      = parseVal(document.getElementById('inp-bruto').value);
      var dependentes = Math.max(0, Math.round(parseVal(document.getElementById('inp-dependentes').value)));
      var deducoes   = parseVal(document.getElementById('inp-deducoes').value);
      var regime     = document.getElementById('sel-regime').value;
      var rat        = parseFloat(document.getElementById('sel-rat').value) || 0.02;
      var isMEI      = regime === 'mei';
      var isSimples  = regime === 'simples';

      // INSS do sócio
      var inss = 0;
      var inssAtivo = !isMEI && (tipoSocio === 'admin' || (tipoSocio === 'nao-admin' && recolherINSS));
      if (inssAtivo) {
        inss = calcularINSS(bruto);
      }

      // IRPF
      var irpf = 0;
      if (reterIR) {
        var baseIR = Math.max(0, bruto - inss - deducoes);
        irpf = calcularIRPF(baseIR, dependentes, bruto);
      }

      var totalDesc  = inss + irpf + deducoes;
      var liquido    = Math.max(0, bruto - totalDesc);
      var pctLiq     = bruto > 0 ? (liquido / bruto * 100) : 0;

      // Custo patronal (apenas Lucro Presumido/Real + sócio admin)
      var inssPat   = 0;
      var ratVal    = 0;
      var terceiros = 0;
      var tercPct   = 0.058;
      if (!isMEI && !isSimples && tipoSocio === 'admin') {
        inssPat   = bruto * 0.20;
        ratVal    = bruto * rat;
        terceiros = bruto * tercPct;
      }
      var totalPat     = inssPat + ratVal + terceiros;
      var custoEmpresa = bruto + totalPat;

      return {
        bruto, inss, irpf, deducoes, totalDesc, liquido, pctLiq,
        inssPat, ratVal, terceiros, totalPat, custoEmpresa,
        isMEI, isSimples, rat, inssAtivo
      };
    }

    /* ---------- atualiza UI ---------- */
    function atualizar() {
      var r = calcular();

      // Resumo painel esquerdo
      document.getElementById('res-inss').textContent      = '− ' + fmt(r.inss);
      document.getElementById('res-irpf').textContent      = '− ' + fmt(r.irpf);
      document.getElementById('res-deducoes').textContent  = '− ' + fmt(r.deducoes);
      document.getElementById('res-total-desc').textContent = '− ' + fmt(r.totalDesc);
      document.getElementById('res-custo-empresa').textContent = fmt(r.custoEmpresa);

      // Disclaimer MEI
      document.getElementById('disc-mei').style.display    = r.isMEI ? '' : 'none';
      document.getElementById('disc-padrao').style.display = r.isMEI ? 'none' : '';

      // Avisos de isenção/redutor 2026
      var avisoIsencao = document.getElementById('aviso-isencao');
      var avisoReductor = document.getElementById('aviso-redutor');
      if (avisoIsencao) avisoIsencao.style.display = (reterIR && r.bruto > 0 && r.bruto <= 5000) ? '' : 'none';
      if (avisoReductor) avisoReductor.style.display = (reterIR && r.bruto > 5000 && r.bruto <= 7350) ? '' : 'none';

      // Resultado principal
      document.getElementById('result-liquido').textContent = fmt(r.liquido);
      document.getElementById('result-pct').textContent     = r.pctLiq.toFixed(1).replace('.', ',') + '% do bruto';

      // Gráfico donut
      if (chart) {
        chart.data.datasets[0].data = [r.liquido, r.inss, r.irpf, r.deducoes];
        chart.update();
      }

      // ---------- Tabela composição ----------
      var tbody = document.getElementById('tabela-body');
      tbody.innerHTML = '';

      var baseIR = Math.max(0, r.bruto - r.inss - r.deducoes);

      var linhas = [
        { label: 'Pró-labore bruto',   valor: r.bruto,    sinal: '',  obs: 'Valor definido em contrato social ou ata',   bold: false },
        { label: 'INSS sócio',         valor: r.inss,     sinal: '−', obs: r.isMEI ? 'Incluído no DAS do MEI' : (r.inssAtivo ? 'Tabela progressiva 2026' : 'Não recolhido (facultativo)'), bold: false },
        { label: 'Base de cálculo IR', valor: baseIR,     sinal: '',  obs: 'Pró-labore − INSS − Deduções',               bold: false, skip: !reterIR },
        { label: 'IRPF',               valor: r.irpf,     sinal: '−', obs: !reterIR ? 'Não retido na fonte — recolher via carnê-leão' : (r.bruto <= 5000 ? 'Isento pela Lei 15.270/2025 (até R$ 5.000)' : r.bruto <= 7350 ? 'Redutor 2026 aplicado (Lei 15.270/2025)' : 'Tabela progressiva 2026'), bold: false },
        { label: 'Deduções adicionais',valor: r.deducoes, sinal: '−', obs: 'Pensão alimentícia, prev. privada, etc.',     bold: false, skip: r.deducoes === 0 },
        { label: 'Pró-labore líquido', valor: r.liquido,  sinal: '',  obs: r.pctLiq.toFixed(1).replace('.', ',') + '% do bruto', bold: true },
      ];

      linhas.forEach(function(linha) {
        if (linha.skip) return;
        if (linha.label === 'Base de cálculo IR') return;
        var tr = document.createElement('tr');
        if (linha.bold) tr.className = 'highlight';

        var valorStr = linha.sinal ? linha.sinal + ' ' + fmt(linha.valor) : fmt(linha.valor);
        var pctStr = linha.label === 'Pró-labore bruto' ? '100%'
                   : linha.label === 'Pró-labore líquido' ? r.pctLiq.toFixed(1).replace('.', ',') + '%'
                   : (linha.valor > 0 ? pct(linha.valor, r.bruto) : '—');

        tr.innerHTML =
          '<td style="text-align:left; color:' + (linha.bold ? '#0d4a28' : '#374151') + '">' +
            (linha.bold ? '<strong>' + linha.label + '</strong>' : linha.label) +
          '</td>' +
          '<td>' + (linha.bold ? '<strong>' + valorStr + '</strong>' : valorStr) + '</td>' +
          '<td>' + pctStr + '</td>' +
          '<td style="text-align:left; color:#9ca3af; font-size:13px">' + linha.obs + '</td>';

        tbody.appendChild(tr);
      });

      // ---------- Tabela custo empresa ----------
      var tbodyCusto = document.getElementById('tabela-custo-body');
      tbodyCusto.innerHTML = '';

      var custoLinhas = [];
      custoLinhas.push({ label: 'Pró-labore bruto', aliq: '—', valor: r.bruto, obs: 'Valor pago ao sócio', bold: false });

      if (r.isMEI) {
        custoLinhas.push({ label: 'INSS patronal', aliq: '—', valor: 0, obs: 'Incluído no DAS fixo mensal', bold: false });
        custoLinhas.push({ label: 'RAT e terceiros', aliq: '—', valor: 0, obs: 'Incluído no DAS fixo mensal', bold: false });
      } else if (r.isSimples) {
        custoLinhas.push({ label: 'INSS patronal (CPP)', aliq: '—', valor: 0, obs: 'Incluído no Simples Nacional (DAS)', bold: false });
        custoLinhas.push({ label: 'RAT e terceiros', aliq: '—', valor: 0, obs: 'Substituído pelo Simples Nacional', bold: false });
      } else if (tipoSocio === 'admin') {
        var ratPct = (r.rat * 100).toFixed(0) + '%';
        custoLinhas.push({ label: 'INSS patronal', aliq: '20%', valor: r.inssPat, obs: 'Lucro Presumido / Lucro Real', bold: false });
        custoLinhas.push({ label: 'RAT', aliq: ratPct, valor: r.ratVal, obs: 'Seguro Acidente de Trabalho (CNAE)', bold: false });
        custoLinhas.push({ label: 'Terceiros (SENAI/SESI etc.)', aliq: '5,8%', valor: r.terceiros, obs: 'Contribuições a entidades do Sistema S', bold: false });
      } else {
        custoLinhas.push({ label: 'INSS patronal', aliq: '20%', valor: 0, obs: 'Não incide sobre sócio não administrador sem pró-labore gerencial', bold: false });
      }

      custoLinhas.push({ label: 'Custo total para empresa', aliq: '—', valor: r.custoEmpresa, obs: 'Desembolso total para remunerar o sócio', bold: true });

      custoLinhas.forEach(function(linha) {
        var tr = document.createElement('tr');
        if (linha.bold) tr.className = 'highlight';
        tr.innerHTML =
          '<td style="text-align:left; color:' + (linha.bold ? '#0d4a28' : '#374151') + '">' +
            (linha.bold ? '<strong>' + linha.label + '</strong>' : linha.label) +
          '</td>' +
          '<td>' + linha.aliq + '</td>' +
          '<td>' + (linha.bold ? '<strong>' + fmt(linha.valor) + '</strong>' : fmt(linha.valor)) + '</td>' +
          '<td style="text-align:left; color:#9ca3af; font-size:13px">' + linha.obs + '</td>';
        tbodyCusto.appendChild(tr);
      });
    }

    /* ---------- tooltip externo donut ---------- */
    function customTooltip(context) {
      var chartObj = context.chart;
      var tooltip  = context.tooltip;

      var el = document.getElementById('calc-tooltip');
      if (!el) {
        el = document.createElement('div');
        el.id = 'calc-tooltip';
        chartObj.canvas.parentNode.style.position = 'relative';
        chartObj.canvas.parentNode.appendChild(el);
      }

      if (tooltip.opacity === 0) { el.style.opacity = '0'; return; }

      var labels = ['Pró-labore líquido', 'INSS sócio', 'IRPF', 'Deduções'];
      var pt = tooltip.dataPoints && tooltip.dataPoints[0];
      if (!pt) return;

      el.innerHTML =
        '<div class="ct-title">' + (labels[pt.dataIndex] || '') + '</div>' +
        '<div class="ct-row ct-bold"><span>' + BRL.format(pt.parsed || 0) + '</span></div>';

      var canvasW = chartObj.canvas.offsetWidth;
      var tipW = 200;
      var left = tooltip.caretX + 12;
      if (left + tipW > canvasW) left = tooltip.caretX - tipW - 12;

      el.style.opacity = '1';
      el.style.left    = left + 'px';
      el.style.top     = (tooltip.caretY - 20) + 'px';
    }

    /* ---------- inicializa gráfico donut ---------- */
    function initChart() {
      var canvas = document.getElementById('grafico');
      if (!canvas || !window.Chart) return;

      chart = new window.Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: ['Pró-labore líquido', 'INSS sócio', 'IRPF', 'Deduções'],
          datasets: [{
            data: [0, 0, 0, 0],
            backgroundColor: ['#16a34a', '#e74c3c', '#eab308', '#9ca3af'],
            borderColor: ['#fff', '#fff', '#fff', '#fff'],
            borderWidth: 3,
            hoverOffset: 8,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '65%',
          plugins: {
            legend: { display: false },
            tooltip: { enabled: false, external: customTooltip },
          },
        },
      });

      atualizar();
    }

    /* ---------- debounce ---------- */
    function debounce(fn) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(fn, 280);
    }

    /* ---------- mostrar/ocultar campos condicionais ---------- */
    function syncUI() {
      // INSS facultativo: só para não-admin
      var fieldINSS = document.getElementById('field-inss-facultativo');
      fieldINSS.style.display = tipoSocio === 'nao-admin' ? '' : 'none';

      // RAT: só para Lucro Presumido/Real
      var regime = document.getElementById('sel-regime').value;
      document.getElementById('field-rat').style.display =
        (regime === 'presumido' && tipoSocio === 'admin') ? '' : 'none';

      // Dependentes e deduções: só quando IR retido
      document.getElementById('field-dependentes').style.display = reterIR ? '' : 'none';
    }

    /* ---------- DOMContentLoaded ---------- */
    document.addEventListener('DOMContentLoaded', function () {
      initChart();
      syncUI();

      // Inputs numéricos
      ['inp-bruto', 'inp-dependentes', 'inp-deducoes'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input',  function () { debounce(function() { atualizar(); }); });
        el.addEventListener('change', atualizar);
        el.addEventListener('blur',   atualizar);
      });

      // Select regime
      document.getElementById('sel-regime').addEventListener('change', function () {
        syncUI();
        atualizar();
      });

      // Select RAT
      document.getElementById('sel-rat').addEventListener('change', atualizar);

      // Toggle tipo sócio
      document.getElementById('btn-admin').addEventListener('click', function () {
        tipoSocio = 'admin';
        document.getElementById('btn-admin').classList.add('active');
        document.getElementById('btn-nao-admin').classList.remove('active');
        syncUI();
        atualizar();
      });
      document.getElementById('btn-nao-admin').addEventListener('click', function () {
        tipoSocio = 'nao-admin';
        document.getElementById('btn-nao-admin').classList.add('active');
        document.getElementById('btn-admin').classList.remove('active');
        syncUI();
        atualizar();
      });

      // Toggle INSS facultativo (não-admin)
      document.getElementById('btn-inss-sim').addEventListener('click', function () {
        recolherINSS = true;
        document.getElementById('btn-inss-sim').classList.add('active');
        document.getElementById('btn-inss-nao').classList.remove('active');
        atualizar();
      });
      document.getElementById('btn-inss-nao').addEventListener('click', function () {
        recolherINSS = false;
        document.getElementById('btn-inss-nao').classList.add('active');
        document.getElementById('btn-inss-sim').classList.remove('active');
        atualizar();
      });

      // Toggle IRPF na fonte
      document.getElementById('btn-ir-sim').addEventListener('click', function () {
        reterIR = true;
        document.getElementById('btn-ir-sim').classList.add('active');
        document.getElementById('btn-ir-nao').classList.remove('active');
        syncUI();
        atualizar();
      });
      document.getElementById('btn-ir-nao').addEventListener('click', function () {
        reterIR = false;
        document.getElementById('btn-ir-nao').classList.add('active');
        document.getElementById('btn-ir-sim').classList.remove('active');
        syncUI();
        atualizar();
      });
    });

  }());
  </script>

  <style is:global>

    /* ===== BREADCRUMB + TÍTULO ===== */
    .calc-breadcrumb ol {
      list-style: none;
      padding: 0; margin: 0 0 10px;
      display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
      font-size: 13px;
    }
    .calc-breadcrumb li { display: flex; align-items: center; gap: 6px; margin: 0; margin-left: 0 !important; }
    .calc-breadcrumb a { color: #16a34a; text-decoration: none; }
    .calc-breadcrumb a:hover { text-decoration: underline; }
    .calc-breadcrumb span { color: #9ca3af; }
    .calc-breadcrumb span.current { color: #374151; font-weight: 500; }
    .calc-page-title {
      font-size: 1.875rem !important;
      font-weight: 800;
      color: #111827;
      line-height: 1.2;
      margin: 0 0 8px !important;
    }
    .calc-page-desc {
      font-size: 1rem;
      color: #6b7280;
      margin: 0 0 36px;
    }

    /* ===== MAIN ===== */
    .calc-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 28px 24px 56px;
    }

    /* ===== TOOL: 2 COLUNAS ===== */
    .calc-tool {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 16px;
      margin-bottom: 40px;
    }
    @media (max-width: 860px) {
      .calc-tool { grid-template-columns: 1fr; }
    }

    /* ===== FORM PANEL ===== */
    .calc-form-panel {
      background: #f9fafb;
      padding: 20px 22px;
      border-radius: 0;
      border: 1px solid #e5e7eb;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .calc-form-title {
      font-size: 1rem;
      font-weight: 800;
      color: #111827;
      margin: 0 0 4px;
    }

    /* Fields */
    .calc-field { display: flex; flex-direction: column; gap: 6px; }
    .calc-label {
      font-size: 13px;
      color: #374151;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* Tooltip */
    .tip-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
    }
    .tip-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 15px;
      height: 15px;
      border-radius: 50%;
      border: 1.5px solid #9ca3af;
      background: transparent;
      color: #9ca3af;
      font-size: 9px;
      font-weight: 700;
      font-style: normal;
      line-height: 1;
      cursor: default;
      user-select: none;
      flex-shrink: 0;
      transition: border-color 0.15s, color 0.15s;
    }
    .tip-wrap:hover .tip-icon { border-color: #16a34a; color: #16a34a; }
    .tip-box {
      position: absolute;
      left: 50%;
      bottom: calc(100% + 8px);
      transform: translateX(-50%);
      width: 220px;
      background: #0d4a28;
      color: #fff;
      font-size: 12px;
      font-weight: 400;
      line-height: 1.5;
      padding: 9px 12px;
      border-radius: 6px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.18);
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.15s, visibility 0.15s;
      z-index: 50;
      white-space: normal;
      text-align: left;
    }
    .tip-box::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: #0d4a28;
    }
    .tip-wrap:hover .tip-box,
    .tip-wrap:focus-within .tip-box { opacity: 1; visibility: visible; }
    .calc-field:first-child .tip-box,
    .calc-field:nth-child(2) .tip-box {
      top: calc(100% + 8px);
      bottom: auto;
    }
    .calc-field:first-child .tip-box::after,
    .calc-field:nth-child(2) .tip-box::after {
      top: auto;
      bottom: 100%;
      border-top-color: transparent;
      border-bottom-color: #0d4a28;
    }

    /* Inputs */
    .calc-input-wrap {
      display: flex;
      align-items: center;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 4px;
      overflow: visible;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .calc-input-wrap:focus-within {
      border-color: #16a34a;
      box-shadow: 0 0 0 3px rgba(22,163,74,0.12);
    }
    .calc-unit {
      padding: 0 12px;
      font-size: 14px;
      color: #6b7280;
      background: #f9fafb;
      height: 42px;
      display: flex;
      align-items: center;
      white-space: nowrap;
      border-right: 1px solid #e5e7eb;
      flex-shrink: 0;
    }
    .calc-input {
      flex: 1;
      border: none;
      outline: none;
      background: transparent;
      padding: 0 12px;
      height: 42px;
      font-size: 15px;
      font-weight: 400;
      color: #374151;
      font-family: Arial, sans-serif;
      min-width: 0;
    }

    /* Select */
    .calc-select-wrap {
      position: relative;
      background: #fff;
      border: 1px solid #d1d5db;
      border-radius: 4px;
      transition: border-color 0.15s;
    }
    .calc-select-wrap:focus-within {
      border-color: #16a34a;
      box-shadow: 0 0 0 3px rgba(22,163,74,0.12);
    }
    .calc-select {
      width: 100%;
      border: none;
      outline: none;
      appearance: none;
      -webkit-appearance: none;
      background: transparent;
      padding: 0 36px 0 12px;
      height: 42px;
      font-size: 15px;
      font-weight: 400;
      color: #374151;
      font-family: Arial, sans-serif;
      cursor: pointer;
    }
    .calc-select-arrow {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 10px;
      color: #6b7280;
      pointer-events: none;
    }

    /* Toggle buttons */
    .calc-toggle-group { display: flex; }
    .calc-toggle {
      flex: 1;
      height: 42px;
      border: 1px solid #d1d5db;
      background: #fff;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      font-family: Arial, sans-serif;
    }
    .calc-toggle:first-child { border-radius: 4px 0 0 4px; border-right: none; }
    .calc-toggle:last-child  { border-radius: 0 4px 4px 0; }
    .calc-toggle.active { background: #0d4a28; color: #fff; border-color: #0d4a28; }
    .calc-toggle:not(.active):hover { background: #f3f4f6; }

    /* Resumo rápido no form */
    .calc-summary-box {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 4px;
    }
    .calc-summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
    }
    .calc-summary-row.total { font-weight: 700; }
    .calc-summary-label { color: #6b7280; }
    .calc-summary-val { font-variant-numeric: tabular-nums; font-weight: 600; color: #374151; }
    .calc-summary-val.red { color: #dc2626; }
    .calc-summary-divider { height: 1px; background: #f3f4f6; margin: 4px 0; }
    .calc-disclaimer {
      font-size: 11px;
      color: #9ca3af;
      margin: 0;
      line-height: 1.5;
    }
    .calc-isencao-notice {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 3px solid #16a34a;
      border-radius: 4px;
      padding: 9px 12px;
      font-size: 12px;
      color: #166534;
      line-height: 1.5;
    }
    .calc-isencao-notice--redutor {
      background: #fefce8;
      border-color: #fde68a;
      border-left-color: #eab308;
      color: #854d0e;
    }

    /* ===== CHART PANEL ===== */
    .calc-chart-panel {
      padding: 20px 24px 16px;
      display: flex;
      flex-direction: column;
      gap: 0;
      height: 100%;
      box-sizing: border-box;
      background: #fff;
      border-radius: 0;
      border: 1px solid #e5e7eb;
    }
    .calc-chart-header { text-align: center; margin-bottom: 12px; }
    .calc-chart-label { font-size: 16px; color: #6b7280; margin: 0 0 2px; font-weight: 500; }
