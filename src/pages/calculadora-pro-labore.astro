    /* ===== ARTICLE CONTENT ===== */
    .calc-article h2 {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
      margin: 40px 0 12px;
      line-height: 1.3;
    }
    .calc-article h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #111827;
