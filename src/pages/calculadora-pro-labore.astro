      .calc-page-desc { font-size: 14px; margin: 0 0 16px; }
      .calc-form-panel { padding: 16px; gap: 12px; }
      .calc-form-title { font-size: 14px; }
      .calc-label { font-size: 13px; }
      .calc-input { font-size: 15px; height: 40px; }
      .calc-unit { height: 40px; padding: 0 10px; font-size: 13px; }
      .calc-toggle { height: 40px; font-size: 12px; }
      .tip-box {
        left: auto !important;
        right: -8px !important;
        transform: none !important;
        width: 180px;
        font-size: 11px;
      }
      .tip-box::after {
        left: auto !important;
        right: 14px !important;
        transform: none !important;
      }
      .calc-field:first-child .tip-box,
      .calc-field:nth-child(2) .tip-box {
        left: auto !important;
        right: -8px !important;
        transform: none !important;
      }
      .calc-field:first-child .tip-box::after,
      .calc-field:nth-child(2) .tip-box::after {
        right: 14px !important;
        left: auto !important;
        transform: none !important;
      }
      .calc-summary-box { padding: 12px 14px; }
      .calc-summary-row { font-size: 12px; }
      .calc-disclaimer { font-size: 10px; }
      .calc-chart-panel { height: auto; padding: 16px; }
      .calc-chart-total { font-size: 28px; }
      .calc-chart-sub { font-size: 12px; }
      .calc-chart-label { font-size: 13px; }
      .calc-chart-area { flex: none; height: 230px; min-height: 230px; }
      .calc-chart-legend { gap: 6px 12px; font-size: 11px; flex-wrap: wrap; margin-top: 8px; }
      .calc-chart-area canvas { max-width: 100% !important; }
      .calc-table-section { padding: 16px 12px; border-radius: 8px; margin-bottom: 20px; }
      .calc-section-title { font-size: 15px; margin: 0 0 14px; }
      .calc-table th { padding: 8px 10px; font-size: 11px; }
      .calc-table td { padding: 9px 10px; font-size: 13px; }
      .calc-formula-block { padding: 12px 14px; overflow-x: auto; }
      .calc-formula-block code { font-size: 13px; }
      .calc-article h2 { font-size: 20px; margin: 28px 0 10px; }
      .calc-article h3 { font-size: 17px; }
      .calc-article p, .calc-article li { font-size: 15px; line-height: 1.65; }
    }
  </style>

</body>
