                    <div class="cbox-cta-caption">no site contabilidade.com</div>
                </div>
            </div>

            <!-- Dados principais -->
            <div class="cbox-data-row">
                <div class="cbox-cell">
                    <div class="cbox-cell-label">Preço mensal</div>
                    <div class="cbox-cell-value">R$ 189<span class="cbox-cell-unit">/mês</span></div>
                    <div class="cbox-cell-sub">Plano Essencial</div>
                </div>
                <div class="cbox-cell">
                    <div class="cbox-cell-label">Abertura de empresa</div>
