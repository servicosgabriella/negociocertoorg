---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout 
  title="Negócio Certo" 
  description="Decisões inteligentes para o seu negócio">
  <!-- HERO -->
  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">
          Decisões inteligentes<br />
          para o seu negócio<br />
          com o <span class="hero-highlight">negóciocerto.</span>
        </h1>
        <p class="hero-subtitle">Nossos especialistas dedicam horas pesquisando, testando e avaliando ferramentas — para que você não precise fazer isso.</p>
        <form class="hero-search" action="/busca" method="get" role="search">
          <input class="hero-search-input" type="search" name="q" placeholder="Buscar maquininhas, contabilidade, ERP..." aria-label="Buscar" />
          <button class="hero-search-btn" type="submit" aria-label="Buscar">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CARDS DE CATEGORIAS -->
  <section class="categories-section">
    <div class="categories-wrapper">
      <div class="categories-grid">

        <a href="/financas/maquininhas-de-cartao/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/><line x1="6" y1="15" x2="10" y2="15"/>
            </svg>
          </span>
          <h3 class="cat-title">Maquininhas de Cartão</h3>
          <p class="cat-desc">Compare as melhores maquininhas para o seu negócio.</p>
        </a>

        <a href="/financas/erp-sistema-gestao/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17h7M17 14v7"/>
            </svg>
          </span>
          <h3 class="cat-title">ERP / Sistema de Gestão</h3>
          <p class="cat-desc">Encontre o sistema ideal para organizar seu negócio.</p>
        </a>

        <a href="/financas/contabilidade-online/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><line x1="8" y1="9" x2="10" y2="9"/>
            </svg>
          </span>
          <h3 class="cat-title">Contabilidade Online</h3>
          <p class="cat-desc">Contabilidade acessível para MEI e empresas.</p>
        </a>

        <a href="/gestao/sistema-pdv/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </span>
          <h3 class="cat-title">Sistema PDV</h3>
          <p class="cat-desc">Gerencie vendas, estoque e caixa com facilidade.</p>
        </a>

        <a href="/gestao/nota-fiscal-eletronica/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
            </svg>
          </span>
          <h3 class="cat-title">Nota Fiscal Eletrônica</h3>
          <p class="cat-desc">Emita NF-e de forma simples e sem complicação.</p>
        </a>

        <a href="/calculadoras/financeiras/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="10" y2="10"/><line x1="14" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="14" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="10" y2="18"/><line x1="14" y1="18" x2="16" y2="18"/>
            </svg>
          </span>
          <h3 class="cat-title">Calculadoras Financeiras</h3>
          <p class="cat-desc">Simule juros, investimentos e rentabilidade.</p>
        </a>

        <a href="/calculadoras/trabalhistas/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </span>
          <h3 class="cat-title">Calculadoras Trabalhistas</h3>
          <p class="cat-desc">Calcule salário líquido, FGTS, férias e rescisão.</p>
        </a>

        <a href="/planejamento/plano-de-negocios/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </span>
          <h3 class="cat-title">Plano de Negócios</h3>
          <p class="cat-desc">Crie um plano sólido para tirar sua ideia do papel.</p>
        </a>

        <a href="/planejamento/registro-de-marca/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </span>
          <h3 class="cat-title">Registro de Marca</h3>
          <p class="cat-desc">Proteja sua marca e garanta exclusividade no mercado.</p>
        </a>

        <a href="/rh/folha-de-pagamento-online/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </span>
          <h3 class="cat-title">Folha de Pagamento</h3>
          <p class="cat-desc">Automatize o pagamento de funcionários com praticidade.</p>
        </a>

      </div>
    </div>
  </section>

  <style>
    /* ======= HERO ======= */
    .hero-section {
      background: #2d6a4f;
      overflow: hidden;
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 32px 80px;
    }
    @media (max-width: 768px) {
      .hero-inner {
        padding: 40px 20px 64px;
      }
    }

    .hero-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      color: #ffffff;
      margin: 0 0 20px;
      letter-spacing: -0.5px;
    }
    .hero-highlight {
      color: #84c341;
    }
    .hero-subtitle {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 17px;
      line-height: 1.6;
      color: rgba(255,255,255,0.80);
      margin: 0 0 32px;
      max-width: 520px;
    }

    /* Search */
    .hero-search {
      display: flex;
      align-items: center;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      max-width: 540px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    }
    .hero-search-input {
      flex: 1;
      border: none;
      outline: none;
      padding: 16px 20px;
      font-family: 'Nunito Sans', sans-serif;
      font-size: 15px;
      color: #111;
      background: transparent;
    }
    .hero-search-input::placeholder { color: #9ca3af; }
    .hero-search-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      background: none;
      border: none;
      cursor: pointer;
      color: #374151;
      transition: color 0.15s;
      flex-shrink: 0;
    }
    .hero-search-btn:hover { color: #0d3b22; }

    /* ======= CATEGORIES ======= */
    .categories-section {
      background: #ffffff;
      padding: 0 24px;
    }

    .categories-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      background: #eaf7ef;
      border-radius: 20px;
      padding: 24px;
      transform: translateY(-48px);
      margin-bottom: -48px;
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }

    @media (max-width: 1024px) {
      .categories-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 600px) {
      .categories-grid { grid-template-columns: repeat(2, 1fr); }
      .categories-wrapper { padding: 16px; transform: translateY(-28px); }
    }

    .cat-card {
      position: relative;
      background: #ffffff;
      border: 1px solid #e2ede8;
      border-radius: 16px;
      padding: 36px 20px 32px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
      min-height: 260px;
    }

    .cat-arrow {
      position: absolute;
      top: 16px;
      right: 18px;
      font-size: 16px;
      color: #b0bec5;
      font-style: normal;
    }

    .cat-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 72px;
      height: 72px;
      margin-bottom: 8px;
      color: #2d6a4f;
      flex-shrink: 0;
    }
    .cat-icon svg {
      width: 72px;
      height: 72px;
    }
    .cat-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: #0f172a;
      margin: 0;
      line-height: 1.25;
    }
    .cat-desc {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: #6b7280;
      margin: 0;
      line-height: 1.55;
    }
  </style>

  <section class="bg-slate-100 py-16">
    <div style="max-width: 1100px; margin: 0 auto; padding-left: 34px; padding-right: 34px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 items-start" style="gap: 37px;">
        <div class="max-w-2xl">
          <h2 style="font-weight: 700; color: rgb(25, 45, 75); font-size: 38px; line-height: 46px;">Avaliações Populares</h2>
          <p style="font-style: normal; font-weight: 600; color: #314a6f; font-size: 22px; line-height: 26px; margin-top: 12px;">Compare planos e preços dos melhores serviços para o seu negócio</p>
        </div>

        <div class="w-full max-w-2xl space-y-3">
          <p style="font-style: normal; font-weight: 400; color: rgb(100, 100, 100); font-size: 16px; line-height: 24px;">Confira nossa pesquisa sobre os melhores serviços e produtos em cada categoria.</p>
          <p style="font-style: normal; font-weight: 400; color: rgb(100, 100, 100); font-size: 16px; line-height: 24px;">Essas são as avaliações mais populares em nosso site, <strong>atualizadas mensalmente</strong>.</p>
        </div>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href="/melhores-contabilidades-online/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/icon-contabilidade-com.webp" alt="Contabilidade.com" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-colinear.webp" alt="Colinear" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-agilize-contabilidade.webp" alt="Agilize" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-contaja-contabilidade.webp" alt="Contajá" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Melhores Contabilidades Online em 2026
            </h3>
          </div>
        </a>

        <a href="/melhores-maquininhas-cartao-voucher-refeicao/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/icon-stone-.webp" alt="Stone" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-mercado-pago.webp" alt="Mercado Pago" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/sumup-icon.webp" alt="SumUp" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-pagbank-.webp" alt="PagBank" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Maquininhas que aceita VR e VA (Atualizado 2026)
            </h3>
          </div>
        </a>

        <a href="/melhores-sistemas-pdv/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/egestor-erp.webp" alt="eGestor" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-bling-erp-.webp" alt="Bling" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-soften-erp.webp" alt="Soften" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-omie.webp" alt="Omie" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Melhores Sistemas de PDV em 2026
            </h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section style="background: #eef3fb; border-top: 1px solid #dbe7f5; padding: 8px 24px;">
    <div style="max-width: 900px; margin: 0 auto; display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: 24px;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 42px; line-height: 63px; font-weight: 700; color: #0f2b5b;">50+</span>
        <span style="font-size: 18px; line-height: 22px; font-weight: 500; color: #374151;">Produtos<br/>Avaliados</span>
      </div>
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 42px; line-height: 63px; font-weight: 700; color: #0f2b5b;">2 MIL</span>
        <span style="font-size: 18px; line-height: 22px; font-weight: 500; color: #374151;">Horas de<br/>Pesquisa</span>
      </div>
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 42px; line-height: 63px; font-weight: 700; color: #0f2b5b;">5 MIL</span>
        <span style="font-size: 18px; line-height: 22px; font-weight: 500; color: #374151;">Leitores<br/>Mensais</span>
      </div>
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 42px; line-height: 63px; font-weight: 700; color: #0f2b5b;">+10</span>
        <span style="font-size: 18px; line-height: 22px; font-weight: 500; color: #374151;">Anos de<br/>Experiência</span>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div style="max-width: 1100px; margin: 0 auto; padding-left: 34px; padding-right: 34px;">
      <div class="flex items-end justify-between gap-4 mb-8">
        <h2 class="!text-[28px] !leading-tight font-bold text-slate-800">Posts recentes do blog</h2>
        <a href="/blog" class="text-sm font-semibold text-yellow-400 hover:text-yellow-400">Ver todos</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
      recentPosts.map((post) => (
        <a href={`/blog/${post.id}/`} class="group block rounded-2xl border border-slate-200 bg-white overflow-hidden hover:border-slate-300 transition-colors duration-200">
          {post.data.heroImage && (
            <Image src={post.data.heroImage} alt={post.data.title} width={720} height={360} class="w-full h-44 object-cover rounded-none" />
          )}
          <div class="p-5">
            <p class="text-xs text-slate-500 mb-2">
              <FormattedDate date={post.data.pubDate} />
            </p>
            <h3 class="font-semibold !text-[20px] leading-snug text-slate-800 group-hover:text-slate-900 transition-colors duration-200">
              {post.data.title}
            </h3>
            <p class="mt-3 text-sm text-slate-500 line-clamp-3">{post.data.description}</p>
          </div>
        </a>
      ))
    }
      </div>
    </div>
  </section>
</Layout>
