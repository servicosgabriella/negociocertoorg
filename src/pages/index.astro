---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts.slice(0, 6);

const searchData = allPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description ?? '',
  coverImage: p.data.coverImage ?? '',
  coverAlt: p.data.coverAlt ?? p.data.title,
  category: p.data.category ?? '',
}));
---

<Layout 
  title="Negócio Certo" 
  description="Decisões inteligentes para o seu negócio">
  <!-- HERO -->
  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">
          Decisões inteligentes<br />
          para o seu negócio<br />
          com o <span class="hero-highlight">negóciocerto.</span>
        </h1>
        <p class="hero-subtitle">Nossos especialistas dedicam horas pesquisando, testando e avaliando ferramentas — para que você não precise fazer isso.</p>
        <div class="hero-search-wrap">
          <form class="hero-search" role="search" id="heroSearchForm" autocomplete="off">
            <input class="hero-search-input" type="search" id="heroSearchInput" placeholder="Buscar maquininhas, contabilidade, ERP..." aria-label="Buscar" aria-expanded="false" aria-controls="heroSearchDropdown" />
            <button class="hero-search-btn" type="submit" aria-label="Buscar">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" />
              </svg>
            </button>
          </form>
          <div class="search-dropdown" id="heroSearchDropdown" role="listbox" hidden></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CARDS DE CATEGORIAS -->
  <section class="categories-section">
    <div class="categories-wrapper">
      <div class="categories-grid">

        <a href="/melhores-maquininhas-cartao-voucher-refeicao" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-maquininha-cartao.png" alt="Maquininhas de Cartão" /></span>
          <h3 class="cat-title">Maquininhas de Cartão</h3>
          <p class="cat-desc">Compare as melhores maquininhas para o seu negócio.</p>
        </a>

        <a href="/financas/erp-sistema-gestao/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-erp-gestao.png" alt="ERP / Sistema de Gestão" /></span>
          <h3 class="cat-title">ERP / Sistema de Gestão</h3>
          <p class="cat-desc">Encontre o sistema ideal para organizar seu negócio.</p>
        </a>

        <a href="/melhores-contabilidades-online" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-documento-calculadora.png" alt="Contabilidade Online" /></span>
          <h3 class="cat-title">Contabilidade Online</h3>
          <p class="cat-desc">Contabilidade acessível para MEI e empresas.</p>
        </a>

        <a href="/melhores-sistemas-pdv" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-pdv-caixa.png" alt="Sistema PDV" /></span>
          <h3 class="cat-title">Sistema PDV</h3>
          <p class="cat-desc">Gerencie vendas, estoque e caixa com facilidade.</p>
        </a>

        <a href="/melhores-sistemas-nota-fiscal" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-nota-fiscal.png" alt="Nota Fiscal Eletrônica" /></span>
          <h3 class="cat-title">Nota Fiscal Eletrônica</h3>
          <p class="cat-desc">Emita NF-e de forma simples e sem complicação.</p>
        </a>

        <a href="/calculadora-salario-liquido" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-calculadora-moedas.png" alt="Calculadoras Financeiras" /></span>
          <h3 class="cat-title">Calculadoras Financeiras</h3>
          <p class="cat-desc">Simule juros, investimentos e rentabilidade.</p>
        </a>

        <a href="/rh/folha-de-pagamento-online/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-contrato-pagamento.png" alt="Folha de Pagamento" /></span>
          <h3 class="cat-title">Folha de Pagamento</h3>
          <p class="cat-desc">Automatize o pagamento de funcionários com praticidade.</p>
        </a>

        <a href="/como-fazer-um-plano-de-negocios-guia-completo-e-pratico-2026" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-crescimento-meta.png" alt="Plano de Negócios" /></span>
          <h3 class="cat-title">Plano de Negócios</h3>
          <p class="cat-desc">Crie um plano sólido para tirar sua ideia do papel.</p>
        </a>

        <a href="/como-registrar-uma-marca" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-marca-registrada.png" alt="Registro de Marca" /></span>
          <h3 class="cat-title">Registro de Marca</h3>
          <p class="cat-desc">Proteja sua marca e garanta exclusividade no mercado.</p>
        </a>

        <a href="/calculadoras/trabalhistas/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-contador-financeiro.png" alt="Calculadoras Trabalhistas" /></span>
          <h3 class="cat-title">Calculadoras Trabalhistas</h3>
          <p class="cat-desc">Calcule salário líquido, FGTS, férias e rescisão.</p>
        </a>

      </div>
    </div>
  </section>

  <style>
    /* ======= HERO ======= */
    .hero-section {
      background: linear-gradient(135deg, #0d4a28 0%, #1d6b3d 45%, #3aaa62 100%);
      overflow: hidden;
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 32px 80px;
    }
    @media (max-width: 768px) {
      .hero-inner {
        padding: 40px 20px 64px;
      }
    }

    .hero-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      color: #ffffff;
      margin: 0 0 20px;
      letter-spacing: -0.5px;
    }
    .hero-highlight {
      color: #ace347;
    }
    .hero-subtitle {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 17px;
      line-height: 1.6;
      color: rgba(255,255,255,0.80);
      margin: 0 0 32px;
      max-width: 520px;
    }

    /* Search */
    .hero-search {
      display: flex;
      align-items: center;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    }
    .hero-search-input {
      flex: 1;
      border: none;
      outline: none;
      padding: 16px 20px;
      font-family: 'Nunito Sans', sans-serif;
      font-size: 15px;
      color: #111;
      background: transparent;
    }
    .hero-search-input::placeholder { color: #9ca3af; }
    .hero-search-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      background: none;
      border: none;
      cursor: pointer;
      color: #374151;
      transition: color 0.15s;
      flex-shrink: 0;
    }
    .hero-search-btn:hover { color: #0d3b22; }

    /* Search dropdown */
    .hero-search-wrap {
      position: relative;
      max-width: 540px;
    }
    .hero-search {
      max-width: 100%;
    }
    .search-dropdown {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.16);
      overflow: hidden;
      z-index: 50;
      border: 1px solid rgba(0,0,0,0.07);
    }
    .search-dropdown[hidden] { display: none; }
    .sd-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 13px 18px;
      text-decoration: none;
      border-bottom: 1px solid #f3f4f6;
      transition: background 0.12s;
    }
    .sd-item:last-child { border-bottom: none; }
    .sd-item:hover { background: #f0faf4; }
    .sd-item:hover .sd-title { color: #2d6a4f; }
    .sd-icon {
      flex-shrink: 0;
      color: #9ca3af;
      display: flex;
      align-items: center;
    }
    .sd-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: #111827;
      line-height: 1.4;
      transition: color 0.12s;
    }
    .sd-empty {
      padding: 22px 18px;
      font-family: 'Nunito Sans', sans-serif;
      font-size: 14px;
      color: #9ca3af;
      text-align: center;
    }

    /* ======= CATEGORIES ======= */
    .categories-section {
      background: #ffffff;
      padding: 0 24px;
    }

    .categories-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      background: #eaf7ef;
      border-radius: 20px;
      padding: 24px;
      transform: translateY(-48px);
      margin-bottom: -48px;
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }

    @media (max-width: 1024px) {
      .categories-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 600px) {
      .categories-grid { grid-template-columns: repeat(2, 1fr); }
      .categories-wrapper { padding: 16px; transform: translateY(-28px); }
    }

    .cat-card {
      position: relative;
      background: #ffffff;
      border: 1px solid transparent;
      border-radius: 16px;
      padding: 24px 16px 20px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
      transition: border-color 0.2s;
    }
    .cat-card:hover {
      border-color: #b0ccc0;
    }

    .cat-arrow {
      position: absolute;
      top: 16px;
      right: 18px;
      font-size: 16px;
      color: #b0bec5;
      font-style: normal;
      transition: transform 0.2s ease, color 0.2s;
    }
    .cat-card:hover .cat-arrow {
      transform: translate(3px, -3px);
      color: #2d6a4f;
    }
    .cat-card:hover .cat-title {
      color: #2d6a4f;
    }

    .cat-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 90px;
      height: 90px;
      flex-shrink: 0;
    }
    .cat-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .cat-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: #0f172a;
      margin: 0;
      line-height: 1.25;
      transition: color 0.2s;
    }
    .cat-desc {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: #6b7280;
      margin: 0;
      line-height: 1.5;
    }
  </style>


  <!-- SEÇÃO DE CONFIANÇA -->
  <section class="trust-section">
    <div class="trust-inner">

      <!-- Esquerda: foto -->
      <div class="trust-photo-wrap">
        <img src="/images/nnegociocerto.png" alt="Especialista NegócioCerto" class="trust-photo" />
      </div>

      <!-- Direita: conteúdo -->
      <div class="trust-right">

        <h2 class="trust-title">Por que empreendedores confiam no NegócioCerto?</h2>

        <!-- Stats horizontais -->
        <div class="trust-stats">
          <div class="trust-stat">
            <span class="trust-stat-number">50<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">produtos avaliados com critérios rigorosos</span>
          </div>
          <div class="trust-stat">
            <span class="trust-stat-number">2.000<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">horas de pesquisa e testes realizados</span>
          </div>
          <div class="trust-stat">
            <span class="trust-stat-number">10<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">anos acompanhando o mercado empreendedor</span>
          </div>
        </div>

        <!-- Logos com scroll -->
        <div class="trust-logos-wrap">
          <p class="trust-logos-label">PRODUTOS QUE JÁ AVALIAMOS E TESTAMOS</p>
          <div class="trust-logos-track-outer">
            <div class="trust-logos-track">
              <img src="/images/logo-pagbank.png" alt="PagBank" />
              <img src="/images/logo-mercado-pago.png" alt="Mercado Pago" />
              <img src="/images/logo-sumup.png" alt="SumUp" />
              <img src="/images/logo-ton.webp" alt="Ton" />
              <img src="/images/logo-contabilidade-com.png" alt="Contabilidade.com" />
              <img src="/images/contabilizei-logo.png" alt="Contabilizei" />
              <img src="/images/agilize-contabilidade-online-logo.png" alt="Agilize" />
              <img src="/images/colinear-logo.png" alt="Colinear" />
              <!-- duplicados para loop contínuo -->
              <img src="/images/logo-pagbank.png" alt="PagBank" aria-hidden="true" />
              <img src="/images/logo-mercado-pago.png" alt="Mercado Pago" aria-hidden="true" />
              <img src="/images/logo-sumup.png" alt="SumUp" aria-hidden="true" />
              <img src="/images/logo-ton.webp" alt="Ton" aria-hidden="true" />
              <img src="/images/logo-contabilidade-com.png" alt="Contabilidade.com" aria-hidden="true" />
              <img src="/images/contabilizei-logo.png" alt="Contabilizei" aria-hidden="true" />
              <img src="/images/agilize-contabilidade-online-logo.png" alt="Agilize" aria-hidden="true" />
              <img src="/images/colinear-logo.png" alt="Colinear" aria-hidden="true" />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style>
    /* ======= TRUST SECTION ======= */
    .trust-section {
      background: #ffffff;
      padding: 64px 32px;
      border-top: 1px solid #f0f0f0;
      overflow: hidden;
    }
    .trust-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 360px minmax(0, 1fr);
      gap: 56px;
      align-items: center;
    }
    @media (max-width: 900px) {
      .trust-inner { grid-template-columns: 1fr; gap: 32px; }
      .trust-photo-wrap { display: none; }
      .trust-section { padding: 48px 20px; }
    }

    /* Foto */
    .trust-photo-wrap {
      flex-shrink: 0;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      transform: translateY(-25px);
    }
    .trust-photo {
      width: 100%;
      height: auto;
      display: block;
    }

    /* Direita */
    .trust-right {
      min-width: 0;
    }

    /* Título */
    .trust-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(22px, 2.4vw, 34px);
      font-weight: 600;
      color: #111111;
      line-height: 1.1;
      margin: 0 0 36px;
      word-break: break-word;
      letter-spacing: -0.3px;
    }

    /* Stats */
    .trust-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 36px;
    }
    @media (max-width: 500px) {
      .trust-stats { grid-template-columns: 1fr; }
    }
    .trust-stat { display: flex; flex-direction: column; gap: 8px; min-width: 0; }
    .trust-stat-number {
      font-family: 'Inter', sans-serif;
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 700;
      color: #2d6a4f;
      line-height: 1;
    }
    .trust-stat-plus {
      color: #84c341;
    }
    .trust-stat-label {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 15px;
      color: #374151;
      font-weight: 400;
      line-height: 1.45;
    }

    /* Logos com scroll */
    .trust-logos-wrap {
      padding-top: 24px;
    }
    .trust-logos-label {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      color: #9ca3af;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin: 0 0 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      white-space: nowrap;
    }
    .trust-logos-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e5e7eb;
    }
    .trust-logos-track-outer {
      overflow: hidden;
      width: 100%;
      mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    }
    .trust-logos-track {
      display: flex;
      align-items: center;
      gap: 48px;
      width: max-content;
      animation: logos-scroll 22s linear infinite;
    }
    .trust-logos-track:hover { animation-play-state: paused; }
    .trust-logos-track img {
      height: 26px;
      width: auto;
      object-fit: contain;
      filter: grayscale(100%);
      opacity: 0.5;
      flex-shrink: 0;
    }

    @keyframes logos-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <!-- BLOG CAROUSEL -->
  <section class="blog-section">
    <div class="blog-section-header">
      <h2 class="blog-section-title">Posts recentes do blog</h2>
      <a href="/blog" class="blog-section-link">VER TODOS OS POSTS →</a>
    </div>

    <div class="blog-carousel-viewport" id="blogViewport">
      <div class="blog-carousel-track" id="blogTrack">
        {([...recentPosts, ...recentPosts, ...recentPosts]).map((post, i) => {
          const midStart = recentPosts.length;
          const isActive = i === midStart + 1;
          return (
            <div class={`blog-slide${isActive ? ' active' : ''}`} data-index={String(i)}>
              <a href={`/blog/${post.id}/`} class="blog-card">
                <div class="blog-card-inner">
                  {post.data.coverImage ? (
                    <img src={post.data.coverImage} alt={post.data.title} width={900} height={506} class="blog-card-img" loading="lazy" />
                  ) : (
                    <div class="blog-card-no-img"></div>
                  )}
                  <div class="blog-card-overlay">
                    <span class="blog-card-date"><FormattedDate date={post.data.pubDate} /></span>
                    <h3 class="blog-card-title">{post.data.title}</h3>
                  </div>
                </div>
              </a>
            </div>
          );
        })}
      </div>
    </div>

    <div class="blog-controls">
      <button class="blog-nav" id="blogPrev" aria-label="Anterior">&#8249;</button>
      <div class="blog-dots" id="blogDots">
        {recentPosts.map((_, i) => (
          <button class={`blog-dot${i === 1 ? ' active' : ''}`} data-index={String(i)} aria-label={`Post ${i + 1}`}></button>
        ))}
      </div>
      <button class="blog-nav" id="blogNext" aria-label="Próximo">&#8250;</button>
    </div>
  </section>

  <style>
    /* ======= BLOG CAROUSEL ======= */
    .blog-section {
      background: #fff;
      padding: 64px 0 56px;
      border-top: 1px solid #f0f0f0;
    }
    .blog-section-header {
      text-align: center;
      padding: 0 24px;
      margin-bottom: 36px;
    }
    .blog-section-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(22px, 2.4vw, 32px);
      font-weight: 700;
      color: #111;
      margin: 0 0 12px;
      letter-spacing: -0.3px;
    }
    .blog-section-link {
      display: inline-block;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: #2d6a4f;
      text-decoration: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-bottom: 1.5px solid #2d6a4f;
      padding-bottom: 2px;
    }
    .blog-section-link:hover { opacity: 0.75; }

    .blog-carousel-viewport {
      overflow: hidden;
      width: 100%;
    }
    .blog-carousel-track {
      display: flex;
      align-items: center;
      gap: 16px;
      transition: transform 0.6s ease;
      will-change: transform;
    }
    .blog-slide {
      flex: 0 0 auto;
      opacity: 0.45;
      transition: opacity 0.6s ease, width 0.6s ease;
    }
    .blog-slide.active {
      opacity: 1;
    }

    .blog-card {
      display: block;
      text-decoration: none;
    }
    .blog-card-inner {
      position: relative;
      height: clamp(220px, 28vw, 420px);
      width: 100%;
      overflow: hidden;
      border-radius: 20px;
    }
    .blog-card-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .blog-card-no-img {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #2d6a4f 0%, #1a3a2a 100%);
    }
    .blog-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 28px 32px;
    }
    .blog-card-date {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      color: rgba(255,255,255,0.80);
      margin-bottom: 8px;
      display: block;
      text-align: right;
    }
    .blog-card-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(16px, 1.8vw, 22px);
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      margin: 0;
    }
    .blog-slide:not(.active) .blog-card-title {
      font-size: clamp(12px, 1.2vw, 16px);
    }
    .blog-slide:not(.active) .blog-card-date {
      font-size: 11px;
    }

    /* Controls */
    .blog-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 28px;
      padding: 0 24px;
    }
    .blog-nav {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1.5px solid #d1d5db;
      background: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: #374151;
      line-height: 1;
      padding: 0;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .blog-nav:hover { border-color: #2d6a4f; color: #2d6a4f; }
    .blog-dots {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .blog-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 1.5px solid #9ca3af;
      background: transparent;
      cursor: pointer;
      padding: 0;
      transition: background 0.2s, border-color 0.2s;
    }
    .blog-dot.active {
      background: #2d6a4f;
      border-color: #2d6a4f;
    }
  </style>

  <script define:vars={{ searchData }}>
    (function () {
      const input = document.getElementById('heroSearchInput');
      const dropdown = document.getElementById('heroSearchDropdown');
      const form = document.getElementById('heroSearchForm');

      function normalize(str) {
        return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      }

      function search(q) {
        const nq = normalize(q.trim());
        if (nq.length < 2) return [];
        return searchData.filter(p => {
          const hay = normalize(p.title + ' ' + p.description + ' ' + p.category);
          return hay.includes(nq);
        });
      }

      const searchIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" /></svg>`;

      function render(results, q) {
        if (!q.trim() || q.trim().length < 2) {
          dropdown.hidden = true;
          return;
        }
        if (results.length === 0) {
          dropdown.hidden = false;
          dropdown.innerHTML = '<p class="sd-empty">Nenhum resultado encontrado.</p>';
          return;
        }
        dropdown.hidden = false;
        dropdown.innerHTML = results.map(p => `
          <a href="/blog/${p.id}/" class="sd-item">
            <span class="sd-icon">${searchIcon}</span>
            <span class="sd-title">${p.title}</span>
          </a>
        `).join('');
      }

      input.addEventListener('input', () => {
        render(search(input.value), input.value);
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const first = dropdown.querySelector('.sd-item');
        if (first) first.click();
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.hero-search-wrap')) {
          dropdown.hidden = true;
        }
      });

      input.addEventListener('focus', () => {
        if (input.value.trim().length >= 2) render(search(input.value), input.value);
      });
    })();
  </script>

  <script>
    (function () {
      const track = document.getElementById('blogTrack') as HTMLElement;
      const viewport = document.getElementById('blogViewport') as HTMLElement;
      const slides = document.querySelectorAll<HTMLElement>('.blog-slide');
      const dots = document.querySelectorAll<HTMLElement>('.blog-dot');
      const prevBtn = document.getElementById('blogPrev') as HTMLButtonElement;
      const nextBtn = document.getElementById('blogNext') as HTMLButtonElement;

      const realTotal = dots.length;          // 6 real posts
      const rendered  = slides.length;        // 18 (triplet)
      let current = realTotal + 1;            // start at middle set, post 1
      const GAP = 16;
      let autoTimer: ReturnType<typeof setInterval> | null = null;
      let teleporting = false;

      function getDims() {
        const vw = viewport.offsetWidth;
        const h = Math.min(Math.max(220, vw * 0.28), 420);
        return {
          activeW: Math.round(h * 16 / 9),
          sideW:   Math.round(h * 9 / 16),
        };
      }

      function goTo(index: number, animate = true) {
        current = index;
        const { activeW, sideW } = getDims();
        const vw = viewport.offsetWidth;

        slides.forEach((s, i) => {
          s.style.width = (i === current ? activeW : sideW) + 'px';
        });

        const translateX = vw / 2 - current * (sideW + GAP) - activeW / 2;

        if (!animate) {
          track.style.transition = 'none';
          slides.forEach(s => { s.style.transition = 'opacity 0.55s'; });
        }
        track.style.transform = `translateX(${translateX}px)`;
        if (!animate) {
          requestAnimationFrame(() => {
            track.style.transition = '';
            slides.forEach(s => { s.style.transition = ''; });
          });
        }

        slides.forEach((s, i) => s.classList.toggle('active', i === current));
        dots.forEach((d, i) => d.classList.toggle('active', i === (current % realTotal)));
      }

      // Infinite loop: teleport to middle set when hitting edges
      track.addEventListener('transitionend', (e: Event) => {
        const te = e as TransitionEvent;
        if (te.propertyName !== 'transform' || teleporting) return;
        if (current < realTotal) {
          teleporting = true;
          goTo(current + realTotal, false);
          requestAnimationFrame(() => { teleporting = false; });
        } else if (current >= realTotal * 2) {
          teleporting = true;
          goTo(current - realTotal, false);
          requestAnimationFrame(() => { teleporting = false; });
        }
      });

      function startAuto() {
        autoTimer = setInterval(() => goTo(current + 1), 4500);
      }
      function stopAuto() {
        if (autoTimer) clearInterval(autoTimer);
      }

      prevBtn.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
      nextBtn.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });
      dots.forEach((dot, i) => dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); }));

      // Pause on hover
      viewport.addEventListener('mouseenter', stopAuto);
      viewport.addEventListener('mouseleave', startAuto);

      // Touch swipe
      let touchStartX = 0;
      viewport.addEventListener('touchstart', (e) => { touchStartX = (e as TouchEvent).touches[0].clientX; stopAuto(); });
      viewport.addEventListener('touchend', (e) => {
        const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          goTo(diff > 0 ? current + 1 : current - 1);
        }
        startAuto();
      });

      goTo(realTotal + 1, false);
      startAuto();
      window.addEventListener('resize', () => goTo(current, false));
    })();
  </script>
</Layout>
