---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout 
  title="Negócio Certo" 
  description="Decisões inteligentes para o seu negócio">
  <!-- HERO -->
  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">
          Decisões inteligentes<br />
          para o seu negócio<br />
          com o <span class="hero-highlight">negóciocerto.</span>
        </h1>
        <p class="hero-subtitle">Nossos especialistas dedicam horas pesquisando, testando e avaliando ferramentas — para que você não precise fazer isso.</p>
        <form class="hero-search" action="/busca" method="get" role="search">
          <input class="hero-search-input" type="search" name="q" placeholder="Buscar maquininhas, contabilidade, ERP..." aria-label="Buscar" />
          <button class="hero-search-btn" type="submit" aria-label="Buscar">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CARDS DE CATEGORIAS -->
  <section class="categories-section">
    <div class="categories-wrapper">
      <div class="categories-grid">

        <a href="/financas/maquininhas-de-cartao/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-maquininha-cartao.png" alt="Maquininhas de Cartão" /></span>
          <h3 class="cat-title">Maquininhas de Cartão</h3>
          <p class="cat-desc">Compare as melhores maquininhas para o seu negócio.</p>
        </a>

        <a href="/financas/erp-sistema-gestao/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-erp-gestao.png" alt="ERP / Sistema de Gestão" /></span>
          <h3 class="cat-title">ERP / Sistema de Gestão</h3>
          <p class="cat-desc">Encontre o sistema ideal para organizar seu negócio.</p>
        </a>

        <a href="/financas/contabilidade-online/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-documento-calculadora.png" alt="Contabilidade Online" /></span>
          <h3 class="cat-title">Contabilidade Online</h3>
          <p class="cat-desc">Contabilidade acessível para MEI e empresas.</p>
        </a>

        <a href="/gestao/sistema-pdv/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-pdv-caixa.png" alt="Sistema PDV" /></span>
          <h3 class="cat-title">Sistema PDV</h3>
          <p class="cat-desc">Gerencie vendas, estoque e caixa com facilidade.</p>
        </a>

        <a href="/gestao/nota-fiscal-eletronica/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-nota-fiscal.png" alt="Nota Fiscal Eletrônica" /></span>
          <h3 class="cat-title">Nota Fiscal Eletrônica</h3>
          <p class="cat-desc">Emita NF-e de forma simples e sem complicação.</p>
        </a>

        <a href="/calculadoras/financeiras/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-calculadora-moedas.png" alt="Calculadoras Financeiras" /></span>
          <h3 class="cat-title">Calculadoras Financeiras</h3>
          <p class="cat-desc">Simule juros, investimentos e rentabilidade.</p>
        </a>

        <a href="/rh/folha-de-pagamento-online/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-contrato-pagamento.png" alt="Folha de Pagamento" /></span>
          <h3 class="cat-title">Folha de Pagamento</h3>
          <p class="cat-desc">Automatize o pagamento de funcionários com praticidade.</p>
        </a>

        <a href="/planejamento/plano-de-negocios/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-crescimento-meta.png" alt="Plano de Negócios" /></span>
          <h3 class="cat-title">Plano de Negócios</h3>
          <p class="cat-desc">Crie um plano sólido para tirar sua ideia do papel.</p>
        </a>

        <a href="/planejamento/registro-de-marca/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-marca-registrada.png" alt="Registro de Marca" /></span>
          <h3 class="cat-title">Registro de Marca</h3>
          <p class="cat-desc">Proteja sua marca e garanta exclusividade no mercado.</p>
        </a>

        <a href="/calculadoras/trabalhistas/" class="cat-card">
          <span class="cat-arrow">↗</span>
          <span class="cat-icon"><img src="/images/icones/icon-contador-financeiro.png" alt="Calculadoras Trabalhistas" /></span>
          <h3 class="cat-title">Calculadoras Trabalhistas</h3>
          <p class="cat-desc">Calcule salário líquido, FGTS, férias e rescisão.</p>
        </a>

      </div>
    </div>
  </section>

  <style>
    /* ======= HERO ======= */
    .hero-section {
      background: #2d6a4f;
      overflow: hidden;
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 32px 80px;
    }
    @media (max-width: 768px) {
      .hero-inner {
        padding: 40px 20px 64px;
      }
    }

    .hero-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 800;
      line-height: 1.1;
      color: #ffffff;
      margin: 0 0 20px;
      letter-spacing: -0.5px;
    }
    .hero-highlight {
      color: #84c341;
    }
    .hero-subtitle {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 17px;
      line-height: 1.6;
      color: rgba(255,255,255,0.80);
      margin: 0 0 32px;
      max-width: 520px;
    }

    /* Search */
    .hero-search {
      display: flex;
      align-items: center;
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      max-width: 540px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    }
    .hero-search-input {
      flex: 1;
      border: none;
      outline: none;
      padding: 16px 20px;
      font-family: 'Nunito Sans', sans-serif;
      font-size: 15px;
      color: #111;
      background: transparent;
    }
    .hero-search-input::placeholder { color: #9ca3af; }
    .hero-search-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      background: none;
      border: none;
      cursor: pointer;
      color: #374151;
      transition: color 0.15s;
      flex-shrink: 0;
    }
    .hero-search-btn:hover { color: #0d3b22; }

    /* ======= CATEGORIES ======= */
    .categories-section {
      background: #ffffff;
      padding: 0 24px;
    }

    .categories-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      background: #eaf7ef;
      border-radius: 20px;
      padding: 24px;
      transform: translateY(-48px);
      margin-bottom: -48px;
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
    }

    @media (max-width: 1024px) {
      .categories-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 600px) {
      .categories-grid { grid-template-columns: repeat(2, 1fr); }
      .categories-wrapper { padding: 16px; transform: translateY(-28px); }
    }

    .cat-card {
      position: relative;
      background: #ffffff;
      border: 1px solid transparent;
      border-radius: 16px;
      padding: 24px 16px 20px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
      transition: border-color 0.2s;
    }
    .cat-card:hover {
      border-color: #b0ccc0;
    }

    .cat-arrow {
      position: absolute;
      top: 16px;
      right: 18px;
      font-size: 16px;
      color: #b0bec5;
      font-style: normal;
      transition: transform 0.2s ease, color 0.2s;
    }
    .cat-card:hover .cat-arrow {
      transform: translate(3px, -3px);
      color: #2d6a4f;
    }
    .cat-card:hover .cat-title {
      color: #2d6a4f;
    }

    .cat-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 90px;
      height: 90px;
      flex-shrink: 0;
    }
    .cat-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .cat-title {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: #0f172a;
      margin: 0;
      line-height: 1.25;
      transition: color 0.2s;
    }
    .cat-desc {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 13px;
      font-weight: 400;
      color: #6b7280;
      margin: 0;
      line-height: 1.5;
    }
  </style>

  <section class="bg-slate-100 py-16">
    <div style="max-width: 1100px; margin: 0 auto; padding-left: 34px; padding-right: 34px;">
      <div class="grid grid-cols-1 lg:grid-cols-2 items-start" style="gap: 37px;">
        <div class="max-w-2xl">
          <h2 style="font-weight: 700; color: rgb(25, 45, 75); font-size: 38px; line-height: 46px;">Avaliações Populares</h2>
          <p style="font-style: normal; font-weight: 600; color: #314a6f; font-size: 22px; line-height: 26px; margin-top: 12px;">Compare planos e preços dos melhores serviços para o seu negócio</p>
        </div>

        <div class="w-full max-w-2xl space-y-3">
          <p style="font-style: normal; font-weight: 400; color: rgb(100, 100, 100); font-size: 16px; line-height: 24px;">Confira nossa pesquisa sobre os melhores serviços e produtos em cada categoria.</p>
          <p style="font-style: normal; font-weight: 400; color: rgb(100, 100, 100); font-size: 16px; line-height: 24px;">Essas são as avaliações mais populares em nosso site, <strong>atualizadas mensalmente</strong>.</p>
        </div>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href="/melhores-contabilidades-online/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/icon-contabilidade-com.webp" alt="Contabilidade.com" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-colinear.webp" alt="Colinear" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-agilize-contabilidade.webp" alt="Agilize" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-contaja-contabilidade.webp" alt="Contajá" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Melhores Contabilidades Online em 2026
            </h3>
          </div>
        </a>

        <a href="/melhores-maquininhas-cartao-voucher-refeicao/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/icon-stone-.webp" alt="Stone" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-mercado-pago.webp" alt="Mercado Pago" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/sumup-icon.webp" alt="SumUp" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-pagbank-.webp" alt="PagBank" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Maquininhas que aceita VR e VA (Atualizado 2026)
            </h3>
          </div>
        </a>

        <a href="/melhores-sistemas-pdv/" class="group block cursor-pointer transition-all duration-300 h-full">
          <div class="bg-white border-2 border-white rounded-2xl p-5 shadow-sm group-hover:bg-[#deedf8] group-hover:border-[#007eff] transition-all duration-300 h-full">
            <div class="h-[64px] flex items-center mb-3 relative">
              <img src="/images/egestor-erp.webp" alt="eGestor" class="w-[64px] h-[64px] z-40 transition-all duration-300" />
              <img src="/images/icon-bling-erp-.webp" alt="Bling" class="w-[64px] h-[64px] z-30 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-soften-erp.webp" alt="Soften" class="w-[64px] h-[64px] z-20 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
              <img src="/images/icon-omie.webp" alt="Omie" class="w-[64px] h-[64px] z-10 transition-all duration-300 group-hover:!ml-[-28px]" style="margin-left: -36px" />
            </div>
            <h3 style="font-weight: 600; font-size: 22px; line-height: 29px;" class="text-[#244d6a] transition-colors duration-300 group-hover:text-[#007eff]">
              Melhores Sistemas de PDV em 2026
            </h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- SEÇÃO DE CONFIANÇA -->
  <section class="trust-section">
    <div class="trust-inner">

      <!-- Esquerda: foto -->
      <div class="trust-photo-wrap">
        <img src="/images/nnegociocerto.png" alt="Especialista NegócioCerto" class="trust-photo" />
      </div>

      <!-- Direita: conteúdo -->
      <div class="trust-right">

        <h2 class="trust-title">Por que empreendedores confiam no NegócioCerto?</h2>

        <!-- Stats horizontais -->
        <div class="trust-stats">
          <div class="trust-stat">
            <span class="trust-stat-number">50<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">produtos avaliados com critérios rigorosos</span>
          </div>
          <div class="trust-stat">
            <span class="trust-stat-number">2.000<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">horas de pesquisa e testes realizados</span>
          </div>
          <div class="trust-stat">
            <span class="trust-stat-number">10<span class="trust-stat-plus">+</span></span>
            <span class="trust-stat-label">anos acompanhando o mercado empreendedor</span>
          </div>
        </div>

        <!-- Logos com scroll -->
        <div class="trust-logos-wrap">
          <p class="trust-logos-label">PRODUTOS QUE JÁ AVALIAMOS E TESTAMOS</p>
          <div class="trust-logos-track-outer">
            <div class="trust-logos-track">
              <img src="/images/logo-pagbank.png" alt="PagBank" />
              <img src="/images/logo-mercado-pago.png" alt="Mercado Pago" />
              <img src="/images/logo-sumup.png" alt="SumUp" />
              <img src="/images/logo-ton.webp" alt="Ton" />
              <img src="/images/logo-contabilidade-com.png" alt="Contabilidade.com" />
              <img src="/images/contabilizei-logo.png" alt="Contabilizei" />
              <img src="/images/agilize-contabilidade-online-logo.png" alt="Agilize" />
              <img src="/images/colinear-logo.png" alt="Colinear" />
              <!-- duplicados para loop contínuo -->
              <img src="/images/logo-pagbank.png" alt="PagBank" aria-hidden="true" />
              <img src="/images/logo-mercado-pago.png" alt="Mercado Pago" aria-hidden="true" />
              <img src="/images/logo-sumup.png" alt="SumUp" aria-hidden="true" />
              <img src="/images/logo-ton.webp" alt="Ton" aria-hidden="true" />
              <img src="/images/logo-contabilidade-com.png" alt="Contabilidade.com" aria-hidden="true" />
              <img src="/images/contabilizei-logo.png" alt="Contabilizei" aria-hidden="true" />
              <img src="/images/agilize-contabilidade-online-logo.png" alt="Agilize" aria-hidden="true" />
              <img src="/images/colinear-logo.png" alt="Colinear" aria-hidden="true" />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style>
    /* ======= TRUST SECTION ======= */
    .trust-section {
      background: #ffffff;
      padding: 64px 32px;
      border-top: 1px solid #f0f0f0;
      overflow: hidden;
    }
    .trust-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 56px;
      align-items: center;
    }
    @media (max-width: 900px) {
      .trust-inner { grid-template-columns: 1fr; gap: 32px; }
      .trust-photo-wrap { display: none; }
      .trust-section { padding: 48px 20px; }
    }

    /* Foto */
    .trust-photo-wrap {
      flex-shrink: 0;
      background: #d4f0e2;
      border-radius: 24px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      min-height: 320px;
    }
    .trust-photo {
      width: 100%;
      max-width: 300px;
      height: auto;
      display: block;
      object-fit: cover;
      object-position: top center;
    }

    /* Direita */
    .trust-right {
      min-width: 0;
    }

    /* Título */
    .trust-title {
      font-family: 'Inter', sans-serif;
      font-size: clamp(26px, 3vw, 44px);
      font-weight: 700;
      color: #111111;
      line-height: 1.1;
      margin: 0 0 36px;
      word-break: break-word;
      letter-spacing: -0.3px;
    }

    /* Stats */
    .trust-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      margin-bottom: 36px;
    }
    @media (max-width: 500px) {
      .trust-stats { grid-template-columns: 1fr; }
    }
    .trust-stat { display: flex; flex-direction: column; gap: 8px; min-width: 0; }
    .trust-stat-number {
      font-family: 'Inter', sans-serif;
      font-size: clamp(36px, 4.5vw, 56px);
      font-weight: 700;
      color: #2d6a4f;
      line-height: 1;
    }
    .trust-stat-plus {
      color: #84c341;
    }
    .trust-stat-label {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 15px;
      color: #374151;
      font-weight: 400;
      line-height: 1.45;
    }

    /* Logos com scroll */
    .trust-logos-wrap {
      padding-top: 24px;
    }
    .trust-logos-label {
      font-family: 'Nunito Sans', sans-serif;
      font-size: 11px;
      font-weight: 700;
      color: #9ca3af;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin: 0 0 16px;
      display: flex;
      align-items: center;
      gap: 14px;
      white-space: nowrap;
    }
    .trust-logos-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e5e7eb;
    }
    .trust-logos-track-outer {
      overflow: hidden;
      width: 100%;
      mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    }
    .trust-logos-track {
      display: flex;
      align-items: center;
      gap: 48px;
      width: max-content;
      animation: logos-scroll 22s linear infinite;
    }
    .trust-logos-track:hover { animation-play-state: paused; }
    .trust-logos-track img {
      height: 26px;
      width: auto;
      object-fit: contain;
      filter: grayscale(100%);
      opacity: 0.5;
      flex-shrink: 0;
    }

    @keyframes logos-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <section class="bg-white py-16">
    <div style="max-width: 1100px; margin: 0 auto; padding-left: 34px; padding-right: 34px;">
      <div class="flex items-end justify-between gap-4 mb-8">
        <h2 class="!text-[28px] !leading-tight font-bold text-slate-800">Posts recentes do blog</h2>
        <a href="/blog" class="text-sm font-semibold text-yellow-400 hover:text-yellow-400">Ver todos</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
      recentPosts.map((post) => (
        <a href={`/blog/${post.id}/`} class="group block rounded-2xl border border-slate-200 bg-white overflow-hidden hover:border-slate-300 transition-colors duration-200">
          {post.data.heroImage && (
            <Image src={post.data.heroImage} alt={post.data.title} width={720} height={360} class="w-full h-44 object-cover rounded-none" />
          )}
          <div class="p-5">
            <p class="text-xs text-slate-500 mb-2">
              <FormattedDate date={post.data.pubDate} />
            </p>
            <h3 class="font-semibold !text-[20px] leading-snug text-slate-800 group-hover:text-slate-900 transition-colors duration-200">
              {post.data.title}
            </h3>
            <p class="mt-3 text-sm text-slate-500 line-clamp-3">{post.data.description}</p>
          </div>
        </a>
      ))
    }
      </div>
    </div>
  </section>
</Layout>
