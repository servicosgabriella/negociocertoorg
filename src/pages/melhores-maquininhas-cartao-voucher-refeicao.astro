---
import ReviewLayout from '../layouts/ReviewLayout.astro';
import { getBreadcrumb, getSubcategoria } from '../data/estrutura';

const subcategoria = getSubcategoria('financas', 'maquininhas');
const breadcrumb = getBreadcrumb('financas', 'Maquininhas que aceitam voucher e vale refeição (2026)', subcategoria);
