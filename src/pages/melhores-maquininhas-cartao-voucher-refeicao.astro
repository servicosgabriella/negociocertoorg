                        <tbody>
                            <tr><td style="padding:8px;border:1px solid #e5e7eb;">Débito</td><td style="padding:8px;text-align:center;border:1px solid #e5e7eb;">0,57%</td><td style="padding:8px;text-align:center;border:1px solid #e5e7eb;">0,57%</td></tr>
                            <tr style="background:#fafafa;"><td style="padding:8px;border:1px solid #e5e7eb;">Crédito à vista</td><td style="padding:8px;text-align:center;border:1px solid #e5e7eb;">0,57%</td><td style="padding:8px;text-align:center;border:1px solid #e5e7eb;">0,57%</td></tr>
