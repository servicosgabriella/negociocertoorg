    <style>
        .plan-item-foto {
            display: flex;
            align-items: stretch;
            padding: 0 !important;
            overflow: hidden;
            gap: 0;
        }
        .plan-item-foto .foto-col {
            width: 220px;
            min-height: 200px;
            background: #eef2f7;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .plan-item-foto .foto-col img {
            width: 220px;
            height: 200px;
            object-fit: contain;
            display: block;
        }
        .plan-item-foto .info-col {
            flex: 1;
            padding: 16px;
            min-width: 0;
        }
        .plan-item-foto .plan-title {
            font-size: 16px;
            color: #1f2937;
            letter-spacing: 0.02em;
            text-transform: none;
            margin-bottom: 8px;
        }
        @media (max-width: 600px) {
            .plan-item-foto {
                flex-direction: column;
            }
            .plan-item-foto .foto-col {
                width: 100%;
                min-height: 110px;
            }
            .plan-item-foto .foto-col img {
                width: 100%;
                height: 110px;
            }
            .plan-item-foto .info-col {
                padding: 14px;
            }
            .plan-item-foto .plan-title {
                font-size: 15px;
            }
        }

        /* Novo hero card de maquininha */
        .maquininha-hero-card {
            border: 1.5px solid #e5e7eb;
            border-radius: 14px;
            overflow: hidden;
            background: #fff;
            margin: 20px 0 28px;
            display: flex;
            flex-direction: column;
        }
        .mhc-badge {
            background: #ecfdf5;
            border-bottom: 1px solid #e5e7eb;
            padding: 10px 24px;
            font-size: 13px;
            font-weight: 600;
            color: #065f46;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .mhc-badge i {
            font-size: 15px;
            color: #059669;
        }
        .mhc-body {
            display: flex;
            gap: 28px;
            padding: 24px 28px;
        }
        .mhc-left {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-width: 190px;
            max-width: 200px;
        }
        .mhc-product-img {
            display: block;
        }
        .mhc-product-img img {
            width: 175px;
            height: 175px;
            object-fit: contain;
        }
        .mhc-right {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-width: 0;
        }
        .mhc-product-name {
            font-size: 19px;
            font-weight: 700;
            color: #1a3a5c;
            margin: 0 0 4px;
            border: none;
            padding: 0;
        }
        .mhc-metrics {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            overflow: hidden;
        }
        .mhc-metrics-secondary {
            grid-template-columns: repeat(3, 1fr);
            margin-top: -4px;
        }
        .mhc-metric {
            padding: 10px 14px;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .mhc-metric:last-child {
            border-right: none;
        }
        .mhc-metric-label {
            font-size: 11px;
            color: #7e8a98;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .mhc-metric-value {
            font-size: 16px;
            font-weight: 700;
            color: #1a3a5c;
        }
        .mhc-metrics-secondary .mhc-metric-value {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
        }
        .mhc-price-block {
            border-top: 1px solid #f3f4f6;
            padding-top: 10px;
        }
        .mhc-installment {
            font-size: 14px;
            color: #7e8a98;
        }
        .mhc-installment strong {
            font-size: 16px;
            color: #1a3a5c;
        }
        .mhc-cta-button {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #1a3a5c;
            color: #fff !important;
            border-radius: 8px;
            padding: 15px 20px;
            text-decoration: none !important;
            text-align: center;
            transition: background 0.2s;
        }
        .mhc-cta-button:hover {
            background: #2d6a9f;
        }
        .mhc-cta-main {
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }
        .mhc-cta-sub {
            font-size: 11px;
            opacity: 0.8;
            text-transform: uppercase;
            margin-top: 3px;
            letter-spacing: 0.05em;
        }
        .mhc-domain {
            font-size: 12px;
            color: #7e8a98;
            text-align: center;
        }
        @media (max-width: 720px) {
            .mhc-body {
                flex-direction: column;
                padding: 16px;
                gap: 16px;
            }
            .mhc-left {
                max-width: 100%;
                min-width: unset;
            }
            .mhc-product-img {
                display: none;
            }
            .mhc-metrics {
                grid-template-columns: 1fr 1fr;
            }
            .mhc-metrics-secondary {
                grid-template-columns: 1fr 1fr;
            }
        }

