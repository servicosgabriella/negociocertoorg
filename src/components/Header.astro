---
import { estrutura } from '../data/estrutura';
---

<header class="site-header">
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="header-logo">
      <span class="header-logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;color:#fff;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.414l-7.5 7.5a1 1 0 01-1.414 0l-3.5-3.5a1 1 0 111.414-1.414l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </span>
      <span class="header-logo-text">
        <span class="logo-green">negócio</span><span class="logo-dark">certo</span>
      </span>
    </a>

    <!-- NAV DESKTOP -->
    <nav class="header-nav-desktop" aria-label="Navegação principal">

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Finanças
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title">ERP e Sistemas de Gestão</span>
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Maquininhas de Cartão</span>
              {estrutura.financas.subcategorias.maquininhas.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Contabilidade Online</span>
              {estrutura.financas.subcategorias.contabilidade.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Planejamento
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title">Plano de Negócios</span>
              {estrutura.planejamento.subcategorias.plano_negocios.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Registro de Marca</span>
              {estrutura.planejamento.subcategorias.registro_marca.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Gestão
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title">Sistema PDV</span>
              {estrutura.gestao.subcategorias.pdv.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Nota Fiscal Eletrônica</span>
              {estrutura.gestao.subcategorias.nfe.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          RH
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title">Plataforma de Recrutamento</span>
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Folha de Pagamento Online</span>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Calculadoras
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title">Calculadoras Financeiras</span>
              {estrutura.calculadoras.subcategorias.financeiras.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Calculadoras Trabalhistas</span>
              {estrutura.calculadoras.subcategorias.trabalhistas.paginas.map(p => (
                <a href={p.href + '/'} class="megamenu-article">{p.label}</a>
              ))}
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Calculadora de Empréstimo</span>
            </div>
            <div class="megamenu-col">
              <span class="megamenu-col-title">Calculadora de Datas</span>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Seguros
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title" style="color:#9ca3af !important; cursor:default;">Em breve</span>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-item">
        <button class="nav-link" onclick="handleNavClick(event, this)">
          Ferramentas
          <svg class="nav-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.51a.75.75 0 01-1.08 0l-4.25-4.51a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <div class="megamenu-cols">
            <div class="megamenu-col">
              <span class="megamenu-col-title" style="color:#9ca3af !important; cursor:default;">Em breve</span>
            </div>
          </div>
        </div>
      </div>

      <a href={estrutura.blog.href} class="nav-link nav-link-simple">Blog</a>

    </nav>

    <!-- DIREITA: busca + mobile -->
    <div class="header-right">
      <a href="/busca" class="search-icon-btn" aria-label="Buscar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" />
        </svg>
      </a>

      <!-- HAMBURGER MOBILE -->
      <div class="mobile-toggle-wrapper">
        <input id="mobile-menu-toggle" type="checkbox" class="peer sr-only" />
        <label for="mobile-menu-toggle" class="mobile-hamburger" aria-label="Abrir menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
        <label for="mobile-menu-toggle" class="mobile-overlay" aria-label="Fechar menu"></label>
        <aside class="mobile-sidebar">
          <div class="mobile-sidebar-header">
            <span class="mobile-sidebar-title">Navegação</span>
            <label for="mobile-menu-toggle" class="mobile-close" aria-label="Fechar menu">×</label>
          </div>
          <nav class="mobile-nav">

            <!-- FINANÇAS -->
            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Finanças
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <span class="mobile-subcat-title">ERP / Sistema de Gestão</span>
                <span class="mobile-subcat-title">Maquininhas de Cartão</span>
                {estrutura.financas.subcategorias.maquininhas.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
                <span class="mobile-subcat-title">Contabilidade Online</span>
                {estrutura.financas.subcategorias.contabilidade.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
              </div>
            </div>

            <!-- PLANEJAMENTO -->
            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Planejamento
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <span class="mobile-subcat-title">Plano de Negócios</span>
                {estrutura.planejamento.subcategorias.plano_negocios.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
                <span class="mobile-subcat-title">Registro de Marca</span>
                {estrutura.planejamento.subcategorias.registro_marca.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
              </div>
            </div>

            <!-- GESTÃO -->
            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Gestão
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <span class="mobile-subcat-title">Sistema PDV</span>
                {estrutura.gestao.subcategorias.pdv.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
                <span class="mobile-subcat-title">Nota Fiscal Eletrônica</span>
                {estrutura.gestao.subcategorias.nfe.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
              </div>
            </div>

            <!-- RH -->
            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                RH
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <span class="mobile-subcat-title">Plataforma de Recrutamento</span>
                <span class="mobile-subcat-title">Folha de Pagamento Online</span>
              </div>
            </div>

            <!-- CALCULADORAS -->
            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Calculadoras
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <span class="mobile-subcat-title">Calculadoras Financeiras</span>
                {estrutura.calculadoras.subcategorias.financeiras.paginas.map(p => (
                  <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                ))}
                <span class="mobile-subcat-title">Calculadoras Trabalhistas</span>
                <span class="mobile-subcat-title">Calculadora de Empréstimo</span>
                <span class="mobile-subcat-title">Calculadora de Datas</span>
              </div>
            </div>

            <a href={estrutura.seguros.href} class="mobile-section-title mobile-blog-link">Seguros</a>
            <a href={estrutura.ferramentas.href} class="mobile-section-title mobile-blog-link">Ferramentas</a>
            <a href={estrutura.blog.href} class="mobile-section-title mobile-blog-link">Blog</a>
          </nav>
        </aside>
      </div>
    </div>

  </div>
</header>

<!-- SCRIPTS -->
<script is:inline>
  function handleNavClick(event, btn) {
    event.preventDefault();
    const item = btn.closest('.nav-item');
    const menu = item.querySelector('.dropdown-menu');
    if (!menu.classList.contains('open')) {
      closeAllDropdowns();
      menu.classList.add('open');
      btn.classList.add('active');
    } else {
      closeAllDropdowns();
    }
  }

  function closeAllDropdowns() {
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
    document.querySelectorAll('.nav-link.active').forEach(l => l.classList.remove('active'));
  }

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-item')) closeAllDropdowns();
  });

  function toggleMobileSection(btn) {
    const items = btn.nextElementSibling;
    const arrow = btn.querySelector('.mobile-section-arrow');
    const isOpen = items.classList.contains('open');
    if (!isOpen) {
      items.classList.add('open');
      if (arrow) arrow.style.transform = 'rotate(180deg)';
    } else {
      items.classList.remove('open');
      if (arrow) arrow.style.transform = '';
    }
  }
</script>

<style is:global>
  /* ===================== RESET / BASE ===================== */
  .site-header * {
    font-family: 'Nunito Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    box-sizing: border-box;
  }

  /* ===================== HEADER WRAPPER ===================== */
  .site-header {
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* ===================== LOGO ===================== */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .header-logo-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: #16a34a;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .header-logo-text {
    font-size: 22px;
    font-weight: 800;
    text-transform: lowercase;
    line-height: 1;
    letter-spacing: -0.3px;
  }
  .logo-green { color: #16a34a; }
  .logo-dark  { color: #111827; }

  /* ===================== NAV DESKTOP ===================== */
  .header-nav-desktop {
    display: none;
    align-items: stretch;
    flex: 1;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .header-nav-desktop { display: flex; }
  }

  .nav-item {
    position: static;
    display: flex;
    align-items: stretch;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0 12px;
    font-size: 14px;
    font-weight: 700;
    color: #1f2937 !important;
    text-decoration: none;
    background: none;
    border: none;
    border-bottom: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s;
    line-height: 1;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    background: linear-gradient(to right, #337651, #62a355, #599c55);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: #62a355 !important;
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    opacity: 1;
  }
  .nav-item:hover .nav-link {
    color: #62a355 !important;
  }
  .nav-item:hover .nav-link::after {
    opacity: 1;
  }

  .nav-arrow {
    width: 12px;
    height: 12px;
    color: #6b7280;
    transition: transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .nav-link.active .nav-arrow,
  .nav-item:hover .nav-arrow {
    transform: rotate(180deg);
    color: #62a355;
  }

  .nav-link-simple {
    border-bottom: none;
  }
  .nav-link-simple:hover {
    color: #62a355 !important;
  }

  /* ===================== MEGAMENU ===================== */
  .dropdown-menu {
    position: fixed;
    left: 0;
    right: 0;
    top: 64px;
    width: 100%;
    background: #ffffff;
    box-shadow: 0 8px 30px rgba(0,0,0,0.10);
    border-top: 2px solid #e5e7eb;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s, visibility 0.18s;
    z-index: 200;
  }
  .dropdown-menu.open,
  .nav-item:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
  }

  .megamenu-cols {
    display: flex;
    gap: 0;
    max-width: 1400px;
    margin: 0 auto;
    padding: 28px 32px;
  }
  .megamenu-col {
    flex: 1;
    padding-right: 28px;
    border-right: 1px solid #f0f0f0;
  }
  .megamenu-col:last-child {
    padding-right: 0;
    border-right: none;
  }
  .megamenu-col:not(:first-child) { padding-left: 28px; }

  .megamenu-col-title {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: #111827 !important;
    text-decoration: none;
    margin-bottom: 10px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e5e7eb;
    transition: color 0.15s;
  }
  .megamenu-col-title:hover { color: #337651 !important; }

  .megamenu-article {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: #374151 !important;
    text-decoration: none;
    line-height: 1.5;
    padding: 8px 0;
    border-bottom: 1px solid #f3f4f6;
    transition: color 0.15s;
  }
  .megamenu-article:last-child { border-bottom: none; }
  .megamenu-article:hover {
    color: #337651 !important;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===================== DIREITA: busca + mobile ===================== */
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .search-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: #374151;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .search-icon-btn:hover {
    background: #f3f4f6;
    color: #111827;
  }

  /* ===================== MOBILE TOGGLE ===================== */
  .mobile-toggle-wrapper { display: block; }
  @media (min-width: 1024px) { .mobile-toggle-wrapper { display: none; } }

  .mobile-hamburger {
    cursor: pointer;
    color: #374151;
    display: inline-flex;
    align-items: center;
    padding: 4px;
  }
  .mobile-hamburger:hover { color: #111827; }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 140;
    opacity: 0;
    visibility: hidden;
