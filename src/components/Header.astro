<!-- SCRIPTS -->
<script is:inline>
  function handleNavClick(event, btn) {
    const dropdown = btn.closest('.nav-dropdown');
    const menu = dropdown.querySelector('.dropdown-menu');
    if (!menu.classList.contains('open')) {
      event.preventDefault();
      closeAllDropdowns();
      menu.classList.add('open');
      btn.classList.add('active');
    } else {
      // segundo clique: navega para a categoria
      const href = btn.getAttribute('data-href');
      if (href) window.location.href = href;
    }
  }

  function closeAllDropdowns() {
    document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
    document.querySelectorAll('.nav-link.active').forEach(l => l.classList.remove('active'));
  }

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-dropdown')) closeAllDropdowns();
  });

  function toggleMobileSection(btn) {
    const items = btn.nextElementSibling;
    const arrow = btn.querySelector('.mobile-section-arrow');
    const isOpen = items.classList.contains('open');
    if (!isOpen) {
      items.classList.add('open');
      if (arrow) arrow.style.transform = 'rotate(180deg)';
    } else {
      items.classList.remove('open');
      if (arrow) arrow.style.transform = '';
      items.querySelectorAll('.mobile-sub-menu.open').forEach(s => {
        s.classList.remove('open');
        const a = s.previousElementSibling?.querySelector('.mobile-sub-arrow');
        if (a) a.style.transform = '';
      });
    }
  }

  function toggleMobileSub(btn) {
    const subMenu = btn.nextElementSibling;
    const arrow = btn.querySelector('.mobile-sub-arrow');
    const isOpen = subMenu.classList.contains('open');
    subMenu.classList.toggle('open', !isOpen);
    if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
  }
</script>

<style is:global>
  /* ===================== HEADER BASE ===================== */
  .site-header {
    background: #0f0f0f;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* ===================== LINHA 1: LOGO + BUSCA ===================== */
  .header-top {
    background: #0f0f0f;
    border-bottom: 1px solid #0f0f0f;
  }
  .header-top-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 14px 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* LOGO */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: #facc15;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: lowercase;
    line-height: 1;
  }
  .logo-white { color: #fff; }
  .logo-yellow { color: #facc15; }

  /* BARRA DE BUSCA */
  .search-form {
    display: none;
    align-items: center;
    background: #fff;
    border-radius: 6px;
    overflow: hidden;
    width: 100%;
    max-width: 520px;
  }
  @media (min-width: 768px) {
    .search-form { display: flex; }
  }
  .search-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 10px 16px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    color: #111;
    background: transparent;
  }
  .search-input::placeholder { color: #9ca3af; }
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 14px;
    height: 100%;
    background: #facc15;
    border: none;
    cursor: pointer;
    color: #111;
    transition: background 0.15s;
    min-height: 40px;
  }
  .search-btn:hover { background: #eab308; }

  /* ===================== LINHA 2: NAV CATEGORIAS ===================== */
  .header-nav {
    background: #0f0f0f;
    border-bottom: 1px solid #222;
    position: relative;
    display: none;
  }
  @media (min-width: 768px) {
    .header-nav { display: block; }
  }
  .header-nav-inner {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 65px;
    display: flex;
    align-items: stretch;
    justify-content: space-between;
  }

  /* NAV LINKS */
  .nav-dropdown {
    position: static;
    display: flex;
  }
  .nav-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 14px 16px;
    font-family: Arial, sans-serif;
