                </button>
                <div class="mobile-sub-menu">
                  {estrutura.planejamento.subcategorias.registro_marca.paginas.map(p => (
                    <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                  ))}
                </div>
              </div>
            </div>

            <div class="mobile-section">
