---
import { estrutura } from '../data/estrutura';
---

<header class="site-header">

  <!-- LINHA 1: Logo + Busca -->
  <div class="header-top">
    <div class="header-top-inner">
      <a href="/" class="header-logo">
        <span class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-black" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.414l-7.5 7.5a1 1 0 01-1.414 0l-3.5-3.5a1 1 0 111.414-1.414l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </span>
        <span class="logo-text">
          <span class="logo-white">negócio</span><span class="logo-yellow">certo</span>
        </span>
      </a>

      <!-- BUSCA DESKTOP -->
      <form class="search-form" action="/busca" method="get" role="search">
        <input class="search-input" type="search" name="q" placeholder="Buscar artigos, comparativos..." aria-label="Buscar" />
        <button class="search-btn" type="submit" aria-label="Buscar">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m0 0A7.5 7.5 0 1 0 6 6a7.5 7.5 0 0 0 10.65 10.65Z" />
          </svg>
        </button>
      </form>

      <!-- HAMBURGER MOBILE -->
      <div class="mobile-toggle-wrapper">
        <input id="mobile-menu-toggle" type="checkbox" class="peer sr-only" />
        <label for="mobile-menu-toggle" class="mobile-hamburger" aria-label="Abrir menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
        <label for="mobile-menu-toggle" class="mobile-overlay" aria-label="Fechar menu"></label>
        <aside class="mobile-sidebar">
          <div class="mobile-sidebar-header">
            <span class="mobile-sidebar-title">Navegação</span>
            <label for="mobile-menu-toggle" class="mobile-close" aria-label="Fechar menu">×</label>
          </div>
          <nav class="mobile-nav">

            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Finanças
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <a href={estrutura.financas.subcategorias.erp.href} class="mobile-item">ERP / Sistema de Gestão</a>
                <button class="mobile-item mobile-sub-trigger" onclick="toggleMobileSub(this)">
                  Maquininha de Cartão
                  <svg xmlns="http://www.w3.org/2000/svg" class="mobile-sub-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="mobile-sub-menu">
                  {estrutura.financas.subcategorias.maquininhas.paginas.map(p => (
                    <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                  ))}
                </div>
                <button class="mobile-item mobile-sub-trigger" onclick="toggleMobileSub(this)">
                  Contabilidade Online
                  <svg xmlns="http://www.w3.org/2000/svg" class="mobile-sub-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="mobile-sub-menu">
                  {estrutura.financas.subcategorias.contabilidade.paginas.map(p => (
                    <a href={p.href + '/'} class="mobile-item mobile-sub-item">{p.label}</a>
                  ))}
                </div>
              </div>
            </div>

            <div class="mobile-section">
              <button class="mobile-section-title" onclick="toggleMobileSection(this)">
                Planejamento
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-section-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div class="mobile-section-items">
                <button class="mobile-item mobile-sub-trigger" onclick="toggleMobileSub(this)">
                  Plano de Negócios
